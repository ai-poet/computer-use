{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_JbjTNzfhvbsFoh9KcyxA26wV","type":"tool_result","content":"150\t    await cmd_step_key(out_dir, \"enter\")\n151\t    await asyncio.sleep(2.0)\n152\t    _emit({\"ok\": True, \"action\": \"open-url\", \"url\": url})\n153\t    return 0\n154\t\n155\t\n156\tasync def cmd_bootstrap(\n157\t    out_dir: Path,\n158\t    *,\n159\t    open_browser: bool,\n160\t    url: str | None = None,\n161\t) -> int:\n162\t    apply_no_proxy_env()\n163\t    out_dir = out_dir.resolve()\n164\t    if sandbox_json_path(out_dir).is_file():\n165\t        print(f\"error: {SANDBOX_JSON} already exists; run teardown first\", file=sys.stderr)\n166\t        return 1\n167\t\n168\t    runtime = os.environ.get(\"ANALYZER_RUNTIME\", \"sandbox-local\")\n169\t    image_key = os.environ.get(\"ANALYZER_SANDBOX_IMAGE\", \"linux\").lower()\n170\t    local = runtime != \"sandbox-cloud\"\n171\t    name = _derive_sandbox_name(out_dir)\n172\t\n173\t    from cua import Sandbox\n174\t\n175\t    if local:\n176\t        if image_key not in (\"auto\", \"linux\"):\n177\t            print(\n178\t                f\"warning: sandbox_ctl bootstrap only implements linux container; \"\n179\t                f\"got image={image_key!r}\",\n180\t                file=sys.stderr,\n181\t            )\n182\t        sb = await Sandbox.create(\n183\t            linux_container_image(),\n184\t            name=name,\n185\t            local=True,\n186\t            runtime=linux_docker_runtime(ephemeral=False),\n187\t        )\n188\t        provider = \"docker\"\n189\t        image = os.environ.get(\"ANALYZER_LINUX_CONTAINER_IMAGE\", LINUX_CONTAINER_IMAGE)\n190\t        platform = os.environ.get(\"ANALYZER_LINUX_DOCKER_PLATFORM\", LINUX_DOCKER_PLATFORM)\n191\t    else:\n192\t        api_key = os.environ.get(\"CUA_API_KEY\", \"\").strip()\n193\t        if not api_key:\n194\t            print(\"error: CUA_API_KEY required for cloud bootstrap\", file=sys.stderr)\n195\t            return 1\n196\t        from cua import Image\n197\t\n198\t        sb = await Sandbox.create(Image.linux(), name=name, local=False, api_key=api_key)\n199\t        provider = \"cloud\"\n200\t        image = \"linux\"\n201\t        platform = None\n202\t\n203\t    api_url = _api_url_from_sb(sb)\n204\t    info = {\n205\t        \"name\": sb.name or name,\n206\t        \"provider\": provider,\n207\t        \"api_url\": api_url,\n208\t        \"image\": image,\n209\t        \"platform\": platform,\n210\t        \"local\": local,\n211\t    }\n212\t    write_sandbox_info(out_dir, info)\n213\t    _merge_metadata_sandbox(out_dir, info[\"name\"], api_url, local)\n214\t    await sb.disconnect()\n215\t\n216\t    _emit({\"ok\": True, \"sandbox\": info})\n217\t\n218\t    if open_browser:\n219\t        target = (url or os.environ.get(\"ANALYZER_PRODUCT_URL\") or \"\").strip()\n220\t        if target:\n221\t            return await cmd_step_open_url(out_dir, target, launch=True)\n222\t        return await _launch_browser_once(out_dir)\n223\t    return 0\n224\t\n225\t\n226\tasync def cmd_teardown(out_dir: Path) -> int:\n227\t    apply_no_proxy_env()\n228\t    out_dir = out_dir.resolve()\n229\t    path = sandbox_json_path(out_dir)\n230\t    if not path.is_file():\n231\t        _emit({\"ok\": True, \"skipped\": \"no sandbox.json\"})\n232\t        return 0\n233\t    info = load_sandbox_info(out_dir)\n234\t    from cua import Sandbox\n235\t\n236\t    try:\n237\t        await Sandbox.delete(\n238\t            info[\"name\"],\n239\t            local=bool(info.get(\"local\", True)),\n240\t            api_key=os.environ.get(\"CUA_API_KEY\") if not info.get(\"local\", True) else None,\n241\t        )\n242\t    except Exception as exc:\n243\t        print(f\"warning: Sandbox.delete: {exc}\", file=sys.stderr)\n244\t    path.unlink(missing_ok=True)\n245\t    _emit({\"ok\": True, \"deleted\": info[\"name\"]})\n246\t    return 0\n247\t\n248\t\n249\tdef cmd_status(out_dir: Path) -> int:\n250\t    out_dir = out_dir.resolve()\n251\t    path = sandbox_json_path(out_dir)\n252\t    if not path.is_file():\n253\t        _emit({\"ok\": False, \"error\": f\"no {SANDBOX_JSON} in {out_dir}\"})\n254\t        return 1\n255\t    info = load_sandbox_info(out_dir)\n256\t    _emit({\"ok\": True, \"sandbox\": info})\n257\t    print(json.dumps(info, indent=2, ensure_ascii=False))\n258\t    api_url = info.get(\"api_url\", \"\")\n259\t    if api_url:\n260\t        try:\n261\t            req = urllib.request.Request(f\"{api_url.rstrip('/')}/status\", method=\"GET\")\n262\t            with urllib.request.urlopen(req, timeout=5) as resp:\n263\t                body = resp.read().decode(\"utf-8\", errors=\"replace\")[:500]\n264\t            print(f\"GET {api_url}/status -> {resp.status} {body[:200]}\")\n265\t        except Exception as exc:\n266\t            print(f\"GET {api_url}/status failed: {exc}\", file=sys.stderr)\n267\t            return 1\n268\t    return 0\n269\t\n270\t\n271\tasync def cmd_step_screenshot(out_dir: Path, out_path: Path) -> int:\n272\t    apply_no_proxy_env()\n273\t    info = load_sandbox_info(out_dir)\n274\t    out_path = out_path if out_path.is_absolute() else (out_dir.resolve() / out_path)\n275\t    out_path.parent.mkdir(parents=True, exist_ok=True)\n276\t\n277\t    async with _connect_from_info(info) as sb:\n278\t        png = await sb.screenshot()\n279\t\n280\t    out_path.write_bytes(png)\n281\t    ok = len(png) >= _MIN_SCREENSHOT_BYTES\n282\t    _emit({\"ok\": ok, \"path\": str(out_path), \"bytes\": len(png)})\n283\t    return 0 if ok else 1\n284\t\n285\t\n286\tdef _resolve_shell_command(shell_cmd: str | None, shell_argv: list[str]) -> str | None:\n287\t    if shell_cmd and shell_cmd.strip():\n288\t        return shell_cmd.strip()\n289\t    parts = list(shell_argv)\n290\t    if parts and parts[0] == \"--\":\n291\t        parts = parts[1:]\n292\t    # REMAINDER may capture ``-c cmd ...`` when -c follows positional out_dir.\n293\t    if parts and p