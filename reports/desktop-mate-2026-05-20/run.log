{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_4jbs7GqFKggafyaTM1xTTjsn","type":"tool_result","content":"1\t\"\"\"Thin CLI bridge: step-by-step Cua sandbox control for batch workers.\n2\t\n3\tDoes not import claude_driver (keeps dependency graph acyclic).\n4\t\"\"\"\n5\t\n6\tfrom __future__ import annotations\n7\t\n8\timport argparse\n9\timport asyncio\n10\timport json\n11\timport os\n12\timport re\n13\timport atexit\n14\timport shutil\n15\timport signal\n16\timport subprocess\n17\timport sys\n18\timport threading\n19\timport urllib.request\n20\tfrom pathlib import Path\n21\tfrom typing import Any\n22\t\n23\tfrom .config import REPORTS_DIR\n24\tfrom .sandbox_runtime import (\n25\t    LINUX_CONTAINER_IMAGE,\n26\t    LINUX_DOCKER_PLATFORM,\n27\t    apply_no_proxy_env,\n28\t    linux_container_image,\n29\t    linux_docker_runtime,\n30\t)\n31\tfrom .tasks import read_metadata, update_metadata\n32\t\n33\tSANDBOX_JSON = \"sandbox.json\"\n34\tLAST_SHELL_JSON = \".sandbox_ctl_last_shell.json\"\n35\t_MIN_SCREENSHOT_BYTES = 1000\n36\tANALYZER_SANDBOX_PREFIX = \"analyzer-\"\n37\t\n38\t_cleanup_lock = threading.Lock()\n39\t_cleanup_done = False\n40\t_batch_exit_hooks_installed = False\n41\t_prev_sigint_handler: Any = None\n42\t_prev_sigterm_handler: Any = None\n43\t\n44\t\n45\tdef _emit(payload: dict, *, file: Path | None = None) -> None:\n46\t    \"\"\"Print one JSON line to stdout (always flushed) and optionally persist.\"\"\"\n47\t    line = json.dumps(payload, ensure_ascii=False) + \"\\n\"\n48\t    sys.stdout.write(line)\n49\t    sys.stdout.flush()\n50\t    if file is not None:\n51\t        file.parent.mkdir(parents=True, exist_ok=True)\n52\t        file.write_text(line, encoding=\"utf-8\")\n53\t\n54\t\n55\tdef sandbox_json_path(out_dir: Path) -> Path:\n56\t    return out_dir.resolve() / SANDBOX_JSON\n57\t\n58\t\n59\tdef load_sandbox_info(out_dir: Path) -> dict[str, Any]:\n60\t    path = sandbox_json_path(out_dir)\n61\t    if not path.is_file():\n62\t        raise FileNotFoundError(f\"{SANDBOX_JSON} not found under {out_dir}; run bootstrap first\")\n63\t    return json.loads(path.read_text(encoding=\"utf-8\"))\n64\t\n65\t\n66\tdef write_sandbox_info(out_dir: Path, info: dict[str, Any]) -> Path:\n67\t    path = sandbox_json_path(out_dir)\n68\t    out_dir.mkdir(parents=True, exist_ok=True)\n69\t    path.write_text(json.dumps(info, indent=2, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n70\t    return path\n71\t\n72\t\n73\tdef _derive_sandbox_name(out_dir: Path) -> str:\n74\t    base = out_dir.resolve().name\n75\t    safe = re.sub(r\"[^a-zA-Z0-9._-]+\", \"-\", base).strip(\"-\").lower()\n76\t    safe = safe[:48] or \"task\"\n77\t    return f\"analyzer-{safe}\"\n78\t\n79\t\n80\tdef _api_url_from_sb(sb: Any) -> str:\n81\t    rt = getattr(sb, \"_runtime_info\", None)\n82\t    if rt and getattr(rt, \"api_port\", None):\n83\t        host = getattr(rt, \"host\", None) or \"127.0.0.1\"\n84\t        return f\"http://{host}:{rt.api_port}\"\n85\t    raise RuntimeError(\"sandbox has no api_port in runtime_info\")\n86\t\n87\t\n88\tdef _merge_metadata_sandbox(out_dir: Path, name: str, api_url: str, local: bool) -> None:\n89\t    meta = read_metadata(out_dir)\n90\t    if not meta:\n91\t        return\n92\t    sandbox = dict(meta.get(\"sandbox\") or {})\n93\t    sandbox[\"name\"] = name\n94\t    sandbox[\"api_url\"] = api_url\n95\t    sandbox[\"local\"] = local\n96\t    update_metadata(out_dir, sandbox=sandbox)\n97\t\n98\t\n99\tdef _connect_from_info(info: dict[str, Any]) -> Any:\n100\t    from cua import Sandbox\n101\t\n102\t    name = info[\"name\"]\n103\t    local = bool(info.get(\"local\", True))\n104\t    api_key = os.environ.get(\"CUA_API_KEY\") if not local else None\n105\t    if info.get(\"api_url\") and not local:\n106\t        return Sandbox.connect(\n107\t            name,\n108\t            local=False,\n109\t            api_key=api_key,\n110\t            http_url=info[\"api_url\"],\n111\t        )\n112\t    return Sandbox.connect(name, local=local, api_key=api_key)\n113\t\n114\t\n115\t# cua-xfce Linux image ships Firefox only (no Chromium). Probe DISPLAY from /tmp/.X11-unix\n116\t# (often :1, not :0) before launching.\n117\t_LINUX_FIREFOX_LAUNCH_SHELL = (\n118\t    'D=\"${DISPLAY:-}\"; '\n119\t    'if [ -z \"$D\" ] || [ ! -S \"/tmp/.X11-unix/X${D#:}\" ] 2>/dev/null; then '\n120\t    \"for x in /tmp/.X11-unix/X*; do \"\n121\t    '[ -S \"$x\" ] || continue; '\n122\t    'D=\":${x##*/X}\"; break; '\n123\t    \"done; \"\n124\t    \"fi; \"\n125\t    'export DISPLAY=\"${D:-:1}\"; '\n126\t    \"if pgrep -x firefox >/dev/null 2>&1; then exit 0; fi; \"\n127\t    \"firefox --new-window about:blank >/dev/null 2>&1 & \"\n128\t    \"sleep 3; \"\n129\t    \"pgrep -x firefox >/dev/null\"\n130\t)\n131\t\n132\t\n133\tasync def _launch_browser_once(out_dir: Path) -> int:\n134\t    \"\"\"One-time shell helper to start Firefox; navigation after this is mouse/keyboard.\"\"\"\n135\t    return await cmd_step_shell(out_dir, _LINUX_FIREFOX_LAUNCH_SHELL)\n136\t\n137\t\n138\tasync def cmd_step_open_url(out_dir: Path, url: str, *, launch: bool = True) -> int:\n139\t    \"\"\"Open URL in sandbox browser using keyboard focus + type (mouse-first navigation).\"\"\"\n140\t    if launch:\n141\t        await _launch_browser_once(out_dir)\n142\t        await asyncio.sleep(1.0)\n143\t    # Focus omnibox then type URL (Firefox on cua-xfce XFCE).\n144\t    await cmd_step_key(out_dir, \"ctrl+l\")\n145\t    await asyncio.sleep(0.4)\n146\t    await cmd_step_key(out_dir, \"ctrl+a\")\n147\t    await asyncio.sleep(0.1)\n148\t    await cmd_step_type(out_dir, url)\n149\t    await asyncio.sleep(0.2)\n150\t    await cmd_step_key(out_dir, \"enter\")"}]},"parent_tool_use_id":null,"session_id":"eae7466e-d4e1-45c4-b8c4-525cbacc4ad0","uuid":"b7809acc-98ee-49ac-abba-0f8d04914b0d","timestamp":"2026-05-20T09:27:45.148Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/huzhiwei/Desktop/Projects/computer-use/scripts/product_analyzer/sandbox_ctl.py","content":"\"\"\"Thin CLI bridge: step-by-step Cua sandbox control for batch workers.\n\nDoes not import claude_driver (keeps dependency graph acyclic).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport asyncio\nimport json\nimport os\nimport re\nimport atexit\nimport shutil\nimport signal\nimport subprocess\nimport sys\nimport threading\nimport urllib.request\nfrom pathlib import Path\nfrom typing import Any\n\nfrom .config import REPORTS_DIR\nfrom .sandbox_runtime import (\n    LINUX_CONTAINER_IMAGE,\n    LINUX_DOCKER_PLATFORM,\n    apply_no_proxy_env,\n    linux_container_image,\n    linux_docker_runtime,\n)\nfrom .tasks import read_metadata, update_metadata\n\nSANDBOX_JSON = \"sandbox.json\"\nLAST_SHELL_JSON = \".sandbox_ctl_last_shell.json\"\n_MIN_SCREENSHOT_BYTES = 1000\nANALYZER_SANDBOX_PREFIX = \"analyzer-\"\n\n_cleanup_lock = threading.Lock()\n_cleanup_done = False\n_batch_exit_hooks_installed = False\n_prev_sigint_handler: Any = None\n_prev_sigterm_handler: Any = None\n\n\ndef _emit(payload: dict, *, file: Path | None = None) -> None:\n    \"\"\"Print one JSON line to stdout (always flushed) and optionally persist.\"\"\"\n    line = json.dumps(payload, ensure_ascii=False) + \"\\n\"\n    sys.stdout.write(line)\n    sys.stdout.flush()\n    if file is not None:\n        file.parent.mkdir(parents=True, exist_ok=True)\n        file.write_text(line, encoding=\"utf-8\")\n\n\ndef sandbox_json_path(out_dir: Path) -> Path:\n    return out_dir.resolve() / SANDBOX_JSON\n\n\ndef load_sandbox_info(out_dir: Path) -> dict[str, Any]:\n    path = sandbox_json_path(out_dir)\n    if not path.is_file():\n        raise FileNotFoundError(f\"{SANDBOX_JSON} not found under {out_dir}; run bootstrap first\")\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_sandbox_info(out_dir: Path, info: dict[str, Any]) -> Path:\n    path = sandbox_json_path(out_dir)\n    out_dir.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(info, indent=2, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n    return path\n\n\ndef _derive_sandbox_name(out_dir: Path) -> str:\n    base = out_dir.resolve().name\n    safe = re.sub(r\"[^a-zA-Z0-9._-]+\", \"-\", base).strip(\"-\").lower()\n    safe = safe[:48] or \"task\"\n    return f\"analyzer-{safe}\"\n\n\ndef _api_url_from_sb(sb: Any) -> str:\n    rt = getattr(sb, \"_runtime_info\", None)\n    if rt and getattr(rt, \"api_port\", None):\n        host = getattr(rt, \"host\", None) or \"127.0.0.1\"\n        return f\"http://{host}:{rt.api_port}\"\n    raise RuntimeError(\"sandbox has no api_port in runtime_info\")\n\n\ndef _merge_metadata_sandbox(out_dir: Path, name: str, api_url: str, local: bool) -> None:\n    meta = read_metadata(out_dir)\n    if not meta:\n        return\n    sandbox = dict(meta.get(\"sandbox\") or {})\n    sandbox[\"name\"] = name\n    sandbox[\"api_url\"] = api_url\n    sandbox[\"local\"] = local\n    update_metadata(out_dir, sandbox=sandbox)\n\n\ndef _connect_from_info(info: dict[str, Any]) -> Any:\n    from cua import Sandbox\n\n    name = info[\"name\"]\n    local = bool(info.get(\"local\", True))\n    api_key = os.environ.get(\"CUA_API_KEY\") if not local else None\n    if info.get(\"api_url\") and not local:\n        return Sandbox.connect(\n            name,\n            local=False,\n            api_key=api_key,\n            http_url=info[\"api_url\"],\n        )\n    return Sandbox.connect(name, local=local, api_key=api_key)\n\n\n# cua-xfce Linux image ships Firefox only (no Chromium). Probe DISPLAY from /tmp/.X11-unix\n# (often :1, not :0) before launching.\n_LINUX_FIREFOX_LAUNCH_SHELL = (\n    'D=\"${DISPLAY:-}\"; '\n    'if [ -z \"$D\" ] || [ ! -S \"/tmp/.X11-unix/X${D#:}\" ] 2>/dev/null; then '\n    \"for x in /tmp/.X11-unix/X*; do \"\n    '[ -S \"$x\" ] || continue; '\n    'D=\":${x##*/X}\"; break; '\n    \"done; \"\n    \"fi; \"\n    'export DISPLAY=\"${D:-:1}\"; '\n    \"if pgrep -x firefox >/dev/null 2>&1; then exit 0; fi; \"\n    \"firefox --new-window about:blank >/dev/null 2>&1 & \"\n    \"sleep 3; \"\n    \"pgrep -x firefox >/dev/null\"\n)\n\n\nasync def _launch_browser_once(out_dir: Path) -> int:\n    \"\"\"One-time shell helper to start Firefox; navigation after this is mouse/keyboard.\"\"\"\n    return await cmd_step_shell(out_dir, _LINUX_FIREFOX_LAUNCH_SHELL)\n\n\nasync def cmd_step_open_url(out_dir: Path, url: str, *, launch: bool = True) -> int:\n    \"\"\"Open URL in sandbox browser using keyboard focus + type (mouse-first navigation).\"\"\"\n    if launch:\n        await _launch_browser_once(out_dir)\n        await asyncio.sleep(1.0)\n    # Focus omnibox then type URL (Firefox on cua-xfce XFCE).\n    await cmd_step_key(out_dir, \"ctrl+l\")\n    await asyncio.sleep(0.4)\n    await cmd_step_key(out_dir, \"ctrl+a\")\n    await asyncio.sleep(0.1)\n    await cmd_step_type(out_dir, url)\n    await asyncio.sleep(0.2)\n    await cmd_step_key(out_dir, \"enter\")","numLines":150,"startLine":1,"totalLines":822}}}
