{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_SJlXIjp9Ed1rU163n68dBl7J","type":"tool_result","content":"446\tdef _collect_sandbox_names_from_reports() -> set[str]:\n447\t    names: set[str] = set()\n448\t    if not REPORTS_DIR.is_dir():\n449\t        return names\n450\t    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n451\t        try:\n452\t            data = json.loads(path.read_text(encoding=\"utf-8\"))\n453\t        except (json.JSONDecodeError, OSError):\n454\t            continue\n455\t        name = (data.get(\"name\") or \"\").strip()\n456\t        if name:\n457\t            names.add(name)\n458\t    return names\n459\t\n460\t\n461\tdef _docker_cua_sandbox_container_names() -> set[str]:\n462\t    \"\"\"Container names with Cua sandbox label (running or stopped).\"\"\"\n463\t    if not shutil.which(\"docker\"):\n464\t        return set()\n465\t    proc = subprocess.run(\n466\t        [\n467\t            \"docker\",\n468\t            \"ps\",\n469\t            \"-aq\",\n470\t            \"--filter\",\n471\t            \"label=cua.sandbox=true\",\n472\t            \"--format\",\n473\t            \"{{.Names}}\",\n474\t        ],\n475\t        capture_output=True,\n476\t        text=True,\n477\t        timeout=60,\n478\t    )\n479\t    if proc.returncode != 0:\n480\t        return set()\n481\t    return {line.strip() for line in proc.stdout.splitlines() if line.strip()}\n482\t\n483\t\n484\tdef _docker_force_rm(names: set[str]) -> list[str]:\n485\t    removed: list[str] = []\n486\t    if not names or not shutil.which(\"docker\"):\n487\t        return removed\n488\t    for name in sorted(names):\n489\t        proc = subprocess.run(\n490\t            [\"docker\", \"rm\", \"-f\", name],\n491\t            capture_output=True,\n492\t            text=True,\n493\t            timeout=30,\n494\t        )\n495\t        if proc.returncode == 0:\n496\t            removed.append(name)\n497\t    return removed\n498\t\n499\t\n500\tdef _unlink_sandbox_json_for_name(name: str) -> None:\n501\t    if not REPORTS_DIR.is_dir():\n502\t        return\n503\t    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n504\t        try:\n505\t            data = json.loads(path.read_text(encoding=\"utf-8\"))\n506\t        except (json.JSONDecodeError, OSError):\n507\t            continue\n508\t        if data.get(\"name\") == name:\n509\t            path.unlink(missing_ok=True)\n510\t\n511\t\n512\tasync def cmd_cleanup_all(*, prefix: str = ANALYZER_SANDBOX_PREFIX) -> int:\n513\t    \"\"\"Stop/remove local Cua Docker sandboxes (batch exit / manual cleanup).\"\"\"\n514\t    apply_no_proxy_env()\n515\t    from cua import Sandbox\n516\t\n517\t    docker_names = _docker_cua_sandbox_container_names()\n518\t    targets: set[str] = set(docker_names)\n519\t    targets |= _collect_sandbox_names_from_reports()\n520\t\n521\t    try:\n522\t        listed = await Sandbox.list(local=True)\n523\t        for info in listed:\n524\t            if info.name:\n525\t                targets.add(info.name)\n526\t    except Exception as exc:\n527\t        print(f\"warning: Sandbox.list: {exc}\", file=sys.stderr)\n528\t\n529\t    to_delete = set(docker_names)\n530\t    to_delete |= {n for n in targets if n.startswith(prefix)}\n531\t\n532\t    deleted: list[str] = []\n533\t    errors: list[str] = []\n534\t    for name in sorted(to_delete):\n535\t        try:\n536\t            await Sandbox.delete(name, local=True)\n537\t            deleted.append(name)\n538\t            _unlink_sandbox_json_for_name(name)\n539\t        except Exception as exc:\n540\t            errors.append(f\"{name}: {exc}\")\n541\t\n542\t    docker_removed = _docker_force_rm(to_delete - set(deleted))\n543\t    deleted.extend(n for n in docker_removed if n not in deleted)\n544\t\n545\t    leftover = _docker_cua_sandbox_container_names() - set(deleted)\n546\t    if leftover:\n547\t        docker_removed2 = _docker_force_rm(leftover)\n548\t        deleted.extend(n for n in docker_removed2 if n not in deleted)\n549\t\n550\t    payload = {\n551\t        \"ok\": not errors,\n552\t        \"deleted\": deleted,\n553\t        \"errors\": errors,\n554\t        \"count\": len(deleted),\n555\t    }\n556\t    _emit(payload)\n557\t    if deleted:\n558\t        print(\n559\t            f\"sandbox_ctl cleanup: removed {len(deleted)} container(s)\",\n560\t            file=sys.stderr,\n561\t            flush=True,\n562\t        )\n563\t    for err in errors:\n564\t        print(f\"sandbox_ctl cleanup: {err}\", file=sys.stderr)\n565\t    return 0 if not errors else 1\n566\t\n567\t\n568\tdef reset_batch_cleanup_gate() -> None:\n569\t    \"\"\"Allow a new batch run to run exit cleanup again.\"\"\"\n570\t    global _cleanup_done\n571\t    with _cleanup_lock:\n572\t        _cleanup_done = False\n573\t\n574\t\n575\tdef docker_cleanup_sync_quick() -> int:\n576\t    \"\"\"SIGINT-safe: ``docker rm -f`` Cua containers without asyncio (for signal handler).\"\"\"\n577\t    if _batch_cleanup_disabled():\n578\t        return 0\n579\t    names = _docker_cua_sandbox_container_names()\n580\t    names |= {\n581\t        n\n582\t        for n in _collect_sandbox_names_from_reports()\n583\t        if n.startswith(ANALYZER_SANDBOX_PREFIX)\n584\t    }\n585\t    removed = _docker_force_rm(names)\n586\t    if removed:\n587\t        print(\n588\t            f\"sandbox_ctl: 已停止 {len(removed)} 个 Docker 沙盒容器\",\n589\t            file=sys.stderr,\n590\t            flush=True,\n591\t        )\n592\t    return len(removed)\n593\t\n594\t\n595\tdef _batch_signal_handler(signum: int, frame: Any) -> None:\n596\t    \"\"\"First Ctrl+C: quick docker stop; then raise KeyboardInterrupt for ``finally``.\"\"\"\n597\t    try:\n598\t        docker_cleanup_sync_quick()\n599\t    except Exception:\n600\t        pass\n601\t    raise KeyboardInterrupt\n602\t\n603\t\n604\tdef install_batch_exit_hooks(*, local: bool) -> None:\n605\t    \"\"\"Register SIGINT/SIGTERM + atexit so forced exit still cleans Docker sandboxes.\"\"\"\n606\t    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n607\t    if not local or _batch_cleanup_disabled() or _batch_exit_hooks_installed:\n608\t        return\n609\t    _prev_sigint_handler = signal.getsignal(signal.SIGINT)\n610\t    _prev_sigterm_handler = signal.getsignal(signal.SIGTERM)\n611\t    signal.signal(signal.SIGINT, _batch_signal_handler)\n612\t    signal.signal(signal.SIGTERM, _batch_signal_handler)\n613\t    atexit.register(cleanup_all_local_sandboxes)\n614\t    _batch_exit_hooks_installed = True\n615\t\n616\t\n617\tdef uninstall_batch_exit_hooks() -> None:\n618\t    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n619\t    if not _batch_exit_hooks_installed:\n620\t        return\n621\t    if _prev_sigint_handler is not None:\n622\t        signal.signal(signal.SIGINT, _prev_sigint_handler)\n623\t    if _prev_sigterm_handler is not None:\n624\t        signal.signal(signal.SIGTERM, _prev_sigterm_handler)\n625\t    _prev_sigint_handler = None\n626\t    _prev_sigterm_handler = None\n627\t    _batch_exit_hooks_installed = False\n628\t\n629\t\n630\tdef cleanup_all_local_sandboxes(*, force: bool = False) -> None:\n631\t    \"\"\"Idempotent batch-exit hook: tear down Cua Docker sandboxes. Never raises.\"\"\"\n632\t    global _cleanup_done\n633\t    if _batch_cleanup_disabled():\n634\t        return\n635\t    with _cleanup_lock:\n636\t        if _cleanup_done and not force:\n637\t            return\n638\t        _cleanup_done = True\n639\t    try:\n640\t        asyncio.run(cmd_cleanup_all())\n641\t    except Exception as exc:\n642\t        print(f\"sandbox_ctl cleanup: {exc}\", file=sys.stderr, flush=True)\n643\t        try:\n644\t            docker_cleanup_sync_quick()\n645\t        except Exception:\n646\t            pass\n647\t\n648\t\n649\tdef teardown_out_dir(out_dir: Path) -> None:\n650\t    \"\"\"Best-effort teardown for batch finally hook; never raises.\"\"\"\n651\t    tr