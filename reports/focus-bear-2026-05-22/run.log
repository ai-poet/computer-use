{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_5cpLucogkUZTcFhUhhRMwb7s","type":"tool_result","content":"1\t\"\"\"Thin CLI bridge: step-by-step Cua sandbox control for batch workers.\n2\t\n3\tDoes not import claude_driver (keeps dependency graph acyclic).\n4\t\"\"\"\n5\t\n6\tfrom __future__ import annotations\n7\t\n8\timport argparse\n9\timport asyncio\n10\timport json\n11\timport os\n12\timport re\n13\timport atexit\n14\timport shutil\n15\timport signal\n16\timport subprocess\n17\timport sys\n18\timport threading\n19\timport urllib.request\n20\tfrom pathlib import Path\n21\tfrom typing import Any\n22\t\n23\tfrom .config import REPORTS_DIR\n24\tfrom .sandbox_runtime import (\n25\t    LINUX_CONTAINER_IMAGE,\n26\t    LINUX_DOCKER_PLATFORM,\n27\t    apply_no_proxy_env,\n28\t    linux_container_image,\n29\t    linux_docker_runtime,\n30\t)\n31\tfrom .tasks import read_metadata, update_metadata\n32\t\n33\tSANDBOX_JSON = \"sandbox.json\"\n34\tLAST_SHELL_JSON = \".sandbox_ctl_last_shell.json\"\n35\t_MIN_SCREENSHOT_BYTES = 1000\n36\tANALYZER_SANDBOX_PREFIX = \"analyzer-\"\n37\t_PAGE_LOAD_WAIT_S = 10.0\n38\t\n39\t_cleanup_lock = threading.Lock()\n40\t_cleanup_done = False\n41\t_batch_exit_hooks_installed = False\n42\t_prev_sigint_handler: Any = None\n43\t_prev_sigterm_handler: Any = None\n44\t\n45\t\n46\tdef _emit(payload: dict, *, file: Path | None = None) -> None:\n47\t    \"\"\"Print one JSON line to stdout (always flushed) and optionally persist.\"\"\"\n48\t    line = json.dumps(payload, ensure_ascii=False) + \"\\n\"\n49\t    sys.stdout.write(line)\n50\t    sys.stdout.flush()\n51\t    if file is not None:\n52\t        file.parent.mkdir(parents=True, exist_ok=True)\n53\t        file.write_text(line, encoding=\"utf-8\")\n54\t\n55\t\n56\tdef sandbox_json_path(out_dir: Path) -> Path:\n57\t    return out_dir.resolve() / SANDBOX_JSON\n58\t\n59\t\n60\tdef load_sandbox_info(out_dir: Path) -> dict[str, Any]:\n61\t    path = sandbox_json_path(out_dir)\n62\t    if not path.is_file():\n63\t        raise FileNotFoundError(f\"{SANDBOX_JSON} not found under {out_dir}; run bootstrap first\")\n64\t    return json.loads(path.read_text(encoding=\"utf-8\"))\n65\t\n66\t\n67\tdef write_sandbox_info(out_dir: Path, info: dict[str, Any]) -> Path:\n68\t    path = sandbox_json_path(out_dir)\n69\t    out_dir.mkdir(parents=True, exist_ok=True)\n70\t    path.write_text(json.dumps(info, indent=2, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n71\t    return path\n72\t\n73\t\n74\tdef _derive_sandbox_name(out_dir: Path) -> str:\n75\t    base = out_dir.resolve().name\n76\t    safe = re.sub(r\"[^a-zA-Z0-9._-]+\", \"-\", base).strip(\"-\").lower()\n77\t    safe = safe[:48] or \"task\"\n78\t    return f\"analyzer-{safe}\"\n79\t\n80\t\n81\tdef _api_url_from_sb(sb: Any) -> str:\n82\t    rt = getattr(sb, \"_runtime_info\", None)\n83\t    if rt and getattr(rt, \"api_port\", None):\n84\t        host = getattr(rt, \"host\", None) or \"127.0.0.1\"\n85\t        return f\"http://{host}:{rt.api_port}\"\n86\t    raise RuntimeError(\"sandbox has no api_port in runtime_info\")\n87\t\n88\t\n89\tdef _merge_metadata_sandbox(out_dir: Path, name: str, api_url: str, local: bool) -> None:\n90\t    meta = read_metadata(out_dir)\n91\t    if not meta:\n92\t        return\n93\t    sandbox = dict(meta.get(\"sandbox\") or {})\n94\t    sandbox[\"name\"] = name\n95\t    sandbox[\"api_url\"] = api_url\n96\t    sandbox[\"local\"] = local\n97\t    update_metadata(out_dir, sandbox=sandbox)\n98\t\n99\t\n100\tdef _connect_from_info(info: dict[str, Any]) -> Any:\n101\t    from cua import Sandbox\n102\t\n103\t    name = info[\"name\"]\n104\t    local = bool(info.get(\"local\", True))\n105\t    api_key = os.environ.get(\"CUA_API_KEY\") if not local else None\n106\t    kwargs: dict[str, Any] = {\"name\": name, \"local\": local, \"api_key\": api_key}\n107\t    api_url = (info.get(\"api_url\") or \"\").strip()\n108\t    if api_url:\n109\t        # Prefer stored computer-server URL (Sandbox.connect http_url=… per SDK docs).\n110\t        kwargs[\"http_url\"] = api_url\n111\t    return Sandbox.connect(**kwargs)\n112\t\n113\t\n114\t# cua-xfce Linux image ships Firefox only (no Chromium). Probe DISPLAY from /tmp/.X11-unix\n115\t# (often :1, not :0) before launching.\n116\t_LINUX_DISPLAY_PROBE = (\n117\t    'D=\"${DISPLAY:-}\"; '\n118\t    'if [ -z \"$D\" ] || [ ! -S \"/tmp/.X11-unix/X${D#:}\" ] 2>/dev/null; then '\n119\t    \"for x in /tmp/.X11-unix/X*; do \"\n120\t    '[ -S \"$x\" ] || continue; '\n121\t    'D=\":${x##*/X}\"; break; '\n122\t    \"done; \"\n123\t    \"fi; \"\n124\t    'export DISPLAY=\"${D:-:1}\"; '\n125\t)\n126\t\n127\t_LINUX_FIREFOX_LAUNCH_SHELL = (\n128\t    _LINUX_DISPLAY_PROBE\n129\t    + \"if pgrep -x firefox >/dev/null 2>&1; then exit 0; fi; \"\n130\t    + \"firefox --new-window about:blank >/dev/null 2>&1 & \"\n131\t    + \"sleep 3; \"\n132\t    + \"pgrep -x firefox >/dev/null\"\n133\t)\n134\t\n135\t# Best-effort: keep XFCE desktop awake during long batch runs (xset + xfconf + systemd).\n136\t_LINUX_XFCE_DISABLE_SLEEP_SHELL = (\n137\t    _LINUX_DISPLAY_PROBE\n138\t    + \"if command -v xset >/dev/null 2>&1; then \"\n139\t    + \"xset s off -dpms s noblank 2>/dev/null || true; \"\n140\t    + \"fi; \"\n141\t    + \"if command -v xfconf-query >/dev/null 2>&1; then \"\n142\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/inactivity-sleep-mode-on-ac -s 0 \"\n143\t    + \"2>/dev/null || true; \"\n144\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/inactivity-sleep-mode-on-battery -s 0 \"\n145\t    + \"2>/dev/null || true; \"\n146\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/blank-on-ac -s 0 \"\n147\t    + \"2>/dev/null || true; \"\n148\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/blank-on-battery -s 0 \"\n149\t    + \"2>/dev/null || true; \"\n150\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-sleep -s 0 \"\n151\t    + \"2>/dev/null || true; \"\n152\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-off -s 0 \"\n153\t    + \"2>/dev/null || true; \"\n154\t    + \"xfconf-query -c screensaver -p /saver/enabled -s false 2>/dev/null || true; \"\n155\t    + \"xfconf-query -c screensaver -p /saver/idle-activation/enabled -s false 2>/dev/null || true; \"\n156\t    + \"fi; \"\n157\t    + \"if command -v systemctl >/dev/null 2>&1; then \"\n158\t    + \"systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target \"\n159\t    + \"2>/dev/null || true; \"\n160\t    + \"fi; \"\n161\t    + \"exit 0\"\n162\t)\n163\t\n164\t\n165\tasync def _launch_browser_once(out_dir: Path) -> int:\n166\t    \"\"\"One-time shell helper to start Firefox; navigation after this is mouse/keyboard.\"\"\"\n167\t    return await cmd_step_shell(out_dir, _LINUX_FIREFOX_LAUNCH_SHELL)\n168\t\n169\t\n170\tasync def _disable_linux_xfce_sleep(out_dir: Path) -> None:\n171\t    \"\"\"Best-effort disable screen blank/suspend on cua-xfce; never fails bootstrap.\"\"\"\n172\t    rc = await cmd_step_shell(out_dir, _LINUX_XFCE_DISABLE_SLEEP_SHELL)\n173\t    if rc != 0:\n174\t        print(\n175\t            \"warning: sandbox_ctl could not fully disable XFCE sleep (non-fatal)\",\n176\t            file=sys.stderr,\n177\t        )\n178\t\n179\t\n180\tasync def cmd_step_open_url(out_dir: Path, url: str, *, launch: bool = True) -> int:\n181\t    \"\"\"Open URL in sandbox browser using keyboard focus + type (mouse-first navigation).\"\"\"\n182\t    if launch:\n183\t        await _launch_browser_once(out_dir)\n184\t        await asyncio.sleep(1.0)\n185\t    # Focus omnibox then type URL (Firefox on cua-xfce XFCE).\n186\t    await cmd_step_key(out_dir, \"ctrl+l\")\n187\t    await asyncio.sleep(0.4)\n188\t    await cmd_step_key(out_dir, \"ctrl+a\")\n189\t    await asyncio.sleep(0.1)\n190\t    await cmd_step_type(out_dir, url)\n191\t    await asyncio.sleep(0.2)\n192\t    await cmd_step_key(out_dir, \"enter\")\n193\t    await asyncio.sleep(_PAGE_LOAD_WAIT_S)\n194\t    _emit({\"ok\": True, \"action\": \"open-url\", \"url\": url, \"load_wait_s\": _PAGE_LOAD_WAIT_S})\n195\t    return 0\n196\t\n197\t\n198\tasync def cmd_bootstrap(\n199\t    out_dir: Path,\n200\t    *,\n201\t    open_browser: bool,\n202\t    url: str | None = None,\n203\t) -> int:\n204\t    apply_no_proxy_env()\n205\t    out_dir = out_dir.resolve()\n206\t    if sandbox_json_path(out_dir).is_file():\n207\t        print(f\"error: {SANDBOX_JSON} already exists; run teardown first\", file=sys.stderr)\n208\t        return 1\n209\t\n210\t    runtime = os.environ.get(\"ANALYZER_RUNTIME\", \"sandbox-local\")\n211\t    image_key = os.environ.get(\"ANALYZER_SANDBOX_IMAGE\", \"linux\").lower()\n212\t    local = runtime != \"sandbox-cloud\"\n213\t    name = _derive_sandbox_name(out_dir)\n214\t\n215\t    from cua import Sandbox\n216\t\n217\t    if local:\n218\t        if image_key not in (\"auto\", \"linux\"):\n219\t            print(\n220\t                f\"warning: sandbox_ctl bootstrap only implements linux container; \"\n221\t                f\"got image={image_key!r}\",\n222\t                file=sys.stderr,\n223\t            )\n224\t        sb = await Sandbox.create(\n225\t            linux_container_image(),\n226\t            name=name,\n227\t            local=True,\n228\t            runtime=linux_docker_runtime(ephemeral=False),\n229\t        )\n230\t        provider = \"docker\"\n231\t        image = os.environ.get(\"ANALYZER_LINUX_CONTAINER_IMAGE\", LINUX_CONTAINER_IMAGE)\n232\t        platform = os.environ.get(\"ANALYZER_LINUX_DOCKER_PLATFORM\", LINUX_DOCKER_PLATFORM)\n233\t    else:\n234\t        api_key = os.environ.get(\"CUA_API_KEY\", \"\").strip()\n235\t        if not api_key:\n236\t            print(\"error: CUA_API_KEY required for cloud bootstrap\", file=sys.stderr)\n237\t            return 1\n238\t        from cua import Image\n239\t\n240\t        sb = await Sandbox.create(Image.linux(), name=name, local=False, api_key=api_key)\n241\t        provider = \"cloud\"\n242\t        image = \"linux\"\n243\t        platform = None\n244\t\n245\t    api_url = _api_url_from_sb(sb)\n246\t    info = {\n247\t        \"name\": sb.name or name,\n248\t        \"provider\": provider,\n249\t        \"api_url\": api_url,\n250\t        \"image\": image,\n251\t        \"platform\": platform,\n252\t        \"local\": local,\n253\t    }\n254\t    write_sandbox_info(out_dir, info)\n255\t    _merge_metadata_sandbox(out_dir, info[\"name\"], api_url, local)\n256\t    await sb.disconnect()\n257\t\n258\t    _emit({\"ok\": True, \"sandbox\": info})\n259\t\n260\t    if local and image_key in (\"auto\", \"linux\"):\n261\t        await _disable_linux_xfce_sleep(out_dir)\n262\t\n263\t    if open_browser:\n264\t        target = (url or os.environ.get(\"ANALYZER_PRODUCT_URL\") or \"\").strip()\n265\t        if target:\n266\t            return await cmd_step_open_url(out_dir, target, launch=True)\n267\t        return await _launch_browser_once(out_dir)\n268\t    return 0\n269\t\n270\t\n271\tasync def cmd_teardown(out_dir: Path) -> int:\n272\t    apply_no_proxy_env()\n273\t    out_dir = out_dir.resolve()\n274\t    path = sandbox_json_path(out_dir)\n275\t    if not path.is_file():\n276\t        _emit({\"ok\": True, \"skipped\": \"no sandbox.json\"})\n277\t        return 0\n278\t    info = load_sandbox_info(out_dir)\n279\t    from cua import Sandbox\n280\t\n281\t    try:\n282\t        await Sandbox.delete(\n283\t            info[\"name\"],\n284\t            local=bool(info.get(\"local\", True)),\n285\t            api_key=os.environ.get(\"CUA_API_KEY\") if not info.get(\"local\", True) else None,\n286\t        )\n287\t    except Exception as exc:\n288\t        print(f\"warning: Sandbox.delete: {exc}\", file=sys.stderr)\n289\t    path.unlink(missing_ok=True)\n290\t    _emit({\"ok\": True, \"deleted\": info[\"name\"]})\n291\t    return 0\n292\t\n293\t\n294\tdef cmd_status(out_dir: Path) -> int:\n295\t    out_dir = out_dir.resolve()\n296\t    path = sandbox_json_path(out_dir)\n297\t    if not path.is_file():\n298\t        _emit({\"ok\": False, \"error\": f\"no {SANDBOX_JSON} in {out_dir}\"})\n299\t        return 1\n300\t    info = load_sandbox_info(out_dir)\n301\t    _emit({\"ok\": True, \"sandbox\": info})\n302\t    print(json.dumps(info, indent=2, ensure_ascii=False))\n303\t    api_url = info.get(\"api_url\", \"\")\n304\t    if api_url:\n305\t        try:\n306\t            req = urllib.request.Request(f\"{api_url.rstrip('/')}/status\", method=\"GET\")\n307\t            with urllib.request.urlopen(req, timeout=5) as resp:\n308\t                body = resp.read().decode(\"utf-8\", errors=\"replace\")[:500]\n309\t            print(f\"GET {api_url}/status -> {resp.status} {body[:200]}\")\n310\t        except Exception as exc:\n311\t            print(f\"GET {api_url}/status failed: {exc}\", file=sys.stderr)\n312\t            return 1\n313\t    return 0\n314\t\n315\t\n316\tasync def cmd_step_screenshot(out_dir: Path, out_path: Path) -> int:\n317\t    apply_no_proxy_env()\n318\t    info = load_sandbox_info(out_dir)\n319\t    out_path = out_path if out_path.is_absolute() else (out_dir.resolve() / out_path)\n320\t    out_path.parent.mkdir(parents=True, exist_ok=True)\n321\t\n322\t    async with _connect_from_info(info) as sb:\n323\t        png = await sb.screenshot()\n324\t\n325\t    out_path.write_bytes(png)\n326\t    ok = len(png) >= _MIN_SCREENSHOT_BYTES\n327\t    _emit({\"ok\": ok, \"path\": str(out_path), \"bytes\": len(png)})\n328\t    return 0 if ok else 1\n329\t\n330\t\n331\tdef _resolve_shell_command(shell_cmd: str | None, shell_argv: list[str]) -> str | None:\n332\t    if shell_cmd and shell_cmd.strip():\n333\t        return shell_cmd.strip()\n334\t    parts = list(shell_argv)\n335\t    if parts and parts[0] == \"--\":\n336\t        parts = parts[1:]\n337\t    # REMAINDER may capture ``-c cmd ...`` when -c follows positional out_dir.\n338\t    if parts and parts[0] in (\"-c\", \"--cmd\"):\n339\t        parts = parts[1:]\n340\t    if not parts:\n341\t        return None\n342\t    return \" \".join(parts)\n343\t\n344\t\n345\tasync def cmd_step_shell(out_dir: Path, command: str) -> int:\n346\t    apply_no_proxy_env()\n347\t    out_dir = out_dir.resolve()\n348\t    artifact = out_dir / LAST_SHELL_JSON\n349\t    try:\n350\t        info = load_sandbox_info(out_dir)\n351\t        async with _connect_from_info(info) as sb:\n352\t            result = await sb.shell.run(command)\n353\t    except Exception as exc:\n354\t        payload = {\n355\t            \"ok\": False,\n356\t            \"returncode\": 1,\n357\t            \"stdout\": \"\",\n358\t            \"stderr\": str(exc),\n359\t            \"command\": command,\n360\t            \"artifact\": str(artifact),\n361\t            \"error\": f\"{type(exc).__name__}: {exc}\",\n362\t        }\n363\t        _emit(payload, file=artifact)\n364\t        print(f\"sandbox_ctl shell: {payload['error']}\", file=sys.stderr, flush=True)\n365\t        return 1\n366\t    stdout = result.stdout or \"\"\n367\t    stderr = result.stderr or \"\"\n368\t    payload = {\n369\t        \"ok\": result.success,\n370\t        \"returncode\": result.returncode,\n371\t        \"stdout\": stdout,\n372\t        \"stderr\": stderr,\n373\t        \"command\": command,\n374\t        \"artifact\": str(artifact),\n375\t    }\n376\t    _emit(payload, file=artifact)\n377\t    # Human-readable tail on stderr so Bash-tool users still see something if stdout is sparse.\n378\t    print(\n379\t        f\"sandbox_ctl shell: ok={result.success} rc={result.returncode} \"\n380\t        f\"stdout_bytes={len(stdout)} stderr_bytes={len(stderr)}\",\n381\t        file=sys.stderr,\n382\t        flush=True,\n383\t    )\n384\t    if stdout:\n385\t        sys.stderr.write(stdout if stdout.endswith(\"\\n\") else stdout + \"\\n\")\n386\t        sys.stderr.flush()\n387\t    if stderr:\n388\t        sys.stderr.write(stderr if stderr.endswith(\"\\n\") else stderr + \"\\n\")\n389\t        sys.stderr.flush()\n390\t    return 0 if result.success else 1\n391\t\n392\t\n393\tasync def cmd_step_click(out_dir: Path, x: int, y: int, *, button: str) -> int:\n394\t    apply_no_proxy_env()\n395\t    info = load_sandbox_info(out_dir)\n396\t    async with _connect_from_info(info) as sb:\n397\t        if button == \"right\":\n398\t            await sb.mouse.right_click(x, y)\n399\t        elif button == \"double\":\n400\t            await sb.mouse.double_click(x, y)\n401\t        else:\n402\t            await sb.mouse.click(x, y)\n403\t    _emit({\"ok\": True, \"action\": button, \"x\": x, \"y\": y})\n404\t    return 0\n405\t\n406\t\n407\tasync def cmd_step_move(out_dir: Path, x: int, y: int) -> int:\n408\t    apply_no_proxy_env()\n409\t    info = load_sandbox_info(out_dir)\n410\t    async with _connect_from_info(info) as sb:\n411\t        await sb.mouse.move(x, y)\n412\t    _emit({\"ok\": True, \"x\": x, \"y\": y})\n413\t    return 0\n414\t\n415\t\n416\tasync def cmd_step_type(out_dir: Path, text: str) -> int:\n417\t    apply_no_proxy_env()\n418\t    info = load_sandbox_info(out_dir)\n419\t    async with _connect_from_info(info) as sb:\n420\t        await sb.keyboard.type(text)\n421\t    _emit({\"ok\": True, \"chars\": len(text)})\n422\t    return 0\n423\t\n424\t\n425\t# computer-server (pynput) Key names differ from SDK docs examples — normalize before hotkey.\n426\t# Linux: Key.esc not escape; Key.cmd not meta; Key.page_up not pageup; etc.\n427\t_KEY_ALIASES: dict[str, str] = {\n428\t    \"escape\": \"esc\",\n429\t    \"esc\": \"esc\",\n430\t    \"enter\": \"enter\",\n431\t    \"return\": \"enter\",\n432\t    \"ret\": \"enter\",\n433\t    \"tab\": \"tab\",\n434\t    \"space\": \"space\",\n435\t    \" \": \"space\",\n436\t    \"backspace\": \"backspace\",\n437\t    \"bs\": \"backspace\",\n438\t    \"delete\": \"delete\",\n439\t    \"del\": \"delete\",\n440\t    \"insert\": \"insert\",\n441\t    \"ins\": \"insert\",\n442\t    \"home\": \"home\",\n443\t    \"end\": \"end\",\n444\t    \"pageup\": \"page_up\",\n445\t    \"page_up\": \"page_up\",\n446\t    \"pgup\": \"page_up\",\n447\t    \"pagedown\": \"page_down\",\n448\t    \"page_down\": \"page_down\",\n449\t    \"pgdn\": \"page_down\",\n450\t    \"up\": \"up\",\n451\t    \"down\": \"down\",\n452\t    \"left\": \"left\",\n453\t    \"right\": \"right\",\n454\t    \"control\": \"ctrl\",\n455\t    \"command\": \"cmd\",\n456\t    \"cmd\": \"cmd\",\n457\t    \"win\": \"cmd\",\n458\t    \"super\": \"cmd\",\n459\t    \"meta\": \"cmd\",\n460\t    \"option\": \"alt\",\n461\t}\n462\t\n463\t\n464\tdef _normalize_keys(keys: str) -> list[str]:\n465\t    parts = [k.strip() for k in keys.split(\"+\") if k.strip()]\n466\t    if not parts:\n467\t        return []\n468\t    out: list[str] = []\n469\t    for p in parts:\n470\t        lk = p.lower()\n471\t        out.append(_KEY_ALIASES.get(lk, lk))\n472\t    return out\n473\t\n474\t\n475\tasync def cmd_step_key(out_dir: Path, keys: str) -> int:\n476\t    apply_no_proxy_env()\n477\t    info = load_sandbox_info(out_dir)\n478\t    key_list = _normalize_keys(keys)\n479\t    async with _connect_from_info(info) as sb:\n480\t        # SDK Keyboard.keypress → hotkey; single keys also work via press_key.\n481\t        if len(key_list) == 1:\n482\t            await sb._transport.send(\"press_key\", key=key_list[0])\n483\t        else:\n484\t            await sb.keyboard.keypress(key_list)\n485\t    _emit({\"ok\": True, \"keys\": keys})\n486\t    return 0\n487\t\n488\t\n489\tasync def cmd_step_scroll(\n490\t    out_dir: Path, x: int, y: int, *, scroll_x: int = 0, scroll_y: int = 3\n491\t) -> int:\n492\t    apply_no_proxy_env()\n493\t    info = load_sandbox_info(out_dir)\n494\t    async with _connect_from_info(info) as sb:\n495\t        # cua_sandbox Mouse.scroll sends {x,y,scroll_x,scroll_y}, but computer-server\n496\t        # LinuxAutomationHandler.scroll(x,y) treats x/y as wheel deltas and drops\n497\t        # scroll_x/scroll_y (see trycua/cua computer_server/handlers/linux.py). LocalTransport\n498\t        # does move+scroll correctly; HTTP transport to Docker does not. Work around by\n499\t        # moving first, then scroll_down/up (vertical) or raw scroll deltas (horizontal).\n500\t        await sb.mouse.move(x, y)\n501\t        transport = sb._transport\n502\t        if scroll_y < 0:\n503\t            await transport.send(\"scroll_down\", clicks=abs(scroll_y))\n504\t        elif scroll_y > 0:\n505\t            await transport.send(\"scroll_up\", clicks=scroll_y)\n506\t        if scroll_x < 0:\n507\t            await transport.send(\"scroll\", x=-abs(scroll_x), y=0)\n508\t        elif scroll_x > 0:\n509\t            await transport.send(\"scroll\", x=abs(scroll_x), y=0)\n510\t    _emit({\"ok\": True, \"x\": x, \"y\": y, \"scroll_x\": scroll_x, \"scroll_y\": scroll_y})\n511\t    return 0\n512\t\n513\t\n514\tasync def cmd_step_screen_size(out_dir: Path) -> int:\n515\t    apply_no_proxy_env()\n516\t    info = load_sandbox_info(out_dir)\n517\t    async with _connect_from_info(info) as sb:\n518\t        width, height = await sb.screen.size()\n519\t    _emit({\"ok\": True, \"width\": width, \"height\": height})\n520\t    return 0\n521\t\n522\t\n523\tdef _batch_cleanup_disabled() -> bool:\n524\t    return os.environ.get(\"ANALYZER_BATCH_NO_CLEANUP\", \"\").strip().lower() in (\n525\t        \"1\",\n526\t        \"true\",\n527\t        \"yes\",\n528\t        \"on\",\n529\t    )\n530\t\n531\t\n532\tdef _collect_sandbox_names_from_reports() -> set[str]:\n533\t    names: set[str] = set()\n534\t    if not REPORTS_DIR.is_dir():\n535\t        return names\n536\t    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n537\t        try:\n538\t            data = json.loads(path.read_text(encoding=\"utf-8\"))\n539\t        except (json.JSONDecodeError, OSError):\n540\t            continue\n541\t        name = (data.get(\"name\") or \"\").strip()\n542\t        if name:\n543\t            names.add(name)\n544\t    return names\n545\t\n546\t\n547\tdef _docker_cua_sandbox_container_names() -> set[str]:\n548\t    \"\"\"Container names with Cua sandbox label (running or stopped).\"\"\"\n549\t    if not shutil.which(\"docker\"):\n550\t        return set()\n551\t    proc = subprocess.run(\n552\t        [\n553\t            \"docker\",\n554\t            \"ps\",\n555\t            \"-aq\",\n556\t            \"--filter\",\n557\t            \"label=cua.sandbox=true\",\n558\t            \"--format\",\n559\t            \"{{.Names}}\",\n560\t        ],\n561\t        capture_output=True,\n562\t        text=True,\n563\t        timeout=60,\n564\t    )\n565\t    if proc.returncode != 0:\n566\t        return set()\n567\t    return {line.strip() for line in proc.stdout.splitlines() if line.strip()}\n568\t\n569\t\n570\tdef _docker_force_rm(names: set[str]) -> list[str]:\n571\t    removed: list[str] = []\n572\t    if not names or not shutil.which(\"docker\"):\n573\t        return removed\n574\t    for name in sorted(names):\n575\t        proc = subprocess.run(\n576\t            [\"docker\", \"rm\", \"-f\", name],\n577\t            capture_output=True,\n578\t            text=True,\n579\t            timeout=30,\n580\t        )\n581\t        if proc.returncode == 0:\n582\t            removed.append(name)\n583\t    return removed\n584\t\n585\t\n586\tdef _unlink_sandbox_json_for_name(name: str) -> None:\n587\t    if not REPORTS_DIR.is_dir():\n588\t        return\n589\t    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n590\t        try:\n591\t            data = json.loads(path.read_text(encoding=\"utf-8\"))\n592\t        except (json.JSONDecodeError, OSError):\n593\t            continue\n594\t        if data.get(\"name\") == name:\n595\t            path.unlink(missing_ok=True)\n596\t\n597\t\n598\tasync def cmd_cleanup_all(*, prefix: str = ANALYZER_SANDBOX_PREFIX) -> int:\n599\t    \"\"\"Stop/remove local Cua Docker sandboxes (batch exit / manual cleanup).\"\"\"\n600\t    apply_no_proxy_env()\n601\t    from cua import Sandbox\n602\t\n603\t    docker_names = _docker_cua_sandbox_container_names()\n604\t    targets: set[str] = set(docker_names)\n605\t    targets |= _collect_sandbox_names_from_reports()\n606\t\n607\t    try:\n608\t        listed = await Sandbox.list(local=True)\n609\t        for info in listed:\n610\t            if info.name:\n611\t                targets.add(info.name)\n612\t    except Exception as exc:\n613\t        print(f\"warning: Sandbox.list: {exc}\", file=sys.stderr)\n614\t\n615\t    to_delete = set(docker_names)\n616\t    to_delete |= {n for n in targets if n.startswith(prefix)}\n617\t\n618\t    deleted: list[str] = []\n619\t    errors: list[str] = []\n620\t    for name in sorted(to_delete):\n621\t        try:\n622\t            await Sandbox.delete(name, local=True)\n623\t            deleted.append(name)\n624\t            _unlink_sandbox_json_for_name(name)\n625\t        except Exception as exc:\n626\t            errors.append(f\"{name}: {exc}\")\n627\t\n628\t    docker_removed = _docker_force_rm(to_delete - set(deleted))\n629\t    deleted.extend(n for n in docker_removed if n not in deleted)\n630\t\n631\t    leftover = _docker_cua_sandbox_container_names() - set(deleted)\n632\t    if leftover:\n633\t        docker_removed2 = _docker_force_rm(leftover)\n634\t        deleted.extend(n for n in docker_removed2 if n not in deleted)\n635\t\n636\t    payload = {\n637\t        \"ok\": not errors,\n638\t        \"deleted\": deleted,\n639\t        \"errors\": errors,\n640\t        \"count\": len(deleted),\n641\t    }\n642\t    _emit(payload)\n643\t    if deleted:\n644\t        print(\n645\t            f\"sandbox_ctl cleanup: removed {len(deleted)} container(s)\",\n646\t            file=sys.stderr,\n647\t            flush=True,\n648\t        )\n649\t    for err in errors:\n650\t        print(f\"sandbox_ctl cleanup: {err}\", file=sys.stderr)\n651\t    return 0 if not errors else 1\n652\t\n653\t\n654\tdef reset_batch_cleanup_gate() -> None:\n655\t    \"\"\"Allow a new batch run to run exit cleanup again.\"\"\"\n656\t    global _cleanup_done\n657\t    with _cleanup_lock:\n658\t        _cleanup_done = False\n659\t\n660\t\n661\tdef docker_cleanup_sync_quick() -> int:\n662\t    \"\"\"SIGINT-safe: ``docker rm -f`` Cua containers without asyncio (for signal handler).\"\"\"\n663\t    if _batch_cleanup_disabled():\n664\t        return 0\n665\t    names = _docker_cua_sandbox_container_names()\n666\t    names |= {\n667\t        n\n668\t        for n in _collect_sandbox_names_from_reports()\n669\t        if n.startswith(ANALYZER_SANDBOX_PREFIX)\n670\t    }\n671\t    removed = _docker_force_rm(names)\n672\t    if removed:\n673\t        print(\n674\t            f\"sandbox_ctl: 已停止 {len(removed)} 个 Docker 沙盒容器\",\n675\t            file=sys.stderr,\n676\t            flush=True,\n677\t        )\n678\t    return len(removed)\n679\t\n680\t\n681\tdef _batch_signal_handler(signum: int, frame: Any) -> None:\n682\t    \"\"\"First Ctrl+C: quick docker stop; then raise KeyboardInterrupt for ``finally``.\"\"\"\n683\t    try:\n684\t        docker_cleanup_sync_quick()\n685\t    except Exception:\n686\t        pass\n687\t    raise KeyboardInterrupt\n688\t\n689\t\n690\tdef install_batch_exit_hooks(*, local: bool) -> None:\n691\t    \"\"\"Register SIGINT/SIGTERM + atexit so forced exit still cleans Docker sandboxes.\"\"\"\n692\t    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n693\t    if not local or _batch_cleanup_disabled() or _batch_exit_hooks_installed:\n694\t        return\n695\t    _prev_sigint_handler = signal.getsignal(signal.SIGINT)\n696\t    _prev_sigterm_handler = signal.getsignal(signal.SIGTERM)\n697\t    signal.signal(signal.SIGINT, _batch_signal_handler)\n698\t    signal.signal(signal.SIGTERM, _batch_signal_handler)\n699\t    atexit.register(cleanup_all_local_sandboxes)\n700\t    _batch_exit_hooks_installed = True\n701\t\n702\t\n703\tdef uninstall_batch_exit_hooks() -> None:\n704\t    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n705\t    if not _batch_exit_hooks_installed:\n706\t        return\n707\t    if _prev_sigint_handler is not None:\n708\t        signal.signal(signal.SIGINT, _prev_sigint_handler)\n709\t    if _prev_sigterm_handler is not None:\n710\t        signal.signal(signal.SIGTERM, _prev_sigterm_handler)\n711\t    _prev_sigint_handler = None\n712\t    _prev_sigterm_handler = None\n713\t    _batch_exit_hooks_installed = False\n714\t\n715\t\n716\tdef cleanup_all_local_sandboxes(*, force: bool = False) -> None:\n717\t    \"\"\"Idempotent batch-exit hook: tear down Cua Docker sandboxes. Never raises.\"\"\"\n718\t    global _cleanup_done\n719\t    if _batch_cleanup_disabled():\n720\t        return\n721\t    with _cleanup_lock:\n722\t        if _cleanup_done and not force:\n723\t            return\n724\t        _cleanup_done = True\n725\t    try:\n726\t        asyncio.run(cmd_cleanup_all())\n727\t    except Exception as exc:\n728\t        print(f\"sandbox_ctl cleanup: {exc}\", file=sys.stderr, flush=True)\n729\t        try:\n730\t            docker_cleanup_sync_quick()\n731\t        except Exception:\n732\t            pass\n733\t\n734\t\n735\tdef teardown_out_dir(out_dir: Path) -> None:\n736\t    \"\"\"Best-effort teardown for batch finally hook; never raises.\"\"\"\n737\t    try:\n738\t        asyncio.run(cmd_teardown(out_dir))\n739\t    except Exception as exc:\n740\t        print(f\"sandbox_ctl teardown: {exc}\", file=sys.stderr)\n741\t\n742\t\n743\tdef _build_parser() -> argparse.ArgumentParser:\n744\t    p = argparse.ArgumentParser(description=\"Step-by-step Cua sandbox control for product-analyzer batch\")\n745\t    sub = p.add_subparsers(dest=\"command\", required=True)\n746\t\n747\t    boot = sub.add_parser(\"bootstrap\", help=\"Create named sandbox and write sandbox.json\")\n748\t    boot.add_argument(\"out_dir\", type=Path)\n749\t    boot.add_argument(\n750\t        \"--open-browser\",\n751\t        action=\"store_true\",\n752\t        help=\"After bootstrap, launch Firefox (cua-xfce; use with --url for Ctrl+L navigation)\",\n753\t    )\n754\t    boot.add_argument(\n755\t        \"--url\",\n756\t        default=None,\n757\t        help=\"Product homepage URL (opens via step open-url / Ctrl+L, not wget)\",\n758\t    )\n759\t\n760\t    sub.add_parser(\"teardown\", help=\"Delete sandbox and remove sandbox.json\").add_argument(\n761\t        \"out_dir\", type=Path\n762\t    )\n763\t    sub.add_parser(\n764\t        \"cleanup-all\",\n765\t        help=\"Remove all local Cua Docker sandboxes (analyzer-* + label cua.sandbox=true)\",\n766\t    )\n767\t    sub.add_parser(\"status\", help=\"Print sandbox.json and probe /status\").add_argument(\n768\t        \"out_dir\", type=Path\n769\t    )\n770\t\n771\t    step = sub.add_parser(\"step\", help=\"Single sandbox action\")\n772\t    step_sub = step.add_subparsers(dest=\"step_cmd\", required=True)\n773\t\n774\t    shot = step_sub.add_parser(\"screenshot\", help=\"Save PNG to --out path\")\n775\t    shot.add_argument(\"out_dir\", type=Path)\n776\t    shot.add_argument(\"--out\", type=Path, required=True)\n777\t\n778\t    shell = step_sub.add_parser(\n779\t        \"shell\",\n780\t        help=\"Run one shell command in sandbox (prefer -c)\",\n781\t    )\n782\t    shell.add_argument(\"out_dir\", type=Path)\n783\t    shell.add_argument(\n784\t        \"-c\",\n785\t        \"--cmd\",\n786\t        dest=\"shell_cmd\",\n787\t        metavar=\"CMD\",\n788\t        help=\"Shell command string (required unless legacy args after --)\",\n789\t    )\n790\t    shell.add_argument(\n791\t        \"shell_argv\",\n792\t        nargs=argparse.REMAINDER,\n793\t        metavar=\"[-- CMD ...]\",\n794\t        help=\"Legacy: command tokens after --\",\n795\t    )\n796\t\n797\t    click_p = step_sub.add_parser(\"click\", help=\"Click at x y\")\n798\t    click_p.add_argument(\"out_dir\", type=Path)\n799\t    click_p.add_argument(\"x\", type=int)\n800\t    click_p.add_argument(\"y\", type=int)\n801\t    click_p.add_argument(\"--button\", choices=(\"left\", \"right\", \"double\"), default=\"left\")\n802\t\n803\t    move_p = step_sub.add_parser(\"move\", help=\"Move cursor to x y\")\n804\t    move_p.add_argument(\"out_dir\", type=Path)\n805\t    move_p.add_argument(\"x\", type=int)\n806\t    move_p.add_argument(\"y\", type=int)\n807\t\n808\t    type_p = step_sub.add_parser(\"type\", help=\"Type text\")\n809\t    type_p.add_argument(\"out_dir\", type=Path)\n810\t    type_p.add_argument(\"text\")\n811\t\n812\t    key_p = step_sub.add_parser(\"key\", help=\"Keypress (enter or ctrl+c)\")\n813\t    key_p.add_argument(\"out_dir\", type=Path)\n814\t    key_p.add_argument(\"keys\")\n815\t\n816\t    scroll_p = step_sub.add_parser(\"scroll\", help=\"Scroll at x y\")\n817\t    scroll_p.add_argument(\"out_dir\", type=Path)\n818\t    scroll_p.add_argument(\"x\", type=int)\n819\t    scroll_p.add_argument(\"y\", type=int)\n820\t    scroll_p.add_argument(\"--scroll-x\", type=int, default=0)\n821\t    scroll_p.add_argument(\"--scroll-y\", type=int, default=3)\n822\t\n823\t    step_sub.add_parser(\"screen-size\", help=\"Print sandbox display width x height\").add_argument(\n824\t        \"out_dir\", type=Path\n825\t    )\n826\t\n827\t    open_url = step_sub.add_parser(\n828\t        \"open-url\",\n829\t        help=\"Launch browser (once) and open URL via keyboard (mouse-first)\",\n830\t    )\n831\t    open_url.add_argument(\"out_dir\", type=Path)\n832\t    open_url.add_argument(\"url\")\n833\t    open_url.add_argument(\n834\t        \"--no-launch\",\n835\t        action=\"store_true\",\n836\t        help=\"Skip Firefox launch (browser already running)\",\n837\t    )\n838\t\n839\t    return p\n840\t\n841\t\n842\tdef main(argv: list[str] | None = None) -> int:\n843\t    args = _build_parser().parse_args(argv)\n844\t    if args.command == \"bootstrap\":\n845\t        return asyncio.run(\n846\t            cmd_bootstrap(\n847\t                args.out_dir,\n848\t                open_browser=args.open_browser,\n849\t                url=getattr(args, \"url\", None),\n850\t            )\n851\t        )\n852\t    if args.command == \"teardown\":\n853\t        return asyncio.run(cmd_teardown(args.out_dir))\n854\t    if args.command == \"cleanup-all\":\n855\t        return asyncio.run(cmd_cleanup_all())\n856\t    if args.command == \"status\":\n857\t        return cmd_status(args.out_dir)\n858\t    if args.command == \"step\":\n859\t        if args.step_cmd == \"screenshot\":\n860\t            return asyncio.run(cmd_step_screenshot(args.out_dir, args.out))\n861\t        if args.step_cmd == \"shell\":\n862\t            command = _resolve_shell_command(\n863\t                getattr(args, \"shell_cmd\", None),\n864\t                getattr(args, \"shell_argv\", None) or [],\n865\t            )\n866\t            if not command:\n867\t                print(\n868\t                    \"error: shell requires -c '...' or arguments after --\",\n869\t                    file=sys.stderr,\n870\t                )\n871\t                return 1\n872\t            return asyncio.run(cmd_step_shell(args.out_dir, command))\n873\t        if args.step_cmd == \"click\":\n874\t            return asyncio.run(\n875\t                cmd_step_click(args.out_dir, args.x, args.y, button=args.button)\n876\t            )\n877\t        if args.step_cmd == \"move\":\n878\t            return asyncio.run(cmd_step_move(args.out_dir, args.x, args.y))\n879\t        if args.step_cmd == \"type\":\n880\t            return asyncio.run(cmd_step_type(args.out_dir, args.text))\n881\t        if args.step_cmd == \"key\":\n882\t            return asyncio.run(cmd_step_key(args.out_dir, args.keys))\n883\t        if args.step_cmd == \"scroll\":\n884\t            return asyncio.run(\n885\t                cmd_step_scroll(\n886\t                    args.out_dir,\n887\t                    args.x,\n888\t                    args.y,\n889\t                    scroll_x=args.scroll_x,\n890\t                    scroll_y=args.scroll_y,\n891\t                )\n892\t            )\n893\t        if args.step_cmd == \"screen-size\":\n894\t            return asyncio.run(cmd_step_screen_size(args.out_dir))\n895\t        if args.step_cmd == \"open-url\":\n896\t            return asyncio.run(\n897\t                cmd_step_open_url(\n898\t                    args.out_dir,\n899\t                    args.url,\n900\t                    launch=not args.no_launch,\n901\t                )\n902\t            )\n903\t    return 1\n904\t\n905\t\n906\tif __name__ == \"__main__\":\n907\t    sys.exit(main())\n908\t"}]},"parent_tool_use_id":null,"session_id":"f7306cb3-f577-448d-82ba-7c9e9ee47b08","uuid":"147baff6-35bb-44be-9d1d-72fee9556128","timestamp":"2026-05-21T17:28:40.758Z","tool_use_result":{"type":"text","file":{"filePath":"/home/zhiwei/projects/computer-use/scripts/product_analyzer/sandbox_ctl.py","content":"\"\"\"Thin CLI bridge: step-by-step Cua sandbox control for batch workers.\n\nDoes not import claude_driver (keeps dependency graph acyclic).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport asyncio\nimport json\nimport os\nimport re\nimport atexit\nimport shutil\nimport signal\nimport subprocess\nimport sys\nimport threading\nimport urllib.request\nfrom pathlib import Path\nfrom typing import Any\n\nfrom .config import REPORTS_DIR\nfrom .sandbox_runtime import (\n    LINUX_CONTAINER_IMAGE,\n    LINUX_DOCKER_PLATFORM,\n    apply_no_proxy_env,\n    linux_container_image,\n    linux_docker_runtime,\n)\nfrom .tasks import read_metadata, update_metadata\n\nSANDBOX_JSON = \"sandbox.json\"\nLAST_SHELL_JSON = \".sandbox_ctl_last_shell.json\"\n_MIN_SCREENSHOT_BYTES = 1000\nANALYZER_SANDBOX_PREFIX = \"analyzer-\"\n_PAGE_LOAD_WAIT_S = 10.0\n\n_cleanup_lock = threading.Lock()\n_cleanup_done = False\n_batch_exit_hooks_installed = False\n_prev_sigint_handler: Any = None\n_prev_sigterm_handler: Any = None\n\n\ndef _emit(payload: dict, *, file: Path | None = None) -> None:\n    \"\"\"Print one JSON line to stdout (always flushed) and optionally persist.\"\"\"\n    line = json.dumps(payload, ensure_ascii=False) + \"\\n\"\n    sys.stdout.write(line)\n    sys.stdout.flush()\n    if file is not None:\n        file.parent.mkdir(parents=True, exist_ok=True)\n        file.write_text(line, encoding=\"utf-8\")\n\n\ndef sandbox_json_path(out_dir: Path) -> Path:\n    return out_dir.resolve() / SANDBOX_JSON\n\n\ndef load_sandbox_info(out_dir: Path) -> dict[str, Any]:\n    path = sandbox_json_path(out_dir)\n    if not path.is_file():\n        raise FileNotFoundError(f\"{SANDBOX_JSON} not found under {out_dir}; run bootstrap first\")\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_sandbox_info(out_dir: Path, info: dict[str, Any]) -> Path:\n    path = sandbox_json_path(out_dir)\n    out_dir.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(info, indent=2, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n    return path\n\n\ndef _derive_sandbox_name(out_dir: Path) -> str:\n    base = out_dir.resolve().name\n    safe = re.sub(r\"[^a-zA-Z0-9._-]+\", \"-\", base).strip(\"-\").lower()\n    safe = safe[:48] or \"task\"\n    return f\"analyzer-{safe}\"\n\n\ndef _api_url_from_sb(sb: Any) -> str:\n    rt = getattr(sb, \"_runtime_info\", None)\n    if rt and getattr(rt, \"api_port\", None):\n        host = getattr(rt, \"host\", None) or \"127.0.0.1\"\n        return f\"http://{host}:{rt.api_port}\"\n    raise RuntimeError(\"sandbox has no api_port in runtime_info\")\n\n\ndef _merge_metadata_sandbox(out_dir: Path, name: str, api_url: str, local: bool) -> None:\n    meta = read_metadata(out_dir)\n    if not meta:\n        return\n    sandbox = dict(meta.get(\"sandbox\") or {})\n    sandbox[\"name\"] = name\n    sandbox[\"api_url\"] = api_url\n    sandbox[\"local\"] = local\n    update_metadata(out_dir, sandbox=sandbox)\n\n\ndef _connect_from_info(info: dict[str, Any]) -> Any:\n    from cua import Sandbox\n\n    name = info[\"name\"]\n    local = bool(info.get(\"local\", True))\n    api_key = os.environ.get(\"CUA_API_KEY\") if not local else None\n    kwargs: dict[str, Any] = {\"name\": name, \"local\": local, \"api_key\": api_key}\n    api_url = (info.get(\"api_url\") or \"\").strip()\n    if api_url:\n        # Prefer stored computer-server URL (Sandbox.connect http_url=… per SDK docs).\n        kwargs[\"http_url\"] = api_url\n    return Sandbox.connect(**kwargs)\n\n\n# cua-xfce Linux image ships Firefox only (no Chromium). Probe DISPLAY from /tmp/.X11-unix\n# (often :1, not :0) before launching.\n_LINUX_DISPLAY_PROBE = (\n    'D=\"${DISPLAY:-}\"; '\n    'if [ -z \"$D\" ] || [ ! -S \"/tmp/.X11-unix/X${D#:}\" ] 2>/dev/null; then '\n    \"for x in /tmp/.X11-unix/X*; do \"\n    '[ -S \"$x\" ] || continue; '\n    'D=\":${x##*/X}\"; break; '\n    \"done; \"\n    \"fi; \"\n    'export DISPLAY=\"${D:-:1}\"; '\n)\n\n_LINUX_FIREFOX_LAUNCH_SHELL = (\n    _LINUX_DISPLAY_PROBE\n    + \"if pgrep -x firefox >/dev/null 2>&1; then exit 0; fi; \"\n    + \"firefox --new-window about:blank >/dev/null 2>&1 & \"\n    + \"sleep 3; \"\n    + \"pgrep -x firefox >/dev/null\"\n)\n\n# Best-effort: keep XFCE desktop awake during long batch runs (xset + xfconf + systemd).\n_LINUX_XFCE_DISABLE_SLEEP_SHELL = (\n    _LINUX_DISPLAY_PROBE\n    + \"if command -v xset >/dev/null 2>&1; then \"\n    + \"xset s off -dpms s noblank 2>/dev/null || true; \"\n    + \"fi; \"\n    + \"if command -v xfconf-query >/dev/null 2>&1; then \"\n    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/inactivity-sleep-mode-on-ac -s 0 \"\n    + \"2>/dev/null || true; \"\n    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/inactivity-sleep-mode-on-battery -s 0 \"\n    + \"2>/dev/null || true; \"\n    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/blank-on-ac -s 0 \"\n    + \"2>/dev/null || true; \"\n    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/blank-on-battery -s 0 \"\n    + \"2>/dev/null || true; \"\n    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-sleep -s 0 \"\n    + \"2>/dev/null || true; \"\n    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-off -s 0 \"\n    + \"2>/dev/null || true; \"\n    + \"xfconf-query -c screensaver -p /saver/enabled -s false 2>/dev/null || true; \"\n    + \"xfconf-query -c screensaver -p /saver/idle-activation/enabled -s false 2>/dev/null || true; \"\n    + \"fi; \"\n    + \"if command -v systemctl >/dev/null 2>&1; then \"\n    + \"systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target \"\n    + \"2>/dev/null || true; \"\n    + \"fi; \"\n    + \"exit 0\"\n)\n\n\nasync def _launch_browser_once(out_dir: Path) -> int:\n    \"\"\"One-time shell helper to start Firefox; navigation after this is mouse/keyboard.\"\"\"\n    return await cmd_step_shell(out_dir, _LINUX_FIREFOX_LAUNCH_SHELL)\n\n\nasync def _disable_linux_xfce_sleep(out_dir: Path) -> None:\n    \"\"\"Best-effort disable screen blank/suspend on cua-xfce; never fails bootstrap.\"\"\"\n    rc = await cmd_step_shell(out_dir, _LINUX_XFCE_DISABLE_SLEEP_SHELL)\n    if rc != 0:\n        print(\n            \"warning: sandbox_ctl could not fully disable XFCE sleep (non-fatal)\",\n            file=sys.stderr,\n        )\n\n\nasync def cmd_step_open_url(out_dir: Path, url: str, *, launch: bool = True) -> int:\n    \"\"\"Open URL in sandbox browser using keyboard focus + type (mouse-first navigation).\"\"\"\n    if launch:\n        await _launch_browser_once(out_dir)\n        await asyncio.sleep(1.0)\n    # Focus omnibox then type URL (Firefox on cua-xfce XFCE).\n    await cmd_step_key(out_dir, \"ctrl+l\")\n    await asyncio.sleep(0.4)\n    await cmd_step_key(out_dir, \"ctrl+a\")\n    await asyncio.sleep(0.1)\n    await cmd_step_type(out_dir, url)\n    await asyncio.sleep(0.2)\n    await cmd_step_key(out_dir, \"enter\")\n    await asyncio.sleep(_PAGE_LOAD_WAIT_S)\n    _emit({\"ok\": True, \"action\": \"open-url\", \"url\": url, \"load_wait_s\": _PAGE_LOAD_WAIT_S})\n    return 0\n\n\nasync def cmd_bootstrap(\n    out_dir: Path,\n    *,\n    open_browser: bool,\n    url: str | None = None,\n) -> int:\n    apply_no_proxy_env()\n    out_dir = out_dir.resolve()\n    if sandbox_json_path(out_dir).is_file():\n        print(f\"error: {SANDBOX_JSON} already exists; run teardown first\", file=sys.stderr)\n        return 1\n\n    runtime = os.environ.get(\"ANALYZER_RUNTIME\", \"sandbox-local\")\n    image_key = os.environ.get(\"ANALYZER_SANDBOX_IMAGE\", \"linux\").lower()\n    local = runtime != \"sandbox-cloud\"\n    name = _derive_sandbox_name(out_dir)\n\n    from cua import Sandbox\n\n    if local:\n        if image_key not in (\"auto\", \"linux\"):\n            print(\n                f\"warning: sandbox_ctl bootstrap only implements linux container; \"\n                f\"got image={image_key!r}\",\n                file=sys.stderr,\n            )\n        sb = await Sandbox.create(\n            linux_container_image(),\n            name=name,\n            local=True,\n            runtime=linux_docker_runtime(ephemeral=False),\n        )\n        provider = \"docker\"\n        image = os.environ.get(\"ANALYZER_LINUX_CONTAINER_IMAGE\", LINUX_CONTAINER_IMAGE)\n        platform = os.environ.get(\"ANALYZER_LINUX_DOCKER_PLATFORM\", LINUX_DOCKER_PLATFORM)\n    else:\n        api_key = os.environ.get(\"CUA_API_KEY\", \"\").strip()\n        if not api_key:\n            print(\"error: CUA_API_KEY required for cloud bootstrap\", file=sys.stderr)\n            return 1\n        from cua import Image\n\n        sb = await Sandbox.create(Image.linux(), name=name, local=False, api_key=api_key)\n        provider = \"cloud\"\n        image = \"linux\"\n        platform = None\n\n    api_url = _api_url_from_sb(sb)\n    info = {\n        \"name\": sb.name or name,\n        \"provider\": provider,\n        \"api_url\": api_url,\n        \"image\": image,\n        \"platform\": platform,\n        \"local\": local,\n    }\n    write_sandbox_info(out_dir, info)\n    _merge_metadata_sandbox(out_dir, info[\"name\"], api_url, local)\n    await sb.disconnect()\n\n    _emit({\"ok\": True, \"sandbox\": info})\n\n    if local and image_key in (\"auto\", \"linux\"):\n        await _disable_linux_xfce_sleep(out_dir)\n\n    if open_browser:\n        target = (url or os.environ.get(\"ANALYZER_PRODUCT_URL\") or \"\").strip()\n        if target:\n            return await cmd_step_open_url(out_dir, target, launch=True)\n        return await _launch_browser_once(out_dir)\n    return 0\n\n\nasync def cmd_teardown(out_dir: Path) -> int:\n    apply_no_proxy_env()\n    out_dir = out_dir.resolve()\n    path = sandbox_json_path(out_dir)\n    if not path.is_file():\n        _emit({\"ok\": True, \"skipped\": \"no sandbox.json\"})\n        return 0\n    info = load_sandbox_info(out_dir)\n    from cua import Sandbox\n\n    try:\n        await Sandbox.delete(\n            info[\"name\"],\n            local=bool(info.get(\"local\", True)),\n            api_key=os.environ.get(\"CUA_API_KEY\") if not info.get(\"local\", True) else None,\n        )\n    except Exception as exc:\n        print(f\"warning: Sandbox.delete: {exc}\", file=sys.stderr)\n    path.unlink(missing_ok=True)\n    _emit({\"ok\": True, \"deleted\": info[\"name\"]})\n    return 0\n\n\ndef cmd_status(out_dir: Path) -> int:\n    out_dir = out_dir.resolve()\n    path = sandbox_json_path(out_dir)\n    if not path.is_file():\n        _emit({\"ok\": False, \"error\": f\"no {SANDBOX_JSON} in {out_dir}\"})\n        return 1\n    info = load_sandbox_info(out_dir)\n    _emit({\"ok\": True, \"sandbox\": info})\n    print(json.dumps(info, indent=2, ensure_ascii=False))\n    api_url = info.get(\"api_url\", \"\")\n    if api_url:\n        try:\n            req = urllib.request.Request(f\"{api_url.rstrip('/')}/status\", method=\"GET\")\n            with urllib.request.urlopen(req, timeout=5) as resp:\n                body = resp.read().decode(\"utf-8\", errors=\"replace\")[:500]\n            print(f\"GET {api_url}/status -> {resp.status} {body[:200]}\")\n        except Exception as exc:\n            print(f\"GET {api_url}/status failed: {exc}\", file=sys.stderr)\n            return 1\n    return 0\n\n\nasync def cmd_step_screenshot(out_dir: Path, out_path: Path) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    out_path = out_path if out_path.is_absolute() else (out_dir.resolve() / out_path)\n    out_path.parent.mkdir(parents=True, exist_ok=True)\n\n    async with _connect_from_info(info) as sb:\n        png = await sb.screenshot()\n\n    out_path.write_bytes(png)\n    ok = len(png) >= _MIN_SCREENSHOT_BYTES\n    _emit({\"ok\": ok, \"path\": str(out_path), \"bytes\": len(png)})\n    return 0 if ok else 1\n\n\ndef _resolve_shell_command(shell_cmd: str | None, shell_argv: list[str]) -> str | None:\n    if shell_cmd and shell_cmd.strip():\n        return shell_cmd.strip()\n    parts = list(shell_argv)\n    if parts and parts[0] == \"--\":\n        parts = parts[1:]\n    # REMAINDER may capture ``-c cmd ...`` when -c follows positional out_dir.\n    if parts and parts[0] in (\"-c\", \"--cmd\"):\n        parts = parts[1:]\n    if not parts:\n        return None\n    return \" \".join(parts)\n\n\nasync def cmd_step_shell(out_dir: Path, command: str) -> int:\n    apply_no_proxy_env()\n    out_dir = out_dir.resolve()\n    artifact = out_dir / LAST_SHELL_JSON\n    try:\n        info = load_sandbox_info(out_dir)\n        async with _connect_from_info(info) as sb:\n            result = await sb.shell.run(command)\n    except Exception as exc:\n        payload = {\n            \"ok\": False,\n            \"returncode\": 1,\n            \"stdout\": \"\",\n            \"stderr\": str(exc),\n            \"command\": command,\n            \"artifact\": str(artifact),\n            \"error\": f\"{type(exc).__name__}: {exc}\",\n        }\n        _emit(payload, file=artifact)\n        print(f\"sandbox_ctl shell: {payload['error']}\", file=sys.stderr, flush=True)\n        return 1\n    stdout = result.stdout or \"\"\n    stderr = result.stderr or \"\"\n    payload = {\n        \"ok\": result.success,\n        \"returncode\": result.returncode,\n        \"stdout\": stdout,\n        \"stderr\": stderr,\n        \"command\": command,\n        \"artifact\": str(artifact),\n    }\n    _emit(payload, file=artifact)\n    # Human-readable tail on stderr so Bash-tool users still see something if stdout is sparse.\n    print(\n        f\"sandbox_ctl shell: ok={result.success} rc={result.returncode} \"\n        f\"stdout_bytes={len(stdout)} stderr_bytes={len(stderr)}\",\n        file=sys.stderr,\n        flush=True,\n    )\n    if stdout:\n        sys.stderr.write(stdout if stdout.endswith(\"\\n\") else stdout + \"\\n\")\n        sys.stderr.flush()\n    if stderr:\n        sys.stderr.write(stderr if stderr.endswith(\"\\n\") else stderr + \"\\n\")\n        sys.stderr.flush()\n    return 0 if result.success else 1\n\n\nasync def cmd_step_click(out_dir: Path, x: int, y: int, *, button: str) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        if button == \"right\":\n            await sb.mouse.right_click(x, y)\n        elif button == \"double\":\n            await sb.mouse.double_click(x, y)\n        else:\n            await sb.mouse.click(x, y)\n    _emit({\"ok\": True, \"action\": button, \"x\": x, \"y\": y})\n    return 0\n\n\nasync def cmd_step_move(out_dir: Path, x: int, y: int) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        await sb.mouse.move(x, y)\n    _emit({\"ok\": True, \"x\": x, \"y\": y})\n    return 0\n\n\nasync def cmd_step_type(out_dir: Path, text: str) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        await sb.keyboard.type(text)\n    _emit({\"ok\": True, \"chars\": len(text)})\n    return 0\n\n\n# computer-server (pynput) Key names differ from SDK docs examples — normalize before hotkey.\n# Linux: Key.esc not escape; Key.cmd not meta; Key.page_up not pageup; etc.\n_KEY_ALIASES: dict[str, str] = {\n    \"escape\": \"esc\",\n    \"esc\": \"esc\",\n    \"enter\": \"enter\",\n    \"return\": \"enter\",\n    \"ret\": \"enter\",\n    \"tab\": \"tab\",\n    \"space\": \"space\",\n    \" \": \"space\",\n    \"backspace\": \"backspace\",\n    \"bs\": \"backspace\",\n    \"delete\": \"delete\",\n    \"del\": \"delete\",\n    \"insert\": \"insert\",\n    \"ins\": \"insert\",\n    \"home\": \"home\",\n    \"end\": \"end\",\n    \"pageup\": \"page_up\",\n    \"page_up\": \"page_up\",\n    \"pgup\": \"page_up\",\n    \"pagedown\": \"page_down\",\n    \"page_down\": \"page_down\",\n    \"pgdn\": \"page_down\",\n    \"up\": \"up\",\n    \"down\": \"down\",\n    \"left\": \"left\",\n    \"right\": \"right\",\n    \"control\": \"ctrl\",\n    \"command\": \"cmd\",\n    \"cmd\": \"cmd\",\n    \"win\": \"cmd\",\n    \"super\": \"cmd\",\n    \"meta\": \"cmd\",\n    \"option\": \"alt\",\n}\n\n\ndef _normalize_keys(keys: str) -> list[str]:\n    parts = [k.strip() for k in keys.split(\"+\") if k.strip()]\n    if not parts:\n        return []\n    out: list[str] = []\n    for p in parts:\n        lk = p.lower()\n        out.append(_KEY_ALIASES.get(lk, lk))\n    return out\n\n\nasync def cmd_step_key(out_dir: Path, keys: str) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    key_list = _normalize_keys(keys)\n    async with _connect_from_info(info) as sb:\n        # SDK Keyboard.keypress → hotkey; single keys also work via press_key.\n        if len(key_list) == 1:\n            await sb._transport.send(\"press_key\", key=key_list[0])\n        else:\n            await sb.keyboard.keypress(key_list)\n    _emit({\"ok\": True, \"keys\": keys})\n    return 0\n\n\nasync def cmd_step_scroll(\n    out_dir: Path, x: int, y: int, *, scroll_x: int = 0, scroll_y: int = 3\n) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        # cua_sandbox Mouse.scroll sends {x,y,scroll_x,scroll_y}, but computer-server\n        # LinuxAutomationHandler.scroll(x,y) treats x/y as wheel deltas and drops\n        # scroll_x/scroll_y (see trycua/cua computer_server/handlers/linux.py). LocalTransport\n        # does move+scroll correctly; HTTP transport to Docker does not. Work around by\n        # moving first, then scroll_down/up (vertical) or raw scroll deltas (horizontal).\n        await sb.mouse.move(x, y)\n        transport = sb._transport\n        if scroll_y < 0:\n            await transport.send(\"scroll_down\", clicks=abs(scroll_y))\n        elif scroll_y > 0:\n            await transport.send(\"scroll_up\", clicks=scroll_y)\n        if scroll_x < 0:\n            await transport.send(\"scroll\", x=-abs(scroll_x), y=0)\n        elif scroll_x > 0:\n            await transport.send(\"scroll\", x=abs(scroll_x), y=0)\n    _emit({\"ok\": True, \"x\": x, \"y\": y, \"scroll_x\": scroll_x, \"scroll_y\": scroll_y})\n    return 0\n\n\nasync def cmd_step_screen_size(out_dir: Path) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        width, height = await sb.screen.size()\n    _emit({\"ok\": True, \"width\": width, \"height\": height})\n    return 0\n\n\ndef _batch_cleanup_disabled() -> bool:\n    return os.environ.get(\"ANALYZER_BATCH_NO_CLEANUP\", \"\").strip().lower() in (\n        \"1\",\n        \"true\",\n        \"yes\",\n        \"on\",\n    )\n\n\ndef _collect_sandbox_names_from_reports() -> set[str]:\n    names: set[str] = set()\n    if not REPORTS_DIR.is_dir():\n        return names\n    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n        try:\n            data = json.loads(path.read_text(encoding=\"utf-8\"))\n        except (json.JSONDecodeError, OSError):\n            continue\n        name = (data.get(\"name\") or \"\").strip()\n        if name:\n            names.add(name)\n    return names\n\n\ndef _docker_cua_sandbox_container_names() -> set[str]:\n    \"\"\"Container names with Cua sandbox label (running or stopped).\"\"\"\n    if not shutil.which(\"docker\"):\n        return set()\n    proc = subprocess.run(\n        [\n            \"docker\",\n            \"ps\",\n            \"-aq\",\n            \"--filter\",\n            \"label=cua.sandbox=true\",\n            \"--format\",\n            \"{{.Names}}\",\n        ],\n        capture_output=True,\n        text=True,\n        timeout=60,\n    )\n    if proc.returncode != 0:\n        return set()\n    return {line.strip() for line in proc.stdout.splitlines() if line.strip()}\n\n\ndef _docker_force_rm(names: set[str]) -> list[str]:\n    removed: list[str] = []\n    if not names or not shutil.which(\"docker\"):\n        return removed\n    for name in sorted(names):\n        proc = subprocess.run(\n            [\"docker\", \"rm\", \"-f\", name],\n            capture_output=True,\n            text=True,\n            timeout=30,\n        )\n        if proc.returncode == 0:\n            removed.append(name)\n    return removed\n\n\ndef _unlink_sandbox_json_for_name(name: str) -> None:\n    if not REPORTS_DIR.is_dir():\n        return\n    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n        try:\n            data = json.loads(path.read_text(encoding=\"utf-8\"))\n        except (json.JSONDecodeError, OSError):\n            continue\n        if data.get(\"name\") == name:\n            path.unlink(missing_ok=True)\n\n\nasync def cmd_cleanup_all(*, prefix: str = ANALYZER_SANDBOX_PREFIX) -> int:\n    \"\"\"Stop/remove local Cua Docker sandboxes (batch exit / manual cleanup).\"\"\"\n    apply_no_proxy_env()\n    from cua import Sandbox\n\n    docker_names = _docker_cua_sandbox_container_names()\n    targets: set[str] = set(docker_names)\n    targets |= _collect_sandbox_names_from_reports()\n\n    try:\n        listed = await Sandbox.list(local=True)\n        for info in listed:\n            if info.name:\n                targets.add(info.name)\n    except Exception as exc:\n        print(f\"warning: Sandbox.list: {exc}\", file=sys.stderr)\n\n    to_delete = set(docker_names)\n    to_delete |= {n for n in targets if n.startswith(prefix)}\n\n    deleted: list[str] = []\n    errors: list[str] = []\n    for name in sorted(to_delete):\n        try:\n            await Sandbox.delete(name, local=True)\n            deleted.append(name)\n            _unlink_sandbox_json_for_name(name)\n        except Exception as exc:\n            errors.append(f\"{name}: {exc}\")\n\n    docker_removed = _docker_force_rm(to_delete - set(deleted))\n    deleted.extend(n for n in docker_removed if n not in deleted)\n\n    leftover = _docker_cua_sandbox_container_names() - set(deleted)\n    if leftover:\n        docker_removed2 = _docker_force_rm(leftover)\n        deleted.extend(n for n in docker_removed2 if n not in deleted)\n\n    payload = {\n        \"ok\": not errors,\n        \"deleted\": deleted,\n        \"errors\": errors,\n        \"count\": len(deleted),\n    }\n    _emit(payload)\n    if deleted:\n        print(\n            f\"sandbox_ctl cleanup: removed {len(deleted)} container(s)\",\n            file=sys.stderr,\n            flush=True,\n        )\n    for err in errors:\n        print(f\"sandbox_ctl cleanup: {err}\", file=sys.stderr)\n    return 0 if not errors else 1\n\n\ndef reset_batch_cleanup_gate() -> None:\n    \"\"\"Allow a new batch run to run exit cleanup again.\"\"\"\n    global _cleanup_done\n    with _cleanup_lock:\n        _cleanup_done = False\n\n\ndef docker_cleanup_sync_quick() -> int:\n    \"\"\"SIGINT-safe: ``docker rm -f`` Cua containers without asyncio (for signal handler).\"\"\"\n    if _batch_cleanup_disabled():\n        return 0\n    names = _docker_cua_sandbox_container_names()\n    names |= {\n        n\n        for n in _collect_sandbox_names_from_reports()\n        if n.startswith(ANALYZER_SANDBOX_PREFIX)\n    }\n    removed = _docker_force_rm(names)\n    if removed:\n        print(\n            f\"sandbox_ctl: 已停止 {len(removed)} 个 Docker 沙盒容器\",\n            file=sys.stderr,\n            flush=True,\n        )\n    return len(removed)\n\n\ndef _batch_signal_handler(signum: int, frame: Any) -> None:\n    \"\"\"First Ctrl+C: quick docker stop; then raise KeyboardInterrupt for ``finally``.\"\"\"\n    try:\n        docker_cleanup_sync_quick()\n    except Exception:\n        pass\n    raise KeyboardInterrupt\n\n\ndef install_batch_exit_hooks(*, local: bool) -> None:\n    \"\"\"Register SIGINT/SIGTERM + atexit so forced exit still cleans Docker sandboxes.\"\"\"\n    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n    if not local or _batch_cleanup_disabled() or _batch_exit_hooks_installed:\n        return\n    _prev_sigint_handler = signal.getsignal(signal.SIGINT)\n    _prev_sigterm_handler = signal.getsignal(signal.SIGTERM)\n    signal.signal(signal.SIGINT, _batch_signal_handler)\n    signal.signal(signal.SIGTERM, _batch_signal_handler)\n    atexit.register(cleanup_all_local_sandboxes)\n    _batch_exit_hooks_installed = True\n\n\ndef uninstall_batch_exit_hooks() -> None:\n    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n    if not _batch_exit_hooks_installed:\n        return\n    if _prev_sigint_handler is not None:\n        signal.signal(signal.SIGINT, _prev_sigint_handler)\n    if _prev_sigterm_handler is not None:\n        signal.signal(signal.SIGTERM, _prev_sigterm_handler)\n    _prev_sigint_handler = None\n    _prev_sigterm_handler = None\n    _batch_exit_hooks_installed = False\n\n\ndef cleanup_all_local_sandboxes(*, force: bool = False) -> None:\n    \"\"\"Idempotent batch-exit hook: tear down Cua Docker sandboxes. Never raises.\"\"\"\n    global _cleanup_done\n    if _batch_cleanup_disabled():\n        return\n    with _cleanup_lock:\n        if _cleanup_done and not force:\n            return\n        _cleanup_done = True\n    try:\n        asyncio.run(cmd_cleanup_all())\n    except Exception as exc:\n        print(f\"sandbox_ctl cleanup: {exc}\", file=sys.stderr, flush=True)\n        try:\n            docker_cleanup_sync_quick()\n        except Exception:\n            pass\n\n\ndef teardown_out_dir(out_dir: Path) -> None:\n    \"\"\"Best-effort teardown for batch finally hook; never raises.\"\"\"\n    try:\n        asyncio.run(cmd_teardown(out_dir))\n    except Exception as exc:\n        print(f\"sandbox_ctl teardown: {exc}\", file=sys.stderr)\n\n\ndef _build_parser() -> argparse.ArgumentParser:\n    p = argparse.ArgumentParser(description=\"Step-by-step Cua sandbox control for product-analyzer batch\")\n    sub = p.add_subparsers(dest=\"command\", required=True)\n\n    boot = sub.add_parser(\"bootstrap\", help=\"Create named sandbox and write sandbox.json\")\n    boot.add_argument(\"out_dir\", type=Path)\n    boot.add_argument(\n        \"--open-browser\",\n        action=\"store_true\",\n        help=\"After bootstrap, launch Firefox (cua-xfce; use with --url for Ctrl+L navigation)\",\n    )\n    boot.add_argument(\n        \"--url\",\n        default=None,\n        help=\"Product homepage URL (opens via step open-url / Ctrl+L, not wget)\",\n    )\n\n    sub.add_parser(\"teardown\", help=\"Delete sandbox and remove sandbox.json\").add_argument(\n        \"out_dir\", type=Path\n    )\n    sub.add_parser(\n        \"cleanup-all\",\n        help=\"Remove all local Cua Docker sandboxes (analyzer-* + label cua.sandbox=true)\",\n    )\n    sub.add_parser(\"status\", help=\"Print sandbox.json and probe /status\").add_argument(\n        \"out_dir\", type=Path\n    )\n\n    step = sub.add_parser(\"step\", help=\"Single sandbox action\")\n    step_sub = step.add_subparsers(dest=\"step_cmd\", required=True)\n\n    shot = step_sub.add_parser(\"screenshot\", help=\"Save PNG to --out path\")\n    shot.add_argument(\"out_dir\", type=Path)\n    shot.add_argument(\"--out\", type=Path, required=True)\n\n    shell = step_sub.add_parser(\n        \"shell\",\n        help=\"Run one shell command in sandbox (prefer -c)\",\n    )\n    shell.add_argument(\"out_dir\", type=Path)\n    shell.add_argument(\n        \"-c\",\n        \"--cmd\",\n        dest=\"shell_cmd\",\n        metavar=\"CMD\",\n        help=\"Shell command string (required unless legacy args after --)\",\n    )\n    shell.add_argument(\n        \"shell_argv\",\n        nargs=argparse.REMAINDER,\n        metavar=\"[-- CMD ...]\",\n        help=\"Legacy: command tokens after --\",\n    )\n\n    click_p = step_sub.add_parser(\"click\", help=\"Click at x y\")\n    click_p.add_argument(\"out_dir\", type=Path)\n    click_p.add_argument(\"x\", type=int)\n    click_p.add_argument(\"y\", type=int)\n    click_p.add_argument(\"--button\", choices=(\"left\", \"right\", \"double\"), default=\"left\")\n\n    move_p = step_sub.add_parser(\"move\", help=\"Move cursor to x y\")\n    move_p.add_argument(\"out_dir\", type=Path)\n    move_p.add_argument(\"x\", type=int)\n    move_p.add_argument(\"y\", type=int)\n\n    type_p = step_sub.add_parser(\"type\", help=\"Type text\")\n    type_p.add_argument(\"out_dir\", type=Path)\n    type_p.add_argument(\"text\")\n\n    key_p = step_sub.add_parser(\"key\", help=\"Keypress (enter or ctrl+c)\")\n    key_p.add_argument(\"out_dir\", type=Path)\n    key_p.add_argument(\"keys\")\n\n    scroll_p = step_sub.add_parser(\"scroll\", help=\"Scroll at x y\")\n    scroll_p.add_argument(\"out_dir\", type=Path)\n    scroll_p.add_argument(\"x\", type=int)\n    scroll_p.add_argument(\"y\", type=int)\n    scroll_p.add_argument(\"--scroll-x\", type=int, default=0)\n    scroll_p.add_argument(\"--scroll-y\", type=int, default=3)\n\n    step_sub.add_parser(\"screen-size\", help=\"Print sandbox display width x height\").add_argument(\n        \"out_dir\", type=Path\n    )\n\n    open_url = step_sub.add_parser(\n        \"open-url\",\n        help=\"Launch browser (once) and open URL via keyboard (mouse-first)\",\n    )\n    open_url.add_argument(\"out_dir\", type=Path)\n    open_url.add_argument(\"url\")\n    open_url.add_argument(\n        \"--no-launch\",\n        action=\"store_true\",\n        help=\"Skip Firefox launch (browser already running)\",\n    )\n\n    return p\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = _build_parser().parse_args(argv)\n    if args.command == \"bootstrap\":\n        return asyncio.run(\n            cmd_bootstrap(\n                args.out_dir,\n                open_browser=args.open_browser,\n                url=getattr(args, \"url\", None),\n            )\n        )\n    if args.command == \"teardown\":\n        return asyncio.run(cmd_teardown(args.out_dir))\n    if args.command == \"cleanup-all\":\n        return asyncio.run(cmd_cleanup_all())\n    if args.command == \"status\":\n        return cmd_status(args.out_dir)\n    if args.command == \"step\":\n        if args.step_cmd == \"screenshot\":\n            return asyncio.run(cmd_step_screenshot(args.out_dir, args.out))\n        if args.step_cmd == \"shell\":\n            command = _resolve_shell_command(\n                getattr(args, \"shell_cmd\", None),\n                getattr(args, \"shell_argv\", None) or [],\n            )\n            if not command:\n                print(\n                    \"error: shell requires -c '...' or arguments after --\",\n                    file=sys.stderr,\n                )\n                return 1\n            return asyncio.run(cmd_step_shell(args.out_dir, command))\n        if args.step_cmd == \"click\":\n            return asyncio.run(\n                cmd_step_click(args.out_dir, args.x, args.y, button=args.button)\n            )\n        if args.step_cmd == \"move\":\n            return asyncio.run(cmd_step_move(args.out_dir, args.x, args.y))\n        if args.step_cmd == \"type\":\n            return asyncio.run(cmd_step_type(args.out_dir, args.text))\n        if args.step_cmd == \"key\":\n            return asyncio.run(cmd_step_key(args.out_dir, args.keys))\n        if args.step_cmd == \"scroll\":\n            return asyncio.run(\n                cmd_step_scroll(\n                    args.out_dir,\n                    args.x,\n                    args.y,\n                    scroll_x=args.scroll_x,\n                    scroll_y=args.scroll_y,\n                )\n            )\n        if args.step_cmd == \"screen-size\":\n            return asyncio.run(cmd_step_screen_size(args.out_dir))\n        if args.step_cmd == \"open-url\":\n            return asyncio.run(\n                cmd_step_open_url(\n                    args.out_dir,\n                    args.url,\n                    launch=not args.no_launch,\n                )\n            )\n    return 1\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":908,"startLine":1,"totalLines":908}}}
