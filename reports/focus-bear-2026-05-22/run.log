{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_nHAzbadVcIWNZxuv15ex2Aaz","type":"tool_result","content":"1\t\"\"\"Cua sandbox runtime context for batch workers.\n2\t\n3\tDoes not create sandboxes itself. Describes the contract passed to each Claude\n4\tworker so it can create and drive its own sandbox via the Cua Sandbox SDK.\n5\t\"\"\"\n6\t\n7\tfrom __future__ import annotations\n8\t\n9\timport os\n10\tfrom dataclasses import dataclass\n11\tfrom pathlib import Path\n12\tfrom typing import Literal\n13\t\n14\tSandboxMode = Literal[\"local\", \"cloud\"]\n15\t\n16\tSANDBOX_IMAGES = {\"auto\", \"linux\", \"macos\", \"windows\"}\n17\t\n18\t# Local Linux desktop sandbox (XFCE). See Cua docs \"Linux on Docker\".\n19\tLINUX_CONTAINER_IMAGE = \"trycua/cua-xfce:latest\"\n20\tLINUX_DOCKER_PLATFORM = \"linux/amd64\"\n21\t\n22\t# Host-side Cua SDK requires Python 3.12/3.13 (see README conda setup).\n23\tRECOMMENDED_CONDA_ENV = \"computer-use-py312\"\n24\tPYTHON_VERSION_MIN = \"3.12\"\n25\tPYTHON_VERSION_MAX_EXCLUSIVE = \"3.14\"\n26\t\n27\t_NO_PROXY_HOSTS = \"127.0.0.1,localhost\"\n28\t\n29\t\n30\t@dataclass(frozen=True)\n31\tclass SandboxContext:\n32\t    image: str\n33\t    mode: SandboxMode\n34\t    local: bool\n35\t    android_enabled: bool = True\n36\t    api_key: str | None = None\n37\t\n38\t    @property\n39\t    def runtime(self) -> str:\n40\t        return \"sandbox-local\" if self.local else \"sandbox-cloud\"\n41\t\n42\t    def env(self) -> dict[str, str]:\n43\t        out: dict[str, str] = {\n44\t            \"ANALYZER_RUNTIME\": self.runtime,\n45\t            \"ANALYZER_SANDBOX_IMAGE\": self.image,\n46\t            \"ANALYZER_SANDBOX_LOCAL\": \"1\" if self.local else \"0\",\n47\t            \"ANALYZER_SANDBOX_MODE\": self.mode,\n48\t            \"ANALYZER_ANDROID_ENABLED\": \"1\" if self.android_enabled else \"0\",\n49\t        }\n50\t        out[\"ANALYZER_PYTHON_VERSION_MIN\"] = PYTHON_VERSION_MIN\n51\t        out[\"ANALYZER_PYTHON_VERSION_MAX\"] = PYTHON_VERSION_MAX_EXCLUSIVE\n52\t        out[\"ANALYZER_CONDA_ENV\"] = RECOMMENDED_CONDA_ENV\n53\t        if self.local:\n54\t            out.update(_local_no_proxy_env())\n55\t            out[\"ANALYZER_LINUX_CONTAINER_IMAGE\"] = LINUX_CONTAINER_IMAGE\n56\t            out[\"ANALYZER_LINUX_DOCKER_PLATFORM\"] = LINUX_DOCKER_PLATFORM\n57\t        elif self.api_key:\n58\t            out[\"CUA_API_KEY\"] = self.api_key\n59\t        return out\n60\t\n61\t\n62\tdef _local_no_proxy_env() -> dict[str, str]:\n63\t    \"\"\"Bypass system HTTP proxies for localhost Docker port probes (httpx).\"\"\"\n64\t    merged = _NO_PROXY_HOSTS\n65\t    for key in (\"NO_PROXY\", \"no_proxy\"):\n66\t        existing = os.environ.get(key, \"\").strip()\n67\t        if existing:\n68\t            merged = f\"{merged},{existing}\"\n69\t    return {\"NO_PROXY\": merged, \"no_proxy\": merged}\n70\t\n71\t\n72\tdef normalize_sandbox_image(image: str | None) -> str:\n73\t    value = (image or \"auto\").strip().lower()\n74\t    if value not in SANDBOX_IMAGES:\n75\t        choices = \", \".join(sorted(SANDBOX_IMAGES))\n76\t        raise ValueError(f\"unsupported sandbox image: {image!r}; choose one of {choices}\")\n77\t    return value\n78\t\n79\t\n80\tdef resolve_api_key(cli_key: str | None) -> str | None:\n81\t    if cli_key and cli_key.strip():\n82\t        return cli_key.strip()\n83\t    env_key = os.environ.get(\"CUA_API_KEY\", \"\").strip()\n84\t    return env_key or None\n85\t\n86\t\n87\tdef resolve_sandbox_mode(\n88\t    *,\n89\t    cli_sandbox: str | None,\n90\t    interactive: bool,\n91\t) -> SandboxMode:\n92\t    \"\"\"Pick local vs cloud sandbox for batch mode.\n93\t\n94\t    Default is **local**. Cloud is used only when explicitly requested.\n95\t\n96\t    Priority:\n97\t    1. ``--sandbox cloud`` → cloud (caller must ensure API key)\n98\t    2. ``--sandbox local`` or unset → local (``CUA_API_KEY`` in env is ignored)\n99\t    3. Interactive menu: default local; choose ``2`` for cloud\n100\t    \"\"\"\n101\t    if cli_sandbox == \"cloud\":\n102\t        return \"cloud\"\n103\t    if cli_sandbox == \"local\":\n104\t        return \"local\"\n105\t    if interactive:\n106\t        return _prompt_sandbox_mode()\n107\t    return \"local\"\n108\t\n109\t\n110\tdef _prompt_sandbox_mode() -> SandboxMode:\n111\t    from .ui import prompt_str\n112\t\n113\t    choice = prompt_str(\n114\t        \"Sandbox 运行环境 [1=本地 Docker/Lume(默认), 2=云端 Cua Cloud]: \",\n115\t        validate=lambda s: s in (\"\", \"1\", \"2\"),\n116\t        allow_empty=True,\n117\t    )\n118\t    return \"cloud\" if choice == \"2\" else \"local\"\n119\t\n120\t\n121\tdef linux_container_image():\n122\t    \"\"\"Cua SDK Image for local Linux Docker desktop (XFCE).\"\"\"\n123\t    from dataclasses import replace\n124\t\n125\t    from cua import Image\n126\t\n127\t    return replace(\n128\t        Image.linux(kind=\"container\"),\n129\t        _registry=LINUX_CONTAINER_IMAGE,\n130\t    )\n131\t\n132\t\n133\tdef linux_docker_runtime(*, ephemeral: bool = True):\n134\t    \"\"\"DockerRuntime with linux/amd64 platform (needed on Apple Silicon hosts).\"\"\"\n135\t    from cua_sandbox.runtime.docker import DockerRuntime\n136\t\n137\t    return DockerRuntime(ephemeral=ephemeral, platform=LINUX_DOCKER_PLATFORM)\n138\t\n139\t\n140\tdef apply_no_proxy_env(env: dict[str, str] | None = None) -> dict[str, str]:\n141\t    \"\"\"Merge localhost NO_PROXY into *env* (or os.environ copy).\"\"\"\n142\t    import os\n143\t\n144\t    out = dict(env if env is not None else os.environ)\n145\t    out.update(_local_no_proxy_env())\n146\t    return out\n147\t\n148\t\n149\tdef write_cloud_mcp_config(\n150\t    out_dir: Path,\n151\t    *,\n152\t    api_key: str,\n153\t    sandbox_name: str = \"\",\n154\t) -> Path:\n155\t    \"\"\"Write per-worker MCP config for ``cua serve-mcp`` (cloud batch).\"\"\"\n156\t    import json\n157\t\n158\t    out_dir.mkdir(parents=True, exist_ok=True)\n159\t    path = out_dir / \".mcp.json\"\n160\t    env_block: dict[str, str] = {\"CUA_API_KEY\": api_key}\n161\t    if sandbox_name:\n162\t        env_block[\"CUA_SANDBOX\"] = sandbox_name\n163\t    payload = {\n164\t        \"mcpServers\": {\n165\t            \"cua\": {\n166\t                \"command\": \"cua\",\n167\t                \"args\": [\n168\t                    \"serve-mcp\",\n169\t                    \"--permissions\",\n170\t                    \"computer:all,sandbox:all\",\n171\t                ],\n172\t                \"env\": env_block,\n173\t            }\n174\t        }\n175\t    }\n176\t    path.write_text(json.dumps(payload, indent=2) + \"\\n\", encoding=\"utf-8\")\n177\t    return path\n178\t\n179\t\n180\tdef build_sandbox_context(\n181\t    image: str | None,\n182\t    *,\n183\t    mode: SandboxMode,\n184\t    android_enabled: bool = True,\n185\t    api_key: str | None = None,\n186\t) -> SandboxContext:\n187\t    local = mode == \"local\"\n188\t    return SandboxContext(\n189\t        image=normalize_sandbox_image(image),\n190\t        mode=mode,\n191\t        local=local,\n192\t        android_enabled=android_enabled,\n193\t        api_key=api_key if not local else None,\n194\t    )\n195\t"}]},"parent_tool_use_id":null,"session_id":"f7306cb3-f577-448d-82ba-7c9e9ee47b08","uuid":"05e1d212-829c-43ea-ae13-54d8ed07aeeb","timestamp":"2026-05-21T17:31:05.213Z","tool_use_result":{"type":"text","file":{"filePath":"/home/zhiwei/projects/computer-use/scripts/product_analyzer/sandbox_runtime.py","content":"\"\"\"Cua sandbox runtime context for batch workers.\n\nDoes not create sandboxes itself. Describes the contract passed to each Claude\nworker so it can create and drive its own sandbox via the Cua Sandbox SDK.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Literal\n\nSandboxMode = Literal[\"local\", \"cloud\"]\n\nSANDBOX_IMAGES = {\"auto\", \"linux\", \"macos\", \"windows\"}\n\n# Local Linux desktop sandbox (XFCE). See Cua docs \"Linux on Docker\".\nLINUX_CONTAINER_IMAGE = \"trycua/cua-xfce:latest\"\nLINUX_DOCKER_PLATFORM = \"linux/amd64\"\n\n# Host-side Cua SDK requires Python 3.12/3.13 (see README conda setup).\nRECOMMENDED_CONDA_ENV = \"computer-use-py312\"\nPYTHON_VERSION_MIN = \"3.12\"\nPYTHON_VERSION_MAX_EXCLUSIVE = \"3.14\"\n\n_NO_PROXY_HOSTS = \"127.0.0.1,localhost\"\n\n\n@dataclass(frozen=True)\nclass SandboxContext:\n    image: str\n    mode: SandboxMode\n    local: bool\n    android_enabled: bool = True\n    api_key: str | None = None\n\n    @property\n    def runtime(self) -> str:\n        return \"sandbox-local\" if self.local else \"sandbox-cloud\"\n\n    def env(self) -> dict[str, str]:\n        out: dict[str, str] = {\n            \"ANALYZER_RUNTIME\": self.runtime,\n            \"ANALYZER_SANDBOX_IMAGE\": self.image,\n            \"ANALYZER_SANDBOX_LOCAL\": \"1\" if self.local else \"0\",\n            \"ANALYZER_SANDBOX_MODE\": self.mode,\n            \"ANALYZER_ANDROID_ENABLED\": \"1\" if self.android_enabled else \"0\",\n        }\n        out[\"ANALYZER_PYTHON_VERSION_MIN\"] = PYTHON_VERSION_MIN\n        out[\"ANALYZER_PYTHON_VERSION_MAX\"] = PYTHON_VERSION_MAX_EXCLUSIVE\n        out[\"ANALYZER_CONDA_ENV\"] = RECOMMENDED_CONDA_ENV\n        if self.local:\n            out.update(_local_no_proxy_env())\n            out[\"ANALYZER_LINUX_CONTAINER_IMAGE\"] = LINUX_CONTAINER_IMAGE\n            out[\"ANALYZER_LINUX_DOCKER_PLATFORM\"] = LINUX_DOCKER_PLATFORM\n        elif self.api_key:\n            out[\"CUA_API_KEY\"] = self.api_key\n        return out\n\n\ndef _local_no_proxy_env() -> dict[str, str]:\n    \"\"\"Bypass system HTTP proxies for localhost Docker port probes (httpx).\"\"\"\n    merged = _NO_PROXY_HOSTS\n    for key in (\"NO_PROXY\", \"no_proxy\"):\n        existing = os.environ.get(key, \"\").strip()\n        if existing:\n            merged = f\"{merged},{existing}\"\n    return {\"NO_PROXY\": merged, \"no_proxy\": merged}\n\n\ndef normalize_sandbox_image(image: str | None) -> str:\n    value = (image or \"auto\").strip().lower()\n    if value not in SANDBOX_IMAGES:\n        choices = \", \".join(sorted(SANDBOX_IMAGES))\n        raise ValueError(f\"unsupported sandbox image: {image!r}; choose one of {choices}\")\n    return value\n\n\ndef resolve_api_key(cli_key: str | None) -> str | None:\n    if cli_key and cli_key.strip():\n        return cli_key.strip()\n    env_key = os.environ.get(\"CUA_API_KEY\", \"\").strip()\n    return env_key or None\n\n\ndef resolve_sandbox_mode(\n    *,\n    cli_sandbox: str | None,\n    interactive: bool,\n) -> SandboxMode:\n    \"\"\"Pick local vs cloud sandbox for batch mode.\n\n    Default is **local**. Cloud is used only when explicitly requested.\n\n    Priority:\n    1. ``--sandbox cloud`` → cloud (caller must ensure API key)\n    2. ``--sandbox local`` or unset → local (``CUA_API_KEY`` in env is ignored)\n    3. Interactive menu: default local; choose ``2`` for cloud\n    \"\"\"\n    if cli_sandbox == \"cloud\":\n        return \"cloud\"\n    if cli_sandbox == \"local\":\n        return \"local\"\n    if interactive:\n        return _prompt_sandbox_mode()\n    return \"local\"\n\n\ndef _prompt_sandbox_mode() -> SandboxMode:\n    from .ui import prompt_str\n\n    choice = prompt_str(\n        \"Sandbox 运行环境 [1=本地 Docker/Lume(默认), 2=云端 Cua Cloud]: \",\n        validate=lambda s: s in (\"\", \"1\", \"2\"),\n        allow_empty=True,\n    )\n    return \"cloud\" if choice == \"2\" else \"local\"\n\n\ndef linux_container_image():\n    \"\"\"Cua SDK Image for local Linux Docker desktop (XFCE).\"\"\"\n    from dataclasses import replace\n\n    from cua import Image\n\n    return replace(\n        Image.linux(kind=\"container\"),\n        _registry=LINUX_CONTAINER_IMAGE,\n    )\n\n\ndef linux_docker_runtime(*, ephemeral: bool = True):\n    \"\"\"DockerRuntime with linux/amd64 platform (needed on Apple Silicon hosts).\"\"\"\n    from cua_sandbox.runtime.docker import DockerRuntime\n\n    return DockerRuntime(ephemeral=ephemeral, platform=LINUX_DOCKER_PLATFORM)\n\n\ndef apply_no_proxy_env(env: dict[str, str] | None = None) -> dict[str, str]:\n    \"\"\"Merge localhost NO_PROXY into *env* (or os.environ copy).\"\"\"\n    import os\n\n    out = dict(env if env is not None else os.environ)\n    out.update(_local_no_proxy_env())\n    return out\n\n\ndef write_cloud_mcp_config(\n    out_dir: Path,\n    *,\n    api_key: str,\n    sandbox_name: str = \"\",\n) -> Path:\n    \"\"\"Write per-worker MCP config for ``cua serve-mcp`` (cloud batch).\"\"\"\n    import json\n\n    out_dir.mkdir(parents=True, exist_ok=True)\n    path = out_dir / \".mcp.json\"\n    env_block: dict[str, str] = {\"CUA_API_KEY\": api_key}\n    if sandbox_name:\n        env_block[\"CUA_SANDBOX\"] = sandbox_name\n    payload = {\n        \"mcpServers\": {\n            \"cua\": {\n                \"command\": \"cua\",\n                \"args\": [\n                    \"serve-mcp\",\n                    \"--permissions\",\n                    \"computer:all,sandbox:all\",\n                ],\n                \"env\": env_block,\n            }\n        }\n    }\n    path.write_text(json.dumps(payload, indent=2) + \"\\n\", encoding=\"utf-8\")\n    return path\n\n\ndef build_sandbox_context(\n    image: str | None,\n    *,\n    mode: SandboxMode,\n    android_enabled: bool = True,\n    api_key: str | None = None,\n) -> SandboxContext:\n    local = mode == \"local\"\n    return SandboxContext(\n        image=normalize_sandbox_image(image),\n        mode=mode,\n        local=local,\n        android_enabled=android_enabled,\n        api_key=api_key if not local else None,\n    )\n","numLines":195,"startLine":1,"totalLines":195}}}
