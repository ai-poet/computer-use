{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_g6ZOvgzreXfbcelNNgzPv3UK","type":"tool_result","content":"1\t\"\"\"Thin CLI bridge: step-by-step Cua sandbox control for batch workers.\n2\t\n3\tDoes not import claude_driver (keeps dependency graph acyclic).\n4\t\"\"\"\n5\t\n6\tfrom __future__ import annotations\n7\t\n8\timport argparse\n9\timport asyncio\n10\timport json\n11\timport os\n12\timport re\n13\timport atexit\n14\timport shutil\n15\timport signal\n16\timport subprocess\n17\timport sys\n18\timport threading\n19\timport urllib.request\n20\tfrom pathlib import Path\n21\tfrom typing import Any\n22\t\n23\tfrom .config import REPORTS_DIR\n24\tfrom .sandbox_runtime import (\n25\t    LINUX_CONTAINER_IMAGE,\n26\t    LINUX_DOCKER_PLATFORM,\n27\t    apply_no_proxy_env,\n28\t    linux_container_image,\n29\t    linux_docker_runtime,\n30\t)\n31\tfrom .tasks import read_metadata, update_metadata\n32\t\n33\tSANDBOX_JSON = \"sandbox.json\"\n34\tLAST_SHELL_JSON = \".sandbox_ctl_last_shell.json\"\n35\t_MIN_SCREENSHOT_BYTES = 1000\n36\tANALYZER_SANDBOX_PREFIX = \"analyzer-\"\n37\t\n38\t_cleanup_lock = threading.Lock()\n39\t_cleanup_done = False\n40\t_batch_exit_hooks_installed = False\n41\t_prev_sigint_handler: Any = None\n42\t_prev_sigterm_handler: Any = None\n43\t\n44\t\n45\tdef _emit(payload: dict, *, file: Path | None = None) -> None:\n46\t    \"\"\"Print one JSON line to stdout (always flushed) and optionally persist.\"\"\"\n47\t    line = json.dumps(payload, ensure_ascii=False) + \"\\n\"\n48\t    sys.stdout.write(line)\n49\t    sys.stdout.flush()\n50\t    if file is not None:\n51\t        file.parent.mkdir(parents=True, exist_ok=True)\n52\t        file.write_text(line, encoding=\"utf-8\")\n53\t\n54\t\n55\tdef sandbox_json_path(out_dir: Path) -> Path:\n56\t    return out_dir.resolve() / SANDBOX_JSON\n57\t\n58\t\n59\tdef load_sandbox_info(out_dir: Path) -> dict[str, Any]:\n60\t    path = sandbox_json_path(out_dir)\n61\t    if not path.is_file():\n62\t        raise FileNotFoundError(f\"{SANDBOX_JSON} not found under {out_dir}; run bootstrap first\")\n63\t    return json.loads(path.read_text(encoding=\"utf-8\"))\n64\t\n65\t\n66\tdef write_sandbox_info(out_dir: Path, info: dict[str, Any]) -> Path:\n67\t    path = sandbox_json_path(out_dir)\n68\t    out_dir.mkdir(parents=True, exist_ok=True)\n69\t    path.write_text(json.dumps(info, indent=2, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n70\t    return path\n71\t\n72\t\n73\tdef _derive_sandbox_name(out_dir: Path) -> str:\n74\t    base = out_dir.resolve().name\n75\t    safe = re.sub(r\"[^a-zA-Z0-9._-]+\", \"-\", base).strip(\"-\").lower()\n76\t    safe = safe[:48] or \"task\"\n77\t    return f\"analyzer-{safe}\"\n78\t\n79\t\n80\tdef _api_url_from_sb(sb: Any) -> str:\n81\t    rt = getattr(sb, \"_runtime_info\", None)\n82\t    if rt and getattr(rt, \"api_port\", None):\n83\t        host = getattr(rt, \"host\", None) or \"127.0.0.1\"\n84\t        return f\"http://{host}:{rt.api_port}\"\n85\t    raise RuntimeError(\"sandbox has no api_port in runtime_info\")\n86\t\n87\t\n88\tdef _merge_metadata_sandbox(out_dir: Path, name: str, api_url: str, local: bool) -> None:\n89\t    meta = read_metadata(out_dir)\n90\t    if not meta:\n91\t        return\n92\t    sandbox = dict(meta.get(\"sandbox\") or {})\n93\t    sandbox[\"name\"] = name\n94\t    sandbox[\"api_url\"] = api_url\n95\t    sandbox[\"local\"] = local\n96\t    update_metadata(out_dir, sandbox=sandbox)\n97\t\n98\t\n99\tdef _connect_from_info(info: dict[str, Any]) -> Any:\n100\t    from cua import Sandbox\n101\t\n102\t    name = info[\"name\"]\n103\t    local = bool(info.get(\"local\", True))\n104\t    api_key = os.environ.get(\"CUA_API_KEY\") if not local else None\n105\t    if info.get(\"api_url\") and not local:\n106\t        return Sandbox.connect(\n107\t            name,\n108\t            local=False,\n109\t            api_key=api_key,\n110\t            http_url=info[\"api_url\"],\n111\t        )\n112\t    return Sandbox.connect(name, local=local, api_key=api_key)\n113\t\n114\t\n115\t# cua-xfce Linux image ships Firefox only (no Chromium). Probe DISPLAY from /tmp/.X11-unix\n116\t# (often :1, not :0) before launching.\n117\t_LINUX_FIREFOX_LAUNCH_SHELL = (\n118\t    'D=\"${DISPLAY:-}\"; '\n119\t    'if [ -z \"$D\" ] || [ ! -S \"/tmp/.X11-unix/X${D#:}\" ] 2>/dev/null; then '\n120\t    \"for x in /tmp/.X11-unix/X*; do \"\n121\t    '[ -S \"$x\" ] || continue; '\n122\t    'D=\":${x##*/X}\"; break; '\n123\t    \"done; \"\n124\t    \"fi; \"\n125\t    'export DISPLAY=\"${D:-:1}\"; '\n126\t    \"if pgrep -x firefox >/dev/null 2>&1; then exit 0; fi; \"\n127\t    \"firefox --new-window about:blank >/dev/null 2>&1 & \"\n128\t    \"sleep 3; \"\n129\t    \"pgrep -x firefox >/dev/null\"\n130\t)\n131\t\n132\t\n133\tasync def _launch_browser_once(out_dir: Path) -> int:\n134\t    \"\"\"One-time shell helper to start Firefox; navigation after this is mouse/keyboard.\"\"\"\n135\t    return await cmd_step_shell(out_dir, _LINUX_FIREFOX_LAUNCH_SHELL)\n136\t\n137\t\n138\tasync def cmd_step_open_url(out_dir: Path, url: str, *, launch: bool = True) -> int:\n139\t    \"\"\"Open URL in sandbox browser using keyboard focus + type (mouse-first navigation).\"\"\"\n140\t    if launch:\n141\t        await _launch_browser_once(out_dir)\n142\t        await asyncio.sleep(1.0)\n143\t    # Focus omnibox then type URL (Firefox on cua-xfce XFCE).\n144\t    await cmd_step_key(out_dir, \"ctrl+l\")\n145\t    await asyncio.sleep(0.4)\n146\t    await cmd_step_key(out_dir, \"ctrl+a\")\n147\t    await asyncio.sleep(0.1)\n148\t    await cmd_step_type(out_dir, url)\n149\t    await asyncio.sleep(0.2)\n150\t    await cmd_step_key(out_dir, \"enter\")\n151\t    await asyncio.sleep(2.0)\n152\t    _emit({\"ok\": True, \"action\": \"open-url\", \"url\": url})\n153\t    return 0\n154\t\n155\t\n156\tasync def cmd_bootstrap(\n157\t    out_dir: Path,\n158\t    *,\n159\t    open_browser: bool,\n160\t    url: str | None = None,\n161\t) -> int:\n162\t    apply_no_proxy_env()\n163\t    out_dir = out_dir.resolve()\n164\t    if sandbox_json_path(out_dir).is_file():\n165\t        print(f\"error: {SANDBOX_JSON} already exists; run teardown first\", file=sys.stderr)\n166\t        return 1\n167\t\n168\t    runtime = os.environ.get(\"ANALYZER_RUNTIME\", \"sandbox-local\")\n169\t    image_key = os.environ.get(\"ANALYZER_SANDBOX_IMAGE\", \"linux\").lower()\n170\t    local = runtime != \"sandbox-cloud\"\n171\t    name = _derive_sandbox_name(out_dir)\n172\t\n173\t    from cua import Sandbox\n174\t\n175\t    if local:\n176\t        if image_key not in (\"auto\", \"linux\"):\n177\t            print(\n178\t                f\"warning: sandbox_ctl bootstrap only implements linux container; \"\n179\t                f\"got image={image_key!r}\",\n180\t                file=sys.stderr,\n181\t            )\n182\t        sb = await Sandbox.create(\n183\t            linux_container_image(),\n184\t            name=name,\n185\t            local=True,\n186\t            runtime=linux_docker_runtime(ephemeral=False),\n187\t        )\n188\t        provider = \"docker\"\n189\t        image = os.environ.get(\"ANALYZER_LINUX_CONTAINER_IMAGE\", LINUX_CONTAINER_IMAGE)\n190\t        platform = os.environ.get(\"ANALYZER_LINUX_DOCKER_PLATFORM\", LINUX_DOCKER_PLATFORM)\n191\t    else:\n192\t        api_key = os.environ.get(\"CUA_API_KEY\", \"\").strip()\n193\t        if not api_key:\n194\t            print(\"error: CUA_API_KEY required for cloud bootstrap\", file=sys.stderr)\n195\t            return 1\n196\t        from cua import Image\n197\t\n198\t        sb = await Sandbox.create(Image.linux(), name=name, local=False, api_key=api_key)\n199\t        provider = \"cloud\"\n200\t        image = \"linux\"\n201\t        platform = None\n202\t\n203\t    api_url = _api_url_from_sb(sb)\n204\t    info = {\n205\t        \"name\": sb.name or name,\n206\t        \"provider\": provider,\n207\t        \"api_url\": api_url,\n208\t        \"image\": image,\n209\t        \"platform\": platform,\n210\t        \"local\": local,\n211\t    }\n212\t    write_sandbox_info(out_dir, info)\n213\t    _merge_metadata_sandbox(out_dir, info[\"name\"], api_url, local)\n214\t    await sb.disconnect()\n215\t\n216\t    _emit({\"ok\": True, \"sandbox\": info})\n217\t\n218\t    if open_browser:\n219\t        target = (url or os.environ.get(\"ANALYZER_PRODUCT_URL\") or \"\").strip()\n220\t        if target:\n221\t            return await cmd_step_open_url(out_dir, target, launch=True)\n222\t        return await _launch_browser_once(out_dir)\n223\t    return 0\n224\t\n225\t\n226\tasync def cmd_teardown(out_dir: Path) -> int:\n227\t    apply_no_proxy_env()\n228\t    out_dir = out_dir.resolve()\n229\t    path = sandbox_json_path(out_dir)\n230\t    if not path.is_file():\n231\t        _emit({\"ok\": True, \"skipped\": \"no sandbox.json\"})\n232\t        return 0\n233\t    info = load_sandbox_info(out_dir)\n234\t    from cua import Sandbox\n235\t\n236\t    try:\n237\t        await Sandbox.delete(\n238\t            info[\"name\"],\n239\t            local=bool(info.get(\"local\", True)),\n240\t            api_key=os.environ.get(\"CUA_API_KEY\") if not info.get(\"local\", True) else None,\n241\t        )\n242\t    except Exception as exc:\n243\t        print(f\"warning: Sandbox.delete: {exc}\", file=sys.stderr)\n244\t    path.unlink(missing_ok=True)\n245\t    _emit({\"ok\": True, \"deleted\": info[\"name\"]})\n246\t    return 0\n247\t\n248\t\n249\tdef cmd_status(out_dir: Path) -> int:\n250\t    out_dir = out_dir.resolve()\n251\t    path = sandbox_json_path(out_dir)\n252\t    if not path.is_file():\n253\t        _emit({\"ok\": False, \"error\": f\"no {SANDBOX_JSON} in {out_dir}\"})\n254\t        return 1\n255\t    info = load_sandbox_info(out_dir)\n256\t    _emit({\"ok\": True, \"sandbox\": info})\n257\t    print(json.dumps(info, indent=2, ensure_ascii=False))\n258\t    api_url = info.get(\"api_url\", \"\")\n259\t    if api_url:\n260\t        try:\n261\t            req = urllib.request.Request(f\"{api_url.rstrip('/')}/status\", method=\"GET\")\n262\t            with urllib.request.urlopen(req, timeout=5) as resp:\n263\t                body = resp.read().decode(\"utf-8\", errors=\"replace\")[:500]\n264\t            print(f\"GET {api_url}/status -> {resp.status} {body[:200]}\")\n265\t        except Exception as exc:\n266\t            print(f\"GET {api_url}/status failed: {exc}\", file=sys.stderr)\n267\t            return 1\n268\t    return 0\n269\t\n270\t\n271\tasync def cmd_step_screenshot(out_dir: Path, out_path: Path) -> int:\n272\t    apply_no_proxy_env()\n273\t    info = load_sandbox_info(out_dir)\n274\t    out_path = out_path if out_path.is_absolute() else (out_dir.resolve() / out_path)\n275\t    out_path.parent.mkdir(parents=True, exist_ok=True)\n276\t\n277\t    async with _connect_from_info(info) as sb:\n278\t        png = await sb.screenshot()\n279\t\n280\t    out_path.write_bytes(png)\n281\t    ok = len(png) >= _MIN_SCREENSHOT_BYTES\n282\t    _emit({\"ok\": ok, \"path\": str(out_path), \"bytes\": len(png)})\n283\t    return 0 if ok else 1\n284\t\n285\t\n286\tdef _resolve_shell_command(shell_cmd: str | None, shell_argv: list[str]) -> str | None:\n287\t    if shell_cmd and shell_cmd.strip():\n288\t        return shell_cmd.strip()\n289\t    parts = list(shell_argv)\n290\t    if parts and parts[0] == \"--\":\n291\t        parts = parts[1:]\n292\t    # REMAINDER may capture ``-c cmd ...`` when -c follows positional out_dir.\n293\t    if parts and parts[0] in (\"-c\", \"--cmd\"):\n294\t        parts = parts[1:]\n295\t    if not parts:\n296\t        return None\n297\t    return \" \".join(parts)\n298\t\n299\t\n300\tasync def cmd_step_shell(out_dir: Path, command: str) -> int:\n301\t    apply_no_proxy_env()\n302\t    out_dir = out_dir.resolve()\n303\t    artifact = out_dir / LAST_SHELL_JSON\n304\t    try:\n305\t        info = load_sandbox_info(out_dir)\n306\t        async with _connect_from_info(info) as sb:\n307\t            result = await sb.shell.run(command)\n308\t    except Exception as exc:\n309\t        payload = {\n310\t            \"ok\": False,\n311\t            \"returncode\": 1,\n312\t            \"stdout\": \"\",\n313\t            \"stderr\": str(exc),\n314\t            \"command\": command,\n315\t            \"artifact\": str(artifact),\n316\t            \"error\": f\"{type(exc).__name__}: {exc}\",\n317\t        }\n318\t        _emit(payload, file=artifact)\n319\t        print(f\"sandbox_ctl shell: {payload['error']}\", file=sys.stderr, flush=True)\n320\t        return 1\n321\t    stdout = result.stdout or \"\"\n322\t    stderr = result.stderr or \"\"\n323\t    payload = {\n324\t        \"ok\": result.success,\n325\t        \"returncode\": result.returncode,\n326\t        \"stdout\": stdout,\n327\t        \"stderr\": stderr,\n328\t        \"command\": command,\n329\t        \"artifact\": str(artifact),\n330\t    }\n331\t    _emit(payload, file=artifact)\n332\t    # Human-readable tail on stderr so Bash-tool users still see something if stdout is sparse.\n333\t    print(\n334\t        f\"sandbox_ctl shell: ok={result.success} rc={result.returncode} \"\n335\t        f\"stdout_bytes={len(stdout)} stderr_bytes={len(stderr)}\",\n336\t        file=sys.stderr,\n337\t        flush=True,\n338\t    )\n339\t    if stdout:\n340\t        sys.stderr.write(stdout if stdout.endswith(\"\\n\") else stdout + \"\\n\")\n341\t        sys.stderr.flush()\n342\t    if stderr:\n343\t        sys.stderr.write(stderr if stderr.endswith(\"\\n\") else stderr + \"\\n\")\n344\t        sys.stderr.flush()\n345\t    return 0 if result.success else 1\n346\t\n347\t\n348\tasync def cmd_step_click(out_dir: Path, x: int, y: int, *, button: str) -> int:\n349\t    apply_no_proxy_env()\n350\t    info = load_sandbox_info(out_dir)\n351\t    async with _connect_from_info(info) as sb:\n352\t        if button == \"right\":\n353\t            await sb.mouse.right_click(x, y)\n354\t        elif button == \"double\":\n355\t            await sb.mouse.double_click(x, y)\n356\t        else:\n357\t            await sb.mouse.click(x, y)\n358\t    _emit({\"ok\": True, \"action\": button, \"x\": x, \"y\": y})\n359\t    return 0\n360\t\n361\t\n362\tasync def cmd_step_move(out_dir: Path, x: int, y: int) -> int:\n363\t    apply_no_proxy_env()\n364\t    info = load_sandbox_info(out_dir)\n365\t    async with _connect_from_info(info) as sb:\n366\t        await sb.mouse.move(x, y)\n367\t    _emit({\"ok\": True, \"x\": x, \"y\": y})\n368\t    return 0\n369\t\n370\t\n371\tasync def cmd_step_type(out_dir: Path, text: str) -> int:\n372\t    apply_no_proxy_env()\n373\t    info = load_sandbox_info(out_dir)\n374\t    async with _connect_from_info(info) as sb:\n375\t        await sb.keyboard.type(text)\n376\t    _emit({\"ok\": True, \"chars\": len(text)})\n377\t    return 0\n378\t\n379\t\n380\t# computer-server / cua_auto hotkey() only accepts lowercase names (see cua_auto.keyboard._SPECIAL).\n381\t# Do not emit pynput-style PascalCase (Return, Escape) — HTTP transport rejects them.\n382\t_KEY_ALIASES: dict[str, str] = {\n383\t    \"escape\": \"escape\",\n384\t    \"esc\": \"escape\",\n385\t    \"enter\": \"enter\",\n386\t    \"return\": \"enter\",\n387\t    \"control\": \"ctrl\",\n388\t    \"command\": \"meta\",\n389\t    \"cmd\": \"meta\",\n390\t    \"win\": \"meta\",\n391\t    \"super\": \"meta\",\n392\t    \"option\": \"alt\",\n393\t}\n394\t\n395\t\n396\tdef _normalize_keys(keys: str) -> list[str]:\n397\t    parts = [k.strip() for k in keys.split(\"+\") if k.strip()]\n398\t    if not parts:\n399\t        return []\n400\t    out: list[str] = []\n401\t    for p in parts:\n402\t        lk = p.lower()\n403\t        out.append(_KEY_ALIASES.get(lk, lk))\n404\t    return out\n405\t\n406\t\n407\tasync def cmd_step_key(out_dir: Path, keys: str) -> int:\n408\t    apply_no_proxy_env()\n409\t    info = load_sandbox_info(out_dir)\n410\t    key_list = _normalize_keys(keys)\n411\t    async with _connect_from_info(info) as sb:\n412\t        await sb.keyboard.keypress(key_list)\n413\t    _emit({\"ok\": True, \"keys\": keys})\n414\t    return 0\n415\t\n416\t\n417\tasync def cmd_step_scroll(\n418\t    out_dir: Path, x: int, y: int, *, scroll_x: int = 0, scroll_y: int = 3\n419\t) -> int:\n420\t    apply_no_proxy_env()\n421\t    info = load_sandbox_info(out_dir)\n422\t    async with _connect_from_info(info) as sb:\n423\t        await sb.mouse.scroll(x, y, scroll_x, scroll_y)\n424\t    _emit({\"ok\": True, \"x\": x, \"y\": y, \"scroll_x\": scroll_x, \"scroll_y\": scroll_y})\n425\t    return 0\n426\t\n427\t\n428\tasync def cmd_step_screen_size(out_dir: Path) -> int:\n429\t    apply_no_proxy_env()\n430\t    info = load_sandbox_info(out_dir)\n431\t    async with _connect_from_info(info) as sb:\n432\t        width, height = await sb.screen.size()\n433\t    _emit({\"ok\": True, \"width\": width, \"height\": height})\n434\t    return 0\n435\t\n436\t\n437\tdef _batch_cleanup_disabled() -> bool:\n438\t    return os.environ.get(\"ANALYZER_BATCH_NO_CLEANUP\", \"\").strip().lower() in (\n439\t        \"1\",\n440\t        \"true\",\n441\t        \"yes\",\n442\t        \"on\",\n443\t    )\n444\t\n445\t\n446\tdef _collect_sandbox_names_from_reports() -> set[str]:\n447\t    names: set[str] = set()\n448\t    if not REPORTS_DIR.is_dir():\n449\t        return names\n450\t    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n451\t        try:\n452\t            data = json.loads(path.read_text(encoding=\"utf-8\"))\n453\t        except (json.JSONDecodeError, OSError):\n454\t            continue\n455\t        name = (data.get(\"name\") or \"\").strip()\n456\t        if name:\n457\t            names.add(name)\n458\t    return names\n459\t\n460\t\n461\tdef _docker_cua_sandbox_container_names() -> set[str]:\n462\t    \"\"\"Container names with Cua sandbox label (running or stopped).\"\"\"\n463\t    if not shutil.which(\"docker\"):\n464\t        return set()\n465\t    proc = subprocess.run(\n466\t        [\n467\t            \"docker\",\n468\t            \"ps\",\n469\t            \"-aq\",\n470\t            \"--filter\",\n471\t            \"label=cua.sandbox=true\",\n472\t            \"--format\",\n473\t            \"{{.Names}}\",\n474\t        ],\n475\t        capture_output=True,\n476\t        text=True,\n477\t        timeout=60,\n478\t    )\n479\t    if proc.returncode != 0:\n480\t        return set()\n481\t    return {line.strip() for line in proc.stdout.splitlines() if line.strip()}\n482\t\n483\t\n484\tdef _docker_force_rm(names: set[str]) -> list[str]:\n485\t    removed: list[str] = []\n486\t    if not names or not shutil.which(\"docker\"):\n487\t        return removed\n488\t    for name in sorted(names):\n489\t        proc = subprocess.run(\n490\t            [\"docker\", \"rm\", \"-f\", name],\n491\t            capture_output=True,\n492\t            text=True,\n493\t            timeout=30,\n494\t        )\n495\t        if proc.returncode == 0:\n496\t            removed.append(name)\n497\t    return removed\n498\t\n499\t\n500\tdef _unlink_sandbox_json_for_name(name: str) -> None:\n501\t    if not REPORTS_DIR.is_dir():\n502\t        return\n503\t    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n504\t        try:\n505\t            data = json.loads(path.read_text(encoding=\"utf-8\"))\n506\t        except (json.JSONDecodeError, OSError):\n507\t            continue\n508\t        if data.get(\"name\") == name:\n509\t            path.unlink(missing_ok=True)\n510\t\n511\t\n512\tasync def cmd_cleanup_all(*, prefix: str = ANALYZER_SANDBOX_PREFIX) -> int:\n513\t    \"\"\"Stop/remove local Cua Docker sandboxes (batch exit / manual cleanup).\"\"\"\n514\t    apply_no_proxy_env()\n515\t    from cua import Sandbox\n516\t\n517\t    docker_names = _docker_cua_sandbox_container_names()\n518\t    targets: set[str] = set(docker_names)\n519\t    targets |= _collect_sandbox_names_from_reports()\n520\t\n521\t    try:\n522\t        listed = await Sandbox.list(local=True)\n523\t        for info in listed:\n524\t            if info.name:\n525\t                targets.add(info.name)\n526\t    except Exception as exc:\n527\t        print(f\"warning: Sandbox.list: {exc}\", file=sys.stderr)\n528\t\n529\t    to_delete = set(docker_names)\n530\t    to_delete |= {n for n in targets if n.startswith(prefix)}\n531\t\n532\t    deleted: list[str] = []\n533\t    errors: list[str] = []\n534\t    for name in sorted(to_delete):\n535\t        try:\n536\t            await Sandbox.delete(name, local=True)\n537\t            deleted.append(name)\n538\t            _unlink_sandbox_json_for_name(name)\n539\t        except Exception as exc:\n540\t            errors.append(f\"{name}: {exc}\")\n541\t\n542\t    docker_removed = _docker_force_rm(to_delete - set(deleted))\n543\t    deleted.extend(n for n in docker_removed if n not in deleted)\n544\t\n545\t    leftover = _docker_cua_sandbox_container_names() - set(deleted)\n546\t    if leftover:\n547\t        docker_removed2 = _docker_force_rm(leftover)\n548\t        deleted.extend(n for n in docker_removed2 if n not in deleted)\n549\t\n550\t    payload = {\n551\t        \"ok\": not errors,\n552\t        \"deleted\": deleted,\n553\t        \"errors\": errors,\n554\t        \"count\": len(deleted),\n555\t    }\n556\t    _emit(payload)\n557\t    if deleted:\n558\t        print(\n559\t            f\"sandbox_ctl cleanup: removed {len(deleted)} container(s)\",\n560\t            file=sys.stderr,\n561\t            flush=True,\n562\t        )\n563\t    for err in errors:\n564\t        print(f\"sandbox_ctl cleanup: {err}\", file=sys.stderr)\n565\t    return 0 if not errors else 1\n566\t\n567\t\n568\tdef reset_batch_cleanup_gate() -> None:\n569\t    \"\"\"Allow a new batch run to run exit cleanup again.\"\"\"\n570\t    global _cleanup_done\n571\t    with _cleanup_lock:\n572\t        _cleanup_done = False\n573\t\n574\t\n575\tdef docker_cleanup_sync_quick() -> int:\n576\t    \"\"\"SIGINT-safe: ``docker rm -f`` Cua containers without asyncio (for signal handler).\"\"\"\n577\t    if _batch_cleanup_disabled():\n578\t        return 0\n579\t    names = _docker_cua_sandbox_container_names()\n580\t    names |= {\n581\t        n\n582\t        for n in _collect_sandbox_names_from_reports()\n583\t        if n.startswith(ANALYZER_SANDBOX_PREFIX)\n584\t    }\n585\t    removed = _docker_force_rm(names)\n586\t    if removed:\n587\t        print(\n588\t            f\"sandbox_ctl: 已停止 {len(removed)} 个 Docker 沙盒容器\",\n589\t            file=sys.stderr,\n590\t            flush=True,\n591\t        )\n592\t    return len(removed)\n593\t\n594\t\n595\tdef _batch_signal_handler(signum: int, frame: Any) -> None:\n596\t    \"\"\"First Ctrl+C: quick docker stop; then raise KeyboardInterrupt for ``finally``.\"\"\"\n597\t    try:\n598\t        docker_cleanup_sync_quick()\n599\t    except Exception:\n600\t        pass\n601\t    raise KeyboardInterrupt\n602\t\n603\t\n604\tdef install_batch_exit_hooks(*, local: bool) -> None:\n605\t    \"\"\"Register SIGINT/SIGTERM + atexit so forced exit still cleans Docker sandboxes.\"\"\"\n606\t    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n607\t    if not local or _batch_cleanup_disabled() or _batch_exit_hooks_installed:\n608\t        return\n609\t    _prev_sigint_handler = signal.getsignal(signal.SIGINT)\n610\t    _prev_sigterm_handler = signal.getsignal(signal.SIGTERM)\n611\t    signal.signal(signal.SIGINT, _batch_signal_handler)\n612\t    signal.signal(signal.SIGTERM, _batch_signal_handler)\n613\t    atexit.register(cleanup_all_local_sandboxes)\n614\t    _batch_exit_hooks_installed = True\n615\t\n616\t\n617\tdef uninstall_batch_exit_hooks() -> None:\n618\t    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n619\t    if not _batch_exit_hooks_installed:\n620\t        return\n621\t    if _prev_sigint_handler is not None:\n622\t        signal.signal(signal.SIGINT, _prev_sigint_handler)\n623\t    if _prev_sigterm_handler is not None:\n624\t        signal.signal(signal.SIGTERM, _prev_sigterm_handler)\n625\t    _prev_sigint_handler = None\n626\t    _prev_sigterm_handler = None\n627\t    _batch_exit_hooks_installed = False\n628\t\n629\t\n630\tdef cleanup_all_local_sandboxes(*, force: bool = False) -> None:\n631\t    \"\"\"Idempotent batch-exit hook: tear down Cua Docker sandboxes. Never raises.\"\"\"\n632\t    global _cleanup_done\n633\t    if _batch_cleanup_disabled():\n634\t        return\n635\t    with _cleanup_lock:\n636\t        if _cleanup_done and not force:\n637\t            return\n638\t        _cleanup_done = True\n639\t    try:\n640\t        asyncio.run(cmd_cleanup_all())\n641\t    except Exception as exc:\n642\t        print(f\"sandbox_ctl cleanup: {exc}\", file=sys.stderr, flush=True)\n643\t        try:\n644\t            docker_cleanup_sync_quick()\n645\t        except Exception:\n646\t            pass\n647\t\n648\t\n649\tdef teardown_out_dir(out_dir: Path) -> None:\n650\t    \"\"\"Best-effort teardown for batch finally hook; never raises.\"\"\"\n651\t    try:\n652\t        asyncio.run(cmd_teardown(out_dir))\n653\t    except Exception as exc:\n654\t        print(f\"sandbox_ctl teardown: {exc}\", file=sys.stderr)\n655\t\n656\t\n657\tdef _build_parser() -> argparse.ArgumentParser:\n658\t    p = argparse.ArgumentParser(description=\"Step-by-step Cua sandbox control for product-analyzer batch\")\n659\t    sub = p.add_subparsers(dest=\"command\", required=True)\n660\t\n661\t    boot = sub.add_parser(\"bootstrap\", help=\"Create named sandbox and write sandbox.json\")\n662\t    boot.add_argument(\"out_dir\", type=Path)\n663\t    boot.add_argument(\n664\t        \"--open-browser\",\n665\t        action=\"store_true\",\n666\t        help=\"After bootstrap, launch Firefox (cua-xfce; use with --url for Ctrl+L navigation)\",\n667\t    )\n668\t    boot.add_argument(\n669\t        \"--url\",\n670\t        default=None,\n671\t        help=\"Product homepage URL (opens via step open-url / Ctrl+L, not wget)\",\n672\t    )\n673\t\n674\t    sub.add_parser(\"teardown\", help=\"Delete sandbox and remove sandbox.json\").add_argument(\n675\t        \"out_dir\", type=Path\n676\t    )\n677\t    sub.add_parser(\n678\t        \"cleanup-all\",\n679\t        help=\"Remove all local Cua Docker sandboxes (analyzer-* + label cua.sandbox=true)\",\n680\t    )\n681\t    sub.add_parser(\"status\", help=\"Print sandbox.json and probe /status\").add_argument(\n682\t        \"out_dir\", type=Path\n683\t    )\n684\t\n685\t    step = sub.add_parser(\"step\", help=\"Single sandbox action\")\n686\t    step_sub = step.add_subparsers(dest=\"step_cmd\", required=True)\n687\t\n688\t    shot = step_sub.add_parser(\"screenshot\", help=\"Save PNG to --out path\")\n689\t    shot.add_argument(\"out_dir\", type=Path)\n690\t    shot.add_argument(\"--out\", type=Path, required=True)\n691\t\n692\t    shell = step_sub.add_parser(\n693\t        \"shell\",\n694\t        help=\"Run one shell command in sandbox (prefer -c)\",\n695\t    )\n696\t    shell.add_argument(\"out_dir\", type=Path)\n697\t    shell.add_argument(\n698\t        \"-c\",\n699\t        \"--cmd\",\n700\t        dest=\"shell_cmd\",\n701\t        metavar=\"CMD\",\n702\t        help=\"Shell command string (required unless legacy args after --)\",\n703\t    )\n704\t    shell.add_argument(\n705\t        \"shell_argv\",\n706\t        nargs=argparse.REMAINDER,\n707\t        metavar=\"[-- CMD ...]\",\n708\t        help=\"Legacy: command tokens after --\",\n709\t    )\n710\t\n711\t    click_p = step_sub.add_parser(\"click\", help=\"Click at x y\")\n712\t    click_p.add_argument(\"out_dir\", type=Path)\n713\t    click_p.add_argument(\"x\", type=int)\n714\t    click_p.add_argument(\"y\", type=int)\n715\t    click_p.add_argument(\"--button\", choices=(\"left\", \"right\", \"double\"), default=\"left\")\n716\t\n717\t    move_p = step_sub.add_parser(\"move\", help=\"Move cursor to x y\")\n718\t    move_p.add_argument(\"out_dir\", type=Path)\n719\t    move_p.add_argument(\"x\", type=int)\n720\t    move_p.add_argument(\"y\", type=int)\n721\t\n722\t    type_p = step_sub.add_parser(\"type\", help=\"Type text\")\n723\t    type_p.add_argument(\"out_dir\", type=Path)\n724\t    type_p.add_argument(\"text\")\n725\t\n726\t    key_p = step_sub.add_parser(\"key\", help=\"Keypress (enter or ctrl+c)\")\n727\t    key_p.add_argument(\"out_dir\", type=Path)\n728\t    key_p.add_argument(\"keys\")\n729\t\n730\t    scroll_p = step_sub.add_parser(\"scroll\", help=\"Scroll at x y\")\n731\t    scroll_p.add_argument(\"out_dir\", type=Path)\n732\t    scroll_p.add_argument(\"x\", type=int)\n733\t    scroll_p.add_argument(\"y\", type=int)\n734\t    scroll_p.add_argument(\"--scroll-x\", type=int, default=0)\n735\t    scroll_p.add_argument(\"--scroll-y\", type=int, default=3)\n736\t\n737\t    step_sub.add_parser(\"screen-size\", help=\"Print sandbox display width x height\").add_argument(\n738\t        \"out_dir\", type=Path\n739\t    )\n740\t\n741\t    open_url = step_sub.add_parser(\n742\t        \"open-url\",\n743\t        help=\"Launch browser (once) and open URL via keyboard (mouse-first)\",\n744\t    )\n745\t    open_url.add_argument(\"out_dir\", type=Path)\n746\t    open_url.add_argument(\"url\")\n747\t    open_url.add_argument(\n748\t        \"--no-launch\",\n749\t        action=\"store_true\",\n750\t        help=\"Skip Firefox launch (browser already running)\",\n751\t    )\n752\t\n753\t    return p\n754\t\n755\t\n756\tdef main(argv: list[str] | None = None) -> int:\n757\t    args = _build_parser().parse_args(argv)\n758\t    if args.command == \"bootstrap\":\n759\t        return asyncio.run(\n760\t            cmd_bootstrap(\n761\t                args.out_dir,\n762\t                open_browser=args.open_browser,\n763\t                url=getattr(args, \"url\", None),\n764\t            )\n765\t        )\n766\t    if args.command == \"teardown\":\n767\t        return asyncio.run(cmd_teardown(args.out_dir))\n768\t    if args.command == \"cleanup-all\":\n769\t        return asyncio.run(cmd_cleanup_all())\n770\t    if args.command == \"status\":\n771\t        return cmd_status(args.out_dir)\n772\t    if args.command == \"step\":\n773\t        if args.step_cmd == \"screenshot\":\n774\t            return asyncio.run(cmd_step_screenshot(args.out_dir, args.out))\n775\t        if args.step_cmd == \"shell\":\n776\t            command = _resolve_shell_command(\n777\t                getattr(args, \"shell_cmd\", None),\n778\t                getattr(args, \"shell_argv\", None) or [],\n779\t            )\n780\t            if not command:\n781\t                print(\n782\t                    \"error: shell requires -c '...' or arguments after --\",\n783\t                    file=sys.stderr,\n784\t                )\n785\t                return 1\n786\t            return asyncio.run(cmd_step_shell(args.out_dir, command))\n787\t        if args.step_cmd == \"click\":\n788\t            return asyncio.run(\n789\t                cmd_step_click(args.out_dir, args.x, args.y, button=args.button)\n790\t            )\n791\t        if args.step_cmd == \"move\":\n792\t            return asyncio.run(cmd_step_move(args.out_dir, args.x, args.y))\n793\t        if args.step_cmd == \"type\":\n794\t            return asyncio.run(cmd_step_type(args.out_dir, args.text))\n795\t        if args.step_cmd == \"key\":\n796\t            return asyncio.run(cmd_step_key(args.out_dir, args.keys))\n797\t        if args.step_cmd == \"scroll\":\n798\t            return asyncio.run(\n799\t                cmd_step_scroll(\n800\t                    args.out_dir,\n801\t                    args.x,\n802\t                    args.y,\n803\t                    scroll_x=args.scroll_x,\n804\t                    scroll_y=args.scroll_y,\n805\t                )\n806\t            )\n807\t        if args.step_cmd == \"screen-size\":\n808\t            return asyncio.run(cmd_step_screen_size(args.out_dir))\n809\t        if args.step_cmd == \"open-url\":\n810\t            return asyncio.run(\n811\t                cmd_step_open_url(\n812\t                    args.out_dir,\n813\t                    args.url,\n814\t                    launch=not args.no_launch,\n815\t                )\n816\t            )\n817\t    return 1\n818\t\n819\t\n820\tif __name__ == \"__main__\":\n821\t    sys.exit(main())\n822\t"}]},"parent_tool_use_id":null,"session_id":"36ea181f-816c-4d44-9503-0b29dcdbf90f","uuid":"8764a515-6a10-4ac1-a8b4-fee1940d3882","timestamp":"2026-05-20T09:55:17.790Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/huzhiwei/Desktop/Projects/computer-use/scripts/product_analyzer/sandbox_ctl.py","content":"\"\"\"Thin CLI bridge: step-by-step Cua sandbox control for batch workers.\n\nDoes not import claude_driver (keeps dependency graph acyclic).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport asyncio\nimport json\nimport os\nimport re\nimport atexit\nimport shutil\nimport signal\nimport subprocess\nimport sys\nimport threading\nimport urllib.request\nfrom pathlib import Path\nfrom typing import Any\n\nfrom .config import REPORTS_DIR\nfrom .sandbox_runtime import (\n    LINUX_CONTAINER_IMAGE,\n    LINUX_DOCKER_PLATFORM,\n    apply_no_proxy_env,\n    linux_container_image,\n    linux_docker_runtime,\n)\nfrom .tasks import read_metadata, update_metadata\n\nSANDBOX_JSON = \"sandbox.json\"\nLAST_SHELL_JSON = \".sandbox_ctl_last_shell.json\"\n_MIN_SCREENSHOT_BYTES = 1000\nANALYZER_SANDBOX_PREFIX = \"analyzer-\"\n\n_cleanup_lock = threading.Lock()\n_cleanup_done = False\n_batch_exit_hooks_installed = False\n_prev_sigint_handler: Any = None\n_prev_sigterm_handler: Any = None\n\n\ndef _emit(payload: dict, *, file: Path | None = None) -> None:\n    \"\"\"Print one JSON line to stdout (always flushed) and optionally persist.\"\"\"\n    line = json.dumps(payload, ensure_ascii=False) + \"\\n\"\n    sys.stdout.write(line)\n    sys.stdout.flush()\n    if file is not None:\n        file.parent.mkdir(parents=True, exist_ok=True)\n        file.write_text(line, encoding=\"utf-8\")\n\n\ndef sandbox_json_path(out_dir: Path) -> Path:\n    return out_dir.resolve() / SANDBOX_JSON\n\n\ndef load_sandbox_info(out_dir: Path) -> dict[str, Any]:\n    path = sandbox_json_path(out_dir)\n    if not path.is_file():\n        raise FileNotFoundError(f\"{SANDBOX_JSON} not found under {out_dir}; run bootstrap first\")\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_sandbox_info(out_dir: Path, info: dict[str, Any]) -> Path:\n    path = sandbox_json_path(out_dir)\n    out_dir.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(info, indent=2, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n    return path\n\n\ndef _derive_sandbox_name(out_dir: Path) -> str:\n    base = out_dir.resolve().name\n    safe = re.sub(r\"[^a-zA-Z0-9._-]+\", \"-\", base).strip(\"-\").lower()\n    safe = safe[:48] or \"task\"\n    return f\"analyzer-{safe}\"\n\n\ndef _api_url_from_sb(sb: Any) -> str:\n    rt = getattr(sb, \"_runtime_info\", None)\n    if rt and getattr(rt, \"api_port\", None):\n        host = getattr(rt, \"host\", None) or \"127.0.0.1\"\n        return f\"http://{host}:{rt.api_port}\"\n    raise RuntimeError(\"sandbox has no api_port in runtime_info\")\n\n\ndef _merge_metadata_sandbox(out_dir: Path, name: str, api_url: str, local: bool) -> None:\n    meta = read_metadata(out_dir)\n    if not meta:\n        return\n    sandbox = dict(meta.get(\"sandbox\") or {})\n    sandbox[\"name\"] = name\n    sandbox[\"api_url\"] = api_url\n    sandbox[\"local\"] = local\n    update_metadata(out_dir, sandbox=sandbox)\n\n\ndef _connect_from_info(info: dict[str, Any]) -> Any:\n    from cua import Sandbox\n\n    name = info[\"name\"]\n    local = bool(info.get(\"local\", True))\n    api_key = os.environ.get(\"CUA_API_KEY\") if not local else None\n    if info.get(\"api_url\") and not local:\n        return Sandbox.connect(\n            name,\n            local=False,\n            api_key=api_key,\n            http_url=info[\"api_url\"],\n        )\n    return Sandbox.connect(name, local=local, api_key=api_key)\n\n\n# cua-xfce Linux image ships Firefox only (no Chromium). Probe DISPLAY from /tmp/.X11-unix\n# (often :1, not :0) before launching.\n_LINUX_FIREFOX_LAUNCH_SHELL = (\n    'D=\"${DISPLAY:-}\"; '\n    'if [ -z \"$D\" ] || [ ! -S \"/tmp/.X11-unix/X${D#:}\" ] 2>/dev/null; then '\n    \"for x in /tmp/.X11-unix/X*; do \"\n    '[ -S \"$x\" ] || continue; '\n    'D=\":${x##*/X}\"; break; '\n    \"done; \"\n    \"fi; \"\n    'export DISPLAY=\"${D:-:1}\"; '\n    \"if pgrep -x firefox >/dev/null 2>&1; then exit 0; fi; \"\n    \"firefox --new-window about:blank >/dev/null 2>&1 & \"\n    \"sleep 3; \"\n    \"pgrep -x firefox >/dev/null\"\n)\n\n\nasync def _launch_browser_once(out_dir: Path) -> int:\n    \"\"\"One-time shell helper to start Firefox; navigation after this is mouse/keyboard.\"\"\"\n    return await cmd_step_shell(out_dir, _LINUX_FIREFOX_LAUNCH_SHELL)\n\n\nasync def cmd_step_open_url(out_dir: Path, url: str, *, launch: bool = True) -> int:\n    \"\"\"Open URL in sandbox browser using keyboard focus + type (mouse-first navigation).\"\"\"\n    if launch:\n        await _launch_browser_once(out_dir)\n        await asyncio.sleep(1.0)\n    # Focus omnibox then type URL (Firefox on cua-xfce XFCE).\n    await cmd_step_key(out_dir, \"ctrl+l\")\n    await asyncio.sleep(0.4)\n    await cmd_step_key(out_dir, \"ctrl+a\")\n    await asyncio.sleep(0.1)\n    await cmd_step_type(out_dir, url)\n    await asyncio.sleep(0.2)\n    await cmd_step_key(out_dir, \"enter\")\n    await asyncio.sleep(2.0)\n    _emit({\"ok\": True, \"action\": \"open-url\", \"url\": url})\n    return 0\n\n\nasync def cmd_bootstrap(\n    out_dir: Path,\n    *,\n    open_browser: bool,\n    url: str | None = None,\n) -> int:\n    apply_no_proxy_env()\n    out_dir = out_dir.resolve()\n    if sandbox_json_path(out_dir).is_file():\n        print(f\"error: {SANDBOX_JSON} already exists; run teardown first\", file=sys.stderr)\n        return 1\n\n    runtime = os.environ.get(\"ANALYZER_RUNTIME\", \"sandbox-local\")\n    image_key = os.environ.get(\"ANALYZER_SANDBOX_IMAGE\", \"linux\").lower()\n    local = runtime != \"sandbox-cloud\"\n    name = _derive_sandbox_name(out_dir)\n\n    from cua import Sandbox\n\n    if local:\n        if image_key not in (\"auto\", \"linux\"):\n            print(\n                f\"warning: sandbox_ctl bootstrap only implements linux container; \"\n                f\"got image={image_key!r}\",\n                file=sys.stderr,\n            )\n        sb = await Sandbox.create(\n            linux_container_image(),\n            name=name,\n            local=True,\n            runtime=linux_docker_runtime(ephemeral=False),\n        )\n        provider = \"docker\"\n        image = os.environ.get(\"ANALYZER_LINUX_CONTAINER_IMAGE\", LINUX_CONTAINER_IMAGE)\n        platform = os.environ.get(\"ANALYZER_LINUX_DOCKER_PLATFORM\", LINUX_DOCKER_PLATFORM)\n    else:\n        api_key = os.environ.get(\"CUA_API_KEY\", \"\").strip()\n        if not api_key:\n            print(\"error: CUA_API_KEY required for cloud bootstrap\", file=sys.stderr)\n            return 1\n        from cua import Image\n\n        sb = await Sandbox.create(Image.linux(), name=name, local=False, api_key=api_key)\n        provider = \"cloud\"\n        image = \"linux\"\n        platform = None\n\n    api_url = _api_url_from_sb(sb)\n    info = {\n        \"name\": sb.name or name,\n        \"provider\": provider,\n        \"api_url\": api_url,\n        \"image\": image,\n        \"platform\": platform,\n        \"local\": local,\n    }\n    write_sandbox_info(out_dir, info)\n    _merge_metadata_sandbox(out_dir, info[\"name\"], api_url, local)\n    await sb.disconnect()\n\n    _emit({\"ok\": True, \"sandbox\": info})\n\n    if open_browser:\n        target = (url or os.environ.get(\"ANALYZER_PRODUCT_URL\") or \"\").strip()\n        if target:\n            return await cmd_step_open_url(out_dir, target, launch=True)\n        return await _launch_browser_once(out_dir)\n    return 0\n\n\nasync def cmd_teardown(out_dir: Path) -> int:\n    apply_no_proxy_env()\n    out_dir = out_dir.resolve()\n    path = sandbox_json_path(out_dir)\n    if not path.is_file():\n        _emit({\"ok\": True, \"skipped\": \"no sandbox.json\"})\n        return 0\n    info = load_sandbox_info(out_dir)\n    from cua import Sandbox\n\n    try:\n        await Sandbox.delete(\n            info[\"name\"],\n            local=bool(info.get(\"local\", True)),\n            api_key=os.environ.get(\"CUA_API_KEY\") if not info.get(\"local\", True) else None,\n        )\n    except Exception as exc:\n        print(f\"warning: Sandbox.delete: {exc}\", file=sys.stderr)\n    path.unlink(missing_ok=True)\n    _emit({\"ok\": True, \"deleted\": info[\"name\"]})\n    return 0\n\n\ndef cmd_status(out_dir: Path) -> int:\n    out_dir = out_dir.resolve()\n    path = sandbox_json_path(out_dir)\n    if not path.is_file():\n        _emit({\"ok\": False, \"error\": f\"no {SANDBOX_JSON} in {out_dir}\"})\n        return 1\n    info = load_sandbox_info(out_dir)\n    _emit({\"ok\": True, \"sandbox\": info})\n    print(json.dumps(info, indent=2, ensure_ascii=False))\n    api_url = info.get(\"api_url\", \"\")\n    if api_url:\n        try:\n            req = urllib.request.Request(f\"{api_url.rstrip('/')}/status\", method=\"GET\")\n            with urllib.request.urlopen(req, timeout=5) as resp:\n                body = resp.read().decode(\"utf-8\", errors=\"replace\")[:500]\n            print(f\"GET {api_url}/status -> {resp.status} {body[:200]}\")\n        except Exception as exc:\n            print(f\"GET {api_url}/status failed: {exc}\", file=sys.stderr)\n            return 1\n    return 0\n\n\nasync def cmd_step_screenshot(out_dir: Path, out_path: Path) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    out_path = out_path if out_path.is_absolute() else (out_dir.resolve() / out_path)\n    out_path.parent.mkdir(parents=True, exist_ok=True)\n\n    async with _connect_from_info(info) as sb:\n        png = await sb.screenshot()\n\n    out_path.write_bytes(png)\n    ok = len(png) >= _MIN_SCREENSHOT_BYTES\n    _emit({\"ok\": ok, \"path\": str(out_path), \"bytes\": len(png)})\n    return 0 if ok else 1\n\n\ndef _resolve_shell_command(shell_cmd: str | None, shell_argv: list[str]) -> str | None:\n    if shell_cmd and shell_cmd.strip():\n        return shell_cmd.strip()\n    parts = list(shell_argv)\n    if parts and parts[0] == \"--\":\n        parts = parts[1:]\n    # REMAINDER may capture ``-c cmd ...`` when -c follows positional out_dir.\n    if parts and parts[0] in (\"-c\", \"--cmd\"):\n        parts = parts[1:]\n    if not parts:\n        return None\n    return \" \".join(parts)\n\n\nasync def cmd_step_shell(out_dir: Path, command: str) -> int:\n    apply_no_proxy_env()\n    out_dir = out_dir.resolve()\n    artifact = out_dir / LAST_SHELL_JSON\n    try:\n        info = load_sandbox_info(out_dir)\n        async with _connect_from_info(info) as sb:\n            result = await sb.shell.run(command)\n    except Exception as exc:\n        payload = {\n            \"ok\": False,\n            \"returncode\": 1,\n            \"stdout\": \"\",\n            \"stderr\": str(exc),\n            \"command\": command,\n            \"artifact\": str(artifact),\n            \"error\": f\"{type(exc).__name__}: {exc}\",\n        }\n        _emit(payload, file=artifact)\n        print(f\"sandbox_ctl shell: {payload['error']}\", file=sys.stderr, flush=True)\n        return 1\n    stdout = result.stdout or \"\"\n    stderr = result.stderr or \"\"\n    payload = {\n        \"ok\": result.success,\n        \"returncode\": result.returncode,\n        \"stdout\": stdout,\n        \"stderr\": stderr,\n        \"command\": command,\n        \"artifact\": str(artifact),\n    }\n    _emit(payload, file=artifact)\n    # Human-readable tail on stderr so Bash-tool users still see something if stdout is sparse.\n    print(\n        f\"sandbox_ctl shell: ok={result.success} rc={result.returncode} \"\n        f\"stdout_bytes={len(stdout)} stderr_bytes={len(stderr)}\",\n        file=sys.stderr,\n        flush=True,\n    )\n    if stdout:\n        sys.stderr.write(stdout if stdout.endswith(\"\\n\") else stdout + \"\\n\")\n        sys.stderr.flush()\n    if stderr:\n        sys.stderr.write(stderr if stderr.endswith(\"\\n\") else stderr + \"\\n\")\n        sys.stderr.flush()\n    return 0 if result.success else 1\n\n\nasync def cmd_step_click(out_dir: Path, x: int, y: int, *, button: str) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        if button == \"right\":\n            await sb.mouse.right_click(x, y)\n        elif button == \"double\":\n            await sb.mouse.double_click(x, y)\n        else:\n            await sb.mouse.click(x, y)\n    _emit({\"ok\": True, \"action\": button, \"x\": x, \"y\": y})\n    return 0\n\n\nasync def cmd_step_move(out_dir: Path, x: int, y: int) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        await sb.mouse.move(x, y)\n    _emit({\"ok\": True, \"x\": x, \"y\": y})\n    return 0\n\n\nasync def cmd_step_type(out_dir: Path, text: str) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        await sb.keyboard.type(text)\n    _emit({\"ok\": True, \"chars\": len(text)})\n    return 0\n\n\n# computer-server / cua_auto hotkey() only accepts lowercase names (see cua_auto.keyboard._SPECIAL).\n# Do not emit pynput-style PascalCase (Return, Escape) — HTTP transport rejects them.\n_KEY_ALIASES: dict[str, str] = {\n    \"escape\": \"escape\",\n    \"esc\": \"escape\",\n    \"enter\": \"enter\",\n    \"return\": \"enter\",\n    \"control\": \"ctrl\",\n    \"command\": \"meta\",\n    \"cmd\": \"meta\",\n    \"win\": \"meta\",\n    \"super\": \"meta\",\n    \"option\": \"alt\",\n}\n\n\ndef _normalize_keys(keys: str) -> list[str]:\n    parts = [k.strip() for k in keys.split(\"+\") if k.strip()]\n    if not parts:\n        return []\n    out: list[str] = []\n    for p in parts:\n        lk = p.lower()\n        out.append(_KEY_ALIASES.get(lk, lk))\n    return out\n\n\nasync def cmd_step_key(out_dir: Path, keys: str) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    key_list = _normalize_keys(keys)\n    async with _connect_from_info(info) as sb:\n        await sb.keyboard.keypress(key_list)\n    _emit({\"ok\": True, \"keys\": keys})\n    return 0\n\n\nasync def cmd_step_scroll(\n    out_dir: Path, x: int, y: int, *, scroll_x: int = 0, scroll_y: int = 3\n) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        await sb.mouse.scroll(x, y, scroll_x, scroll_y)\n    _emit({\"ok\": True, \"x\": x, \"y\": y, \"scroll_x\": scroll_x, \"scroll_y\": scroll_y})\n    return 0\n\n\nasync def cmd_step_screen_size(out_dir: Path) -> int:\n    apply_no_proxy_env()\n    info = load_sandbox_info(out_dir)\n    async with _connect_from_info(info) as sb:\n        width, height = await sb.screen.size()\n    _emit({\"ok\": True, \"width\": width, \"height\": height})\n    return 0\n\n\ndef _batch_cleanup_disabled() -> bool:\n    return os.environ.get(\"ANALYZER_BATCH_NO_CLEANUP\", \"\").strip().lower() in (\n        \"1\",\n        \"true\",\n        \"yes\",\n        \"on\",\n    )\n\n\ndef _collect_sandbox_names_from_reports() -> set[str]:\n    names: set[str] = set()\n    if not REPORTS_DIR.is_dir():\n        return names\n    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n        try:\n            data = json.loads(path.read_text(encoding=\"utf-8\"))\n        except (json.JSONDecodeError, OSError):\n            continue\n        name = (data.get(\"name\") or \"\").strip()\n        if name:\n            names.add(name)\n    return names\n\n\ndef _docker_cua_sandbox_container_names() -> set[str]:\n    \"\"\"Container names with Cua sandbox label (running or stopped).\"\"\"\n    if not shutil.which(\"docker\"):\n        return set()\n    proc = subprocess.run(\n        [\n            \"docker\",\n            \"ps\",\n            \"-aq\",\n            \"--filter\",\n            \"label=cua.sandbox=true\",\n            \"--format\",\n            \"{{.Names}}\",\n        ],\n        capture_output=True,\n        text=True,\n        timeout=60,\n    )\n    if proc.returncode != 0:\n        return set()\n    return {line.strip() for line in proc.stdout.splitlines() if line.strip()}\n\n\ndef _docker_force_rm(names: set[str]) -> list[str]:\n    removed: list[str] = []\n    if not names or not shutil.which(\"docker\"):\n        return removed\n    for name in sorted(names):\n        proc = subprocess.run(\n            [\"docker\", \"rm\", \"-f\", name],\n            capture_output=True,\n            text=True,\n            timeout=30,\n        )\n        if proc.returncode == 0:\n            removed.append(name)\n    return removed\n\n\ndef _unlink_sandbox_json_for_name(name: str) -> None:\n    if not REPORTS_DIR.is_dir():\n        return\n    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n        try:\n            data = json.loads(path.read_text(encoding=\"utf-8\"))\n        except (json.JSONDecodeError, OSError):\n            continue\n        if data.get(\"name\") == name:\n            path.unlink(missing_ok=True)\n\n\nasync def cmd_cleanup_all(*, prefix: str = ANALYZER_SANDBOX_PREFIX) -> int:\n    \"\"\"Stop/remove local Cua Docker sandboxes (batch exit / manual cleanup).\"\"\"\n    apply_no_proxy_env()\n    from cua import Sandbox\n\n    docker_names = _docker_cua_sandbox_container_names()\n    targets: set[str] = set(docker_names)\n    targets |= _collect_sandbox_names_from_reports()\n\n    try:\n        listed = await Sandbox.list(local=True)\n        for info in listed:\n            if info.name:\n                targets.add(info.name)\n    except Exception as exc:\n        print(f\"warning: Sandbox.list: {exc}\", file=sys.stderr)\n\n    to_delete = set(docker_names)\n    to_delete |= {n for n in targets if n.startswith(prefix)}\n\n    deleted: list[str] = []\n    errors: list[str] = []\n    for name in sorted(to_delete):\n        try:\n            await Sandbox.delete(name, local=True)\n            deleted.append(name)\n            _unlink_sandbox_json_for_name(name)\n        except Exception as exc:\n            errors.append(f\"{name}: {exc}\")\n\n    docker_removed = _docker_force_rm(to_delete - set(deleted))\n    deleted.extend(n for n in docker_removed if n not in deleted)\n\n    leftover = _docker_cua_sandbox_container_names() - set(deleted)\n    if leftover:\n        docker_removed2 = _docker_force_rm(leftover)\n        deleted.extend(n for n in docker_removed2 if n not in deleted)\n\n    payload = {\n        \"ok\": not errors,\n        \"deleted\": deleted,\n        \"errors\": errors,\n        \"count\": len(deleted),\n    }\n    _emit(payload)\n    if deleted:\n        print(\n            f\"sandbox_ctl cleanup: removed {len(deleted)} container(s)\",\n            file=sys.stderr,\n            flush=True,\n        )\n    for err in errors:\n        print(f\"sandbox_ctl cleanup: {err}\", file=sys.stderr)\n    return 0 if not errors else 1\n\n\ndef reset_batch_cleanup_gate() -> None:\n    \"\"\"Allow a new batch run to run exit cleanup again.\"\"\"\n    global _cleanup_done\n    with _cleanup_lock:\n        _cleanup_done = False\n\n\ndef docker_cleanup_sync_quick() -> int:\n    \"\"\"SIGINT-safe: ``docker rm -f`` Cua containers without asyncio (for signal handler).\"\"\"\n    if _batch_cleanup_disabled():\n        return 0\n    names = _docker_cua_sandbox_container_names()\n    names |= {\n        n\n        for n in _collect_sandbox_names_from_reports()\n        if n.startswith(ANALYZER_SANDBOX_PREFIX)\n    }\n    removed = _docker_force_rm(names)\n    if removed:\n        print(\n            f\"sandbox_ctl: 已停止 {len(removed)} 个 Docker 沙盒容器\",\n            file=sys.stderr,\n            flush=True,\n        )\n    return len(removed)\n\n\ndef _batch_signal_handler(signum: int, frame: Any) -> None:\n    \"\"\"First Ctrl+C: quick docker stop; then raise KeyboardInterrupt for ``finally``.\"\"\"\n    try:\n        docker_cleanup_sync_quick()\n    except Exception:\n        pass\n    raise KeyboardInterrupt\n\n\ndef install_batch_exit_hooks(*, local: bool) -> None:\n    \"\"\"Register SIGINT/SIGTERM + atexit so forced exit still cleans Docker sandboxes.\"\"\"\n    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n    if not local or _batch_cleanup_disabled() or _batch_exit_hooks_installed:\n        return\n    _prev_sigint_handler = signal.getsignal(signal.SIGINT)\n    _prev_sigterm_handler = signal.getsignal(signal.SIGTERM)\n    signal.signal(signal.SIGINT, _batch_signal_handler)\n    signal.signal(signal.SIGTERM, _batch_signal_handler)\n    atexit.register(cleanup_all_local_sandboxes)\n    _batch_exit_hooks_installed = True\n\n\ndef uninstall_batch_exit_hooks() -> None:\n    global _batch_exit_hooks_installed, _prev_sigint_handler, _prev_sigterm_handler\n    if not _batch_exit_hooks_installed:\n        return\n    if _prev_sigint_handler is not None:\n        signal.signal(signal.SIGINT, _prev_sigint_handler)\n    if _prev_sigterm_handler is not None:\n        signal.signal(signal.SIGTERM, _prev_sigterm_handler)\n    _prev_sigint_handler = None\n    _prev_sigterm_handler = None\n    _batch_exit_hooks_installed = False\n\n\ndef cleanup_all_local_sandboxes(*, force: bool = False) -> None:\n    \"\"\"Idempotent batch-exit hook: tear down Cua Docker sandboxes. Never raises.\"\"\"\n    global _cleanup_done\n    if _batch_cleanup_disabled():\n        return\n    with _cleanup_lock:\n        if _cleanup_done and not force:\n            return\n        _cleanup_done = True\n    try:\n        asyncio.run(cmd_cleanup_all())\n    except Exception as exc:\n        print(f\"sandbox_ctl cleanup: {exc}\", file=sys.stderr, flush=True)\n        try:\n            docker_cleanup_sync_quick()\n        except Exception:\n            pass\n\n\ndef teardown_out_dir(out_dir: Path) -> None:\n    \"\"\"Best-effort teardown for batch finally hook; never raises.\"\"\"\n    try:\n        asyncio.run(cmd_teardown(out_dir))\n    except Exception as exc:\n        print(f\"sandbox_ctl teardown: {exc}\", file=sys.stderr)\n\n\ndef _build_parser() -> argparse.ArgumentParser:\n    p = argparse.ArgumentParser(description=\"Step-by-step Cua sandbox control for product-analyzer batch\")\n    sub = p.add_subparsers(dest=\"command\", required=True)\n\n    boot = sub.add_parser(\"bootstrap\", help=\"Create named sandbox and write sandbox.json\")\n    boot.add_argument(\"out_dir\", type=Path)\n    boot.add_argument(\n        \"--open-browser\",\n        action=\"store_true\",\n        help=\"After bootstrap, launch Firefox (cua-xfce; use with --url for Ctrl+L navigation)\",\n    )\n    boot.add_argument(\n        \"--url\",\n        default=None,\n        help=\"Product homepage URL (opens via step open-url / Ctrl+L, not wget)\",\n    )\n\n    sub.add_parser(\"teardown\", help=\"Delete sandbox and remove sandbox.json\").add_argument(\n        \"out_dir\", type=Path\n    )\n    sub.add_parser(\n        \"cleanup-all\",\n        help=\"Remove all local Cua Docker sandboxes (analyzer-* + label cua.sandbox=true)\",\n    )\n    sub.add_parser(\"status\", help=\"Print sandbox.json and probe /status\").add_argument(\n        \"out_dir\", type=Path\n    )\n\n    step = sub.add_parser(\"step\", help=\"Single sandbox action\")\n    step_sub = step.add_subparsers(dest=\"step_cmd\", required=True)\n\n    shot = step_sub.add_parser(\"screenshot\", help=\"Save PNG to --out path\")\n    shot.add_argument(\"out_dir\", type=Path)\n    shot.add_argument(\"--out\", type=Path, required=True)\n\n    shell = step_sub.add_parser(\n        \"shell\",\n        help=\"Run one shell command in sandbox (prefer -c)\",\n    )\n    shell.add_argument(\"out_dir\", type=Path)\n    shell.add_argument(\n        \"-c\",\n        \"--cmd\",\n        dest=\"shell_cmd\",\n        metavar=\"CMD\",\n        help=\"Shell command string (required unless legacy args after --)\",\n    )\n    shell.add_argument(\n        \"shell_argv\",\n        nargs=argparse.REMAINDER,\n        metavar=\"[-- CMD ...]\",\n        help=\"Legacy: command tokens after --\",\n    )\n\n    click_p = step_sub.add_parser(\"click\", help=\"Click at x y\")\n    click_p.add_argument(\"out_dir\", type=Path)\n    click_p.add_argument(\"x\", type=int)\n    click_p.add_argument(\"y\", type=int)\n    click_p.add_argument(\"--button\", choices=(\"left\", \"right\", \"double\"), default=\"left\")\n\n    move_p = step_sub.add_parser(\"move\", help=\"Move cursor to x y\")\n    move_p.add_argument(\"out_dir\", type=Path)\n    move_p.add_argument(\"x\", type=int)\n    move_p.add_argument(\"y\", type=int)\n\n    type_p = step_sub.add_parser(\"type\", help=\"Type text\")\n    type_p.add_argument(\"out_dir\", type=Path)\n    type_p.add_argument(\"text\")\n\n    key_p = step_sub.add_parser(\"key\", help=\"Keypress (enter or ctrl+c)\")\n    key_p.add_argument(\"out_dir\", type=Path)\n    key_p.add_argument(\"keys\")\n\n    scroll_p = step_sub.add_parser(\"scroll\", help=\"Scroll at x y\")\n    scroll_p.add_argument(\"out_dir\", type=Path)\n    scroll_p.add_argument(\"x\", type=int)\n    scroll_p.add_argument(\"y\", type=int)\n    scroll_p.add_argument(\"--scroll-x\", type=int, default=0)\n    scroll_p.add_argument(\"--scroll-y\", type=int, default=3)\n\n    step_sub.add_parser(\"screen-size\", help=\"Print sandbox display width x height\").add_argument(\n        \"out_dir\", type=Path\n    )\n\n    open_url = step_sub.add_parser(\n        \"open-url\",\n        help=\"Launch browser (once) and open URL via keyboard (mouse-first)\",\n    )\n    open_url.add_argument(\"out_dir\", type=Path)\n    open_url.add_argument(\"url\")\n    open_url.add_argument(\n        \"--no-launch\",\n        action=\"store_true\",\n        help=\"Skip Firefox launch (browser already running)\",\n    )\n\n    return p\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = _build_parser().parse_args(argv)\n    if args.command == \"bootstrap\":\n        return asyncio.run(\n            cmd_bootstrap(\n                args.out_dir,\n                open_browser=args.open_browser,\n                url=getattr(args, \"url\", None),\n            )\n        )\n    if args.command == \"teardown\":\n        return asyncio.run(cmd_teardown(args.out_dir))\n    if args.command == \"cleanup-all\":\n        return asyncio.run(cmd_cleanup_all())\n    if args.command == \"status\":\n        return cmd_status(args.out_dir)\n    if args.command == \"step\":\n        if args.step_cmd == \"screenshot\":\n            return asyncio.run(cmd_step_screenshot(args.out_dir, args.out))\n        if args.step_cmd == \"shell\":\n            command = _resolve_shell_command(\n                getattr(args, \"shell_cmd\", None),\n                getattr(args, \"shell_argv\", None) or [],\n            )\n            if not command:\n                print(\n                    \"error: shell requires -c '...' or arguments after --\",\n                    file=sys.stderr,\n                )\n                return 1\n            return asyncio.run(cmd_step_shell(args.out_dir, command))\n        if args.step_cmd == \"click\":\n            return asyncio.run(\n                cmd_step_click(args.out_dir, args.x, args.y, button=args.button)\n            )\n        if args.step_cmd == \"move\":\n            return asyncio.run(cmd_step_move(args.out_dir, args.x, args.y))\n        if args.step_cmd == \"type\":\n            return asyncio.run(cmd_step_type(args.out_dir, args.text))\n        if args.step_cmd == \"key\":\n            return asyncio.run(cmd_step_key(args.out_dir, args.keys))\n        if args.step_cmd == \"scroll\":\n            return asyncio.run(\n                cmd_step_scroll(\n                    args.out_dir,\n                    args.x,\n                    args.y,\n                    scroll_x=args.scroll_x,\n                    scroll_y=args.scroll_y,\n                )\n            )\n        if args.step_cmd == \"screen-size\":\n            return asyncio.run(cmd_step_screen_size(args.out_dir))\n        if args.step_cmd == \"open-url\":\n            return asyncio.run(\n                cmd_step_open_url(\n                    args.out_dir,\n                    args.url,\n                    launch=not args.no_launch,\n                )\n            )\n    return 1\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":822,"startLine":1,"totalLines":822}}}
