power-manager/inactivity-sleep-mode-on-ac -s 0 \"\n143\t    + \"2>/dev/null || true; \"\n144\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/inactivity-sleep-mode-on-battery -s 0 \"\n145\t    + \"2>/dev/null || true; \"\n146\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/blank-on-ac -s 0 \"\n147\t    + \"2>/dev/null || true; \"\n148\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/blank-on-battery -s 0 \"\n149\t    + \"2>/dev/null || true; \"\n150\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-sleep -s 0 \"\n151\t    + \"2>/dev/null || true; \"\n152\t    + \"xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-off -s 0 \"\n153\t    + \"2>/dev/null || true; \"\n154\t    + \"xfconf-query -c screensaver -p /saver/enabled -s false 2>/dev/null || true; \"\n155\t    + \"xfconf-query -c screensaver -p /saver/idle-activation/enabled -s false 2>/dev/null || true; \"\n156\t    + \"fi; \"\n157\t    + \"if command -v systemctl >/dev/null 2>&1; then \"\n158\t    + \"systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target \"\n159\t    + \"2>/dev/null || true; \"\n160\t    + \"fi; \"\n161\t    + \"exit 0\"\n162\t)\n163\t\n164\t\n165\tasync def _launch_browser_once(out_dir: Path) -> int:\n166\t    \"\"\"One-time shell helper to start Firefox; navigation after this is mouse/keyboard.\"\"\"\n167\t    return await cmd_step_shell(out_dir, _LINUX_FIREFOX_LAUNCH_SHELL)\n168\t\n169\t\n170\tasync def _disable_linux_xfce_sleep(out_dir: Path) -> None:\n171\t    \"\"\"Best-effort disable screen blank/suspend on cua-xfce; never fails bootstrap.\"\"\"\n172\t    rc = await cmd_step_shell(out_dir, _LINUX_XFCE_DISABLE_SLEEP_SHELL)\n173\t    if rc != 0:\n174\t        print(\n175\t            \"warning: sandbox_ctl could not fully disable XFCE sleep (non-fatal)\",\n176\t            file=sys.stderr,\n177\t        )\n178\t\n179\t\n180\tasync def cmd_step_open_url(out_dir: Path, url: str, *, launch: bool = True) -> int:\n181\t    \"\"\"Open URL in sandbox browser using keyboard focus + type (mouse-first navigation).\"\"\"\n182\t    if launch:\n183\t        await _launch_browser_once(out_dir)\n184\t        await asyncio.sleep(1.0)\n185\t    # Focus omnibox then type URL (Firefox on cua-xfce XFCE).\n186\t    await cmd_step_key(out_dir, \"ctrl+l\")\n187\t    await asyncio.sleep(0.4)\n188\t    await cmd_step_key(out_dir, \"ctrl+a\")\n189\t    await asyncio.sleep(0.1)\n190\t    await cmd_step_type(out_dir, url)\n191\t    await asyncio.sleep(0.2)\n192\t    await cmd_step_key(out_dir, \"enter\")\n193\t    await asyncio.sleep(_PAGE_LOAD_WAIT_S)\n194\t    _emit({\"ok\": True, \"action\": \"open-url\", \"url\": url, \"load_wait_s\": _PAGE_LOAD_WAIT_S})\n195\t    return 0\n196\t\n197\t\n198\tasync def cmd_bootstrap(\n199\t    out_dir: Path,\n200\t    *,\n201\t    open_browser: bool,\n202\t    url: str | None = None,\n203\t) -> int:\n204\t    apply_no_proxy_env()\n205\t    out_dir = out_dir.resolve()\n206\t    if sandbox_json_path(out_dir).is_file():\n207\t        print(f\"error: {SANDBOX_JSON} already exists; run teardown first\", file=sys.stderr)\n208\t        return 1\n209\t\n210\t    runtime = os.environ.get(\"ANALYZER_RUNTIME\", \"sandbox-local\")\n211\t    image_key = os.environ.get(\"ANALYZER_SANDBOX_IMAGE\", \"linux\").lower()\n212\t    local = runtime != \"sandbox-cloud\"\n213\t    name = _derive_sandbox_name(out_dir)\n214\t\n215\t    from cua import Sandbox\n216\t\n217\t    if local:\n218\t        if image_key not in (\"auto\", \"linux\"):\n219\t            print(\n220\t                f\"warning: sandbox_ctl bootstrap only implements linux container; \"\n221\t                f\"got image={image_key!r}\",\n222\t                file=sys.stderr,\n223\t            )\n224\t        sb = await Sandbox.create(\n225\t            linux_container_image(),\n226\t            name=name,\n227\t            local=True,\n228\t            runtime=