{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_susQ5aBl2HKhbUUKkE5LK5Jv","type":"tool_result","content":"300\t    info = load_sandbox_info(out_dir)\n301\t    _emit({\"ok\": True, \"sandbox\": info})\n302\t    print(json.dumps(info, indent=2, ensure_ascii=False))\n303\t    api_url = info.get(\"api_url\", \"\")\n304\t    if api_url:\n305\t        try:\n306\t            req = urllib.request.Request(f\"{api_url.rstrip('/')}/status\", method=\"GET\")\n307\t            with urllib.request.urlopen(req, timeout=5) as resp:\n308\t                body = resp.read().decode(\"utf-8\", errors=\"replace\")[:500]\n309\t            print(f\"GET {api_url}/status -> {resp.status} {body[:200]}\")\n310\t        except Exception as exc:\n311\t            print(f\"GET {api_url}/status failed: {exc}\", file=sys.stderr)\n312\t            return 1\n313\t    return 0\n314\t\n315\t\n316\tasync def cmd_step_screenshot(out_dir: Path, out_path: Path) -> int:\n317\t    apply_no_proxy_env()\n318\t    info = load_sandbox_info(out_dir)\n319\t    out_path = out_path if out_path.is_absolute() else (out_dir.resolve() / out_path)\n320\t    out_path.parent.mkdir(parents=True, exist_ok=True)\n321\t\n322\t    async with _connect_from_info(info) as sb:\n323\t        png = await sb.screenshot()\n324\t\n325\t    out_path.write_bytes(png)\n326\t    ok = len(png) >= _MIN_SCREENSHOT_BYTES\n327\t    _emit({\"ok\": ok, \"path\": str(out_path), \"bytes\": len(png)})\n328\t    return 0 if ok else 1\n329\t\n330\t\n331\tdef _resolve_shell_command(shell_cmd: str | None, shell_argv: list[str]) -> str | None:\n332\t    if shell_cmd and shell_cmd.strip():\n333\t        return shell_cmd.strip()\n334\t    parts = list(shell_argv)\n335\t    if parts and parts[0] == \"--\":\n336\t        parts = parts[1:]\n337\t    # REMAINDER may capture ``-c cmd ...`` when -c follows positional out_dir.\n338\t    if parts and parts[0] in (\"-c\", \"--cmd\"):\n339\t        parts = parts[1:]\n340\t    if not parts:\n341\t        return None\n342\t    return \" \".join(parts)\n343\t\n344\t\n345\tasync def cmd_step_shell(out_dir: Path, command: str) -> int:\n346\t    apply_no_proxy_env()\n347\t    out_dir = out_dir.resolve()\n348\t    artifact = out_dir / LAST_SHELL_JSON\n349\t    try:\n350\t        info = load_sandbox_info(out_dir)\n351\t        async with _connect_from_info(info) as sb:\n352\t            result = await sb.shell.run(command)\n353\t    except Exception as exc:\n354\t        payload = {\n355\t            \"ok\": False,\n356\t            \"returncode\": 1,\n357\t            \"stdout\": \"\",\n358\t            \"stderr\": str(exc),\n359\t            \"command\": command,\n360\t            \"artifact\": str(artifact),\n361\t            \"error\": f\"{type(exc).__name__}: {exc}\",\n362\t        }\n363\t        _emit(payload, file=artifact)\n364\t        print(f\"sandbox_ctl shell: {payload['error']}\", file=sys.stderr, flush=True)\n365\t        return 1\n366\t    stdout = result.stdout or \"\"\n367\t    stderr = result.stderr or \"\"\n368\t    payload = {\n369\t        \"ok\": result.success,\n370\t        \"returncode\": result.returncode,\n371\t        \"stdout\": stdout,\n372\t        \"stderr\": stderr,\n373\t        \"command\": command,\n374\t        \"artifact\": str(artifact),\n375\t    }\n376\t    _emit(payload, file=artifact)\n377\t    # Human-readable tail on stderr so Bash-tool users still see something if stdout is sparse.\n378\t    print(\n379\t        f\"sandbox_ctl shell: ok={result.success} rc={result.returncode} \"\n380\t        f\"stdout_bytes={len(stdout)} stderr_bytes={len(stderr)}\",\n381\t        file=sys.stderr,\n382\t        flush=True,\n383\t    )\n384\t    if stdout:\n385\t        sys.stderr.write(stdout if stdout.endswith(\"\\n\") else stdout + \"\\n\")\n386\t        sys.stderr.flush()\n387\t    if stderr:\n388\t        sys.stderr.write(stderr if stderr.endswith(\"\\n\") else stderr + \"\\n\")\n389\t        sys.stderr.flush()\n390\t    return 0 if result.success else 1\n391\t\n392\t\n393\tasync def cmd_step_click(out_dir: Path, x: int, y: int, *, button: str) -> int:\n394\t    apply_no_proxy_env()\n395\t    info = load_sandbox_info(out_dir)\n396\t    async with _connect_from_info(info) as sb:\n397\t        if button == \"right\":\n398\t            await sb.mouse.right_click(x, y)\n399\t        elif button == \"double\":\n400\t            await sb.mouse.double_click(x, y)\n401\t        else:\n402\t            await sb.mouse.click(x, y)\n403\t    _emit({\"ok\": True, \"action\": button, \"x\": x, \"y\": y})\n404\t    return 0\n405\t\n406\t\n407\tasync def cmd_step_move(out_dir: Path, x: int, y: int) -> int:\n408\t    apply_no_proxy_env()\n409\t    info = load_sandbox_info(out_dir)\n410\t    async with _connect_from_info(info) as sb:\n411\t        await sb.mouse.move(x, y)\n412\t    _emit({\"ok\": True, \"x\": x, \"y\": y})\n413\t    return 0\n414\t\n415\t\n416\tasync def cmd_step_type(out_dir: Path, text: str) -> int:\n417\t    apply_no_proxy_env()\n418\t    info = load_sandbox_info(out_dir)\n419\t    async with _connect_from_info(info) as sb:\n420\t        await sb.keyboard.type(text)\n421\t    _emit({\"ok\": True, \"chars\": len(text)})\n422\t    return 0\n423\t\n424\t\n425\t# computer-server (pynput) Key names differ from SDK docs examples — normalize before hotkey.\n426\t# Linux: Key.esc not escape; Key.cmd not meta; Key.page_up not pageup; etc.\n427\t_KEY_ALIASES: dict[str, str] = {\n428\t    \"escape\": \"esc\",\n429\t    \"esc\": \"esc\",\n430\t    \"enter\": \"enter\",\n431\t    \"return\": \"enter\",\n432\t    \"ret\": \"enter\",\n433\t    \"tab\": \"tab\",\n434\t    \"space\": \"space\",\n435\t    \" \": \"space\",\n436\t    \"backspace\": \"backspace\",\n437\t    \"bs\": \"backspace\",\n438\t    \"delete\": \"delete\",\n439\t    \"del\": \"delete\",\n440\t    \"insert\": \"insert\",\n441\t    \"ins\": \"insert\",\n442\t    \"home\": \"home\",\n443\t    \"end\": \"end\",\n444\t    \"pageup\": \"page_up\",\n445\t    \"page_up\": \"page_up\",\n446\t    \"pgup\": \"page_up\",\n447\t    \"pagedown\": \"page_down\",\n448\t    \"page_down\": \"page_down\",\n449\t    \"pgdn\": \"page_down\",\n450\t    \"up\": \"up\",\n451\t    \"down\": \"down\",\n452\t    \"left\": \"left\",\n453\t    \"right\": \"right\",\n454\t    \"control\": \"ctrl\",\n455\t    \"command\": \"cmd\",\n456\t    \"cmd\": \"cmd\",\n457\t    \"win\": \"cmd\",\n458\t    \"super\": \"cmd\",\n459\t    \"meta\": \"cmd\",\n460\t    \"option\": \"alt\",\n461\t}\n462\t\n463\t\n464\tdef _normalize_keys(keys: str) -> list[str]:\n465\t    parts = [k.strip() for k in keys.split(\"+\") if k.strip()]\n466\t    if not parts:\n467\t        return []\n468\t    out: list[str] = []\n469\t    for p in parts:\n470\t        lk = p.lower()\n471\t        out.append(_KEY_ALIASES.get(lk, lk))\n472\t    return out\n473\t\n474\t\n475\tasync def cmd_step_key(out_dir: Path, keys: str) -> int:\n476\t    apply_no_proxy_env()\n477\t    info = load_sandbox_info(out_dir)\n478\t    key_list = _normalize_keys(keys)\n479\t    async with _connect_from_info(info) as sb:\n480\t        # SDK Keyboard.keypress → hotkey; single keys also work via press_key.\n481\t        if len(key_list) == 1:\n482\t            await sb._transport.send(\"press_key\", key=key_list[0])\n483\t        else:\n484\t            await sb.keyboard.keypress(key_list)\n485\t    _emit({\"ok\": True, \"keys\": keys})\n486\t    return 0\n487\t\n488\t\n489\tasync def cmd_step_scroll(\n490\t    out_dir: Path, x: int, y: int, *, scroll_x: int = 0, scroll_y: int = 3\n491\t) -> int:\n492\t    apply_no_proxy_env()\n493\t    info = load_sandbox_info(out_dir)\n494\t    async with _connect_from_info(info) as sb:\n495\t        # cua_sandbox Mouse.scroll sends {x,y,scroll_x,scroll_y}, but computer-server\n496\t        # LinuxAutomationHandler.scroll(x,y) treats x/y as wheel deltas and drops\n497\t        # scroll_x/scroll_y (see trycua/cua computer_server/handlers/linux.py). LocalTransport\n498\t        # does move+scroll correctly; HTTP transport to Docker does not. Work around by\n499\t        # moving first, then scroll_down/up (vertical) or raw scroll deltas (horizontal).\n500\t        await sb.mouse.move(x, y)\n501\t        transport = sb._transport\n502\t        if scroll_y < 0:\n503\t            await transport.send(\"scroll_down\", clicks=abs(scroll_y))\n504\t        elif scroll_y > 0:\n505\t            await transport.send(\"scroll_up\", clicks=scroll_y)\n506\t        if scroll_x < 0:\n507\t            await transport.send(\"scroll\", x=-abs(scroll_x), y=0)\n508\t        elif scroll_x > 0:\n509\t            await transport.send(\"scroll\", x=abs(scroll_x), y=0)\n510\t    _emit({\"ok\": True, \"x\": x, \"y\": y, \"scroll_x\": scroll_x, \"scroll_y\": scroll_y})\n511\t    return 0\n512\t\n513\t\n514\tasync def cmd_step_screen_size(out_dir: Path) -> int:\n515\t    apply_no_proxy_env()\n516\t    info = load_sandbox_info(out_dir)\n517\t    async with _connect_from_info(info) as sb:\n518\t        width, height = await sb.screen.size()\n519\t    _emit({\"ok\": True, \"width\": width, \"height\": height})\n520\t    return 0\n521\t\n522\t\n523\tdef _batch_cleanup_disabled() -> bool:\n524\t    return os.environ.get(\"ANALYZER_BATCH_NO_CLEANUP\", \"\").strip().lower() in (\n525\t        \"1\",\n526\t        \"true\",\n527\t        \"yes\",\n528\t        \"on\",\n529\t    )\n530\t\n531\t\n532\tdef _collect_sandbox_names_from_reports() -> set[str]:\n533\t    names: set[str] = set()\n534\t    if not REPORTS_DIR.is_dir():\n535\t        return names\n536\t    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n537\t        try:\n538\t            data = json.loads(path.read_text(encoding=\"utf-8\"))\n539\t        except (json.JSONDecodeError, OSError):\n540\t            continue\n541\t        name = (data.get(\"name\") or \"\").strip()\n542\t        if name:\n543\t            names.add(name)\n544\t    return names\n545\t\n546\t\n547\tdef _docker_cua_sandbox_container_names() -> set[str]:\n548\t    \"\"\"Container names with Cua sandbox label (running or stopped).\"\"\"\n549\t    if not shutil.which(\"docker\"):\n550\t        return set()\n551\t    proc = subprocess.run(\n552\t        [\n553\t            \"docker\",\n554\t            \"ps\",\n555\t            \"-aq\",\n556\t            \"--filter\",\n557\t            \"label=cua.sandbox=true\",\n558\t            \"--format\",\n559\t            \"{{.Names}}\",\n560\t        ],\n561\t        capture_output=True,\n562\t        text=True,\n563\t        timeout=60,\n564\t    )\n565\t    if proc.returncode != 0:\n566\t        return set()\n567\t    return {line.strip() for line in proc.stdout.splitlines() if line.strip()}\n568\t\n569\t\n570\tdef _docker_force_rm(names: set[str]) -> list[str]:\n571\t    removed: list[str] = []\n572\t    if not names or not shutil.which(\"docker\"):\n573\t        return removed\n574\t    for name in sorted(names):\n575\t        proc = subprocess.run(\n576\t            [\"docker\", \"rm\", \"-f\", name],\n577\t            capture_output=True,\n578\t            text=True,\n579\t            timeout=30,\n580\t        )\n581\t        if proc.returncode == 0:\n582\t            removed.append(name)\n583\t    return removed\n584\t\n585\t\n586\tdef _unlink_sandbox_json_for_name(name: str) -> None:\n587\t    if not REPORTS_DIR.is_dir():\n588\t        return\n589\t    for path in REPORTS_DIR.glob(\"*/sandbox.json\"):\n590\t        try:\n591\t            data = json.loads(path.read_text(encoding=\"utf-8\"))\n592\t        except (json.JSONDecodeError, OSError):\n593\t            continue\n594\t        if data.get(\"name\") == name:\n595\t            path.unlink(missing_ok=True)\n596\t\n597\t\n598\tasync def cmd_cleanup_all(*, prefix: str = ANALYZER_SANDBOX_PREFIX) -> int:\n599\t    \"\"\"Stop/remove local Cua Docker sandboxes (batch exit / manual cleanup).\"\"\""}]},"parent_tool_use_id":null,"session_id":"367ea5ec-1d79-4b9f-b4e9-ffb642da862e","uuid