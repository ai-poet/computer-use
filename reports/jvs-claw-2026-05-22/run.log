{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_roSxNUk1QcaxxQ8jAVqLPuNI","type":"tool_result","content":"1\t\"\"\"Thin CLI bridge: step-by-step Cua sandbox control for batch workers.\n2\t\n3\tDoes not import claude_driver (keeps dependency graph acyclic).\n4\t\"\"\"\n5\t\n6\tfrom __future__ import annotations\n7\t\n8\timport argparse\n9\timport asyncio\n10\timport json\n11\timport os\n12\timport re\n13\timport atexit\n14\timport shutil\n15\timport signal\n16\timport subprocess\n17\timport sys\n18\timport threading\n19\timport urllib.request\n20\tfrom pathlib import Path\n21\tfrom typing import Any\n22\t\n23\tfrom .config import REPORTS_DIR\n24\tfrom .sandbox_runtime import (\n25\t    LINUX_CONTAINER_IMAGE,\n26\t    LINUX_DOCKER_PLATFORM,\n27\t    apply_no_proxy_env,\n28\t    linux_container_image,\n29\t    linux_docker_runtime,\n30\t)\n31\tfrom .tasks import read_metadata, update_metadata\n32\t\n33\tSANDBOX_JSON = \"sandbox.json\"\n34\tLAST_SHELL_JSON = \".sandbox_ctl_last_shell.json\"\n35\t_MIN_SCREENSHOT_BYTES = 1000\n36\tANALYZER_SANDBOX_PREFIX = \"analyzer-\"\n37\t_PAGE_LOAD_WAIT_S = 10.0\n38\t\n39\t_cleanup_lock = threading.Lock()\n40\t_cleanup_done = False\n41\t_batch_exit_hooks_installed = False\n42\t_prev_sigint_handler: Any = None\n43\t_prev_sigterm_handler: Any = None\n44\t\n45\t\n46\tdef _emit(payload: dict, *, file: Path | None = None) -> None:\n47\t    \"\"\"Print one JSON line to stdout (always flushed) and optionally persist.\"\"\"\n48\t    line = json.dumps(payload, ensure_ascii=False) + \"\\n\"\n49\t    sys.stdout.write(line)\n50\t    sys.stdout.flush()\n51\t    if file is not None:\n52\t        file.parent.mkdir(parents=True, exist_ok=True)\n53\t        file.write_text(line, encoding=\"utf-8\")\n54\t\n55\t\n56\tdef sandbox_json_path(out_dir: Path) -> Path:\n57\t    return out_dir.resolve() / SANDBOX_JSON\n58\t\n59\t\n60\tdef load_sandbox_info(out_dir: Path) -> dict[str, Any]:\n61\t    path = sandbox_json_path(out_dir)\n62\t    if not path.is_file():\n63\t        raise FileNotFoundError(f\"{SANDBOX_JSON} not found under {out_dir}; run bootstrap first\")\n64\t    return json.loads(path.read_text(encoding=\"utf-8\"))\n65\t\n66\t\n67\tdef write_sandbox_info(out_dir: Path, info: dict[str, Any]) -> Path:\n68\t    path = sandbox_json_path(out_dir)\n69\t    out_dir.mkdir(parents=True, exist_ok=True)\n70\t    path.write_text(json.dumps(info, indent=2, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n71\t    return path\n72\t\n73\t\n74\tdef _derive_sandbox_name(out_dir: Path) -> str:\n75\t    base = out_dir.resolve().name\n76\t    safe = re.sub(r\"[^a-zA-Z0-9._-]+\", \"-\", base).strip(\"-\").lower()\n77\t    safe = safe[:48] or \"task\"\n78\t    return f\"analyzer-{safe}\"\n79\t\n80\t\n81\tdef _api_url_from_sb(sb: Any) -> str:\n82\t    rt = getattr(sb, \"_runtime_info\", None)\n83\t    if rt and getattr(rt, \"api_port\", None):\n84\t        host = getattr(rt, \"host\", None) or \"127.0.0.1\"\n85\t        return f\"http://{host}:{rt.api_port}\"\n86\t    raise RuntimeError(\"sandbox has no api_port in runtime_info\")\n87\t\n88\t\n89\tdef _merge_metadata_sandbox(out_dir: Path, name: str, api_url: str, local: bool) -> None:\n90\t    meta = read_metadata(out_dir)\n91\t    if not meta:\n92\t        return\n93\t    sandbox = dict(meta.get(\"sandbox\") or {})\n94\t    sandbox[\"name\"] = name\n95\t    sandbox[\"api_url\"] = api_url\n96\t    sandbox[\"local\"] = local\n97\t    update_metadata(out_dir, sandbox=sandbox)\n98\t\n99\t\n100\tdef _connect_from_info(info: dict[str, Any]) -> Any:"}]},"parent_tool_use_id":null,"session_id":"367ea5ec-1d79-4b9f-b4e9-ffb642da862e","uuid":"08ede6c2-de67-49c0-b794-7d165d149228","timestamp":"2026-05-21T20:26:17.991Z","tool_use_result":{"type":"text","file":{"filePath":"/home/zhiwei/projects/computer-use/scripts/product_analyzer/sandbox_ctl.py","content":"\"\"\"Thin CLI bridge: step-by-step Cua sandbox control for batch workers.\n\nDoes not import claude_driver (keeps dependency graph acyclic).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport asyncio\nimport json\nimport os\nimport re\nimport atexit\nimport shutil\nimport signal\nimport subprocess\nimport sys\nimport threading\nimport urllib.request\nfrom pathlib import Path\nfrom typing import Any\n\nfrom .config import REPORTS_DIR\nfrom .sandbox_runtime import (\n    LINUX_CONTAINER_IMAGE,\n    LINUX_DOCKER_PLATFORM,\n    apply_no_proxy_env,\n    linux_container_image,\n    linux_docker_runtime,\n)\nfrom .tasks import read_metadata, update_metadata\n\nSANDBOX_JSON = \"sandbox.json\"\nLAST_SHELL_JSON = \".sandbox_ctl_last_shell.json\"\n_MIN_SCREENSHOT_BYTES = 1000\nANALYZER_SANDBOX_PREFIX = \"analyzer-\"\n_PAGE_LOAD_WAIT_S = 10.0\n\n_cleanup_lock = threading.Lock()\n_cleanup_done = False\n_batch_exit_hooks_installed = False\n_prev_sigint_handler: Any = None\n_prev_sigterm_handler: Any = None\n\n\ndef _emit(payload: dict, *, file: Path | None = None) -> None:\n    \"\"\"Print one JSON line to stdout (always flushed) and optionally persist.\"\"\"\n    line = json.dumps(payload, ensure_ascii=False) + \"\\n\"\n    sys.stdout.write(line)\n    sys.stdout.flush()\n    if file is not None:\n        file.parent.mkdir(parents=True, exist_ok=True)\n        file.write_text(line, encoding=\"utf-8\")\n\n\ndef sandbox_json_path(out_dir: Path) -> Path:\n    return out_dir.resolve() / SANDBOX_JSON\n\n\ndef load_sandbox_info(out_dir: Path) -> dict[str, Any]:\n    path = sandbox_json_path(out_dir)\n    if not path.is_file():\n        raise FileNotFoundError(f\"{SANDBOX_JSON} not found under {out_dir}; run bootstrap first\")\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_sandbox_info(out_dir: Path, info: dict[str, Any]) -> Path:\n    path = sandbox_json_path(out_dir)\n    out_dir.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(info, indent=2, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n    return path\n\n\ndef _derive_sandbox_name(out_dir: Path) -> str:\n    base = out_dir.resolve().name\n    safe = re.sub(r\"[^a-zA-Z0-9._-]+\", \"-\", base).strip(\"-\").lower()\n    safe = safe[:48] or \"task\"\n    return f\"analyzer-{safe}\"\n\n\ndef _api_url_from_sb(sb: Any) -> str:\n    rt = getattr(sb, \"_runtime_info\", None)\n    if rt and getattr(rt, \"api_port\", None):\n        host = getattr(rt, \"host\", None) or \"127.0.0.1\"\n        return f\"http://{host}:{rt.api_port}\"\n    raise RuntimeError(\"sandbox has no api_port in runtime_info\")\n\n\ndef _merge_metadata_sandbox(out_dir: Path, name: str, api_url: str, local: bool) -> None:\n    meta = read_metadata(out_dir)\n    if not meta:\n        return\n    sandbox = dict(meta.get(\"sandbox\") or {})\n    sandbox[\"name\"] = name\n    sandbox[\"api_url\"] = api_url\n    sandbox[\"local\"] = local\n    update_metadata(out_dir, sandbox=sandbox)\n\n\ndef _connect_from_info(info: dict[str, Any]) -> Any:","numLines":100,"startLine":1,"totalLines":908}}}
